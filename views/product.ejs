<div class="pdp-wrapper">
    <div class="pdp-container">
        <!-- Breadcrumb Navigation -->
        <div class="pdp-breadcrumb">
            <a href="/">Home</a> <span>/</span> 
            <a href="/category/laptops">Tech</a> <span>/</span>
            <a href="/category/laptops">Laptops</a> <span>/</span>
            <span><%= product.title %></span>
        </div>

        <!-- TOP FOLD: Gallery, Main Info, Action Card -->
        <div class="pdp-top-fold">
            
            <!-- Column 1: Image Gallery -->
            <div class="pdp-gallery-col">
                <div class="pdp-main-image-box">
                    <span class="pdp-discount-badge">-25%</span>
                    <button class="pdp-wish-btn">🤍</button>
                    <button class="pdp-expand-btn">⤢</button>
                    <button class="pdp-nav-arrow left">‹</button>
                    <button class="pdp-nav-arrow right">›</button>

                    <div class="pdp-main-img" id="mainImageDisplay">
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.title %>" style="width:100%; height:100%; object-fit:contain">
                        <% } else { %>
                            <%= product.category.icon %>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Column 2: Main Info & Options -->
            <div class="pdp-info-col">
                <span class="pdp-best-seller-badge">Best Seller</span>
                
                <h1 class="pdp-title"><%= product.title %></h1>
                
                <div class="pdp-rating-row">
                    <span class="stars"><%= "★".repeat(Math.round(product.ratings.average)) %><%= "☆".repeat(5-Math.round(product.ratings.average)) %></span>
                    <span class="rating-val"><%= product.ratings.average %></span>
                    <span class="rating-count">(<%= product.ratings.count %> reviews)</span>
                    <span class="divider">|</span>
                    <span class="bought-tag">2K+ sold in past month</span>
                </div>

                <div class="pdp-price-row">
                    <span class="price-large">₹<%= product.price.toFixed(2) %></span>
                    <span class="mrp-text">₹<%= (product.price * 1.25).toFixed(2) %></span>
                    <span class="pdp-discount-tag">25% OFF</span>
                </div>
                <div class="tax-text">Inclusive of all taxes <span style="cursor:pointer; color:var(--text-mute)">ⓘ</span></div>

                <div class="pdp-stock-status">
                    <span class="stock-pill">In Stock</span>
                    <span class="delivery-estimation">📅 Free delivery by <strong>Tomorrow</strong></span>
                </div>

                <!-- Product specs metadata table matching mockup -->
                <div class="pdp-meta-table">
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Brand:</span>
                        <span class="pdp-meta-value"><%= product.brand || 'NeuraCart' %></span>
                    </div>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Category:</span>
                        <span class="pdp-meta-value">Laptops</span>
                    </div>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">SKU:</span>
                        <span class="pdp-meta-value">NC-NB-16-512-BK</span>
                    </div>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Warranty:</span>
                        <span class="pdp-meta-value">2 Years</span>
                    </div>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Seller:</span>
                        <span class="pdp-meta-value" style="color:var(--purple-primary)">NeuraCart Official Store <span style="font-size:10px; font-weight:bold; background:var(--purple-light); padding:2px 6px; border-radius:4px">✓ Verified</span></span>
                    </div>
                </div>

                <!-- Color Selection Circles -->
                <div class="pdp-color-picker">
                    <span class="color-label">Color: <strong>Space Black</strong></span>
                    <div class="color-options">
                        <div class="color-ring active" data-color="Space Black"><div class="color-circle" style="background:#1f2937"></div></div>
                        <div class="color-ring" data-color="Silver"><div class="color-circle" style="background:#e5e7eb"></div></div>
                        <div class="color-ring" data-color="Navy"><div class="color-circle" style="background:#1e3a8a"></div></div>
                        <div class="color-ring" data-color="Light Gray"><div class="color-circle" style="background:#f3f4f6"></div></div>
                    </div>
                </div>

                <!-- Storage Selection Buttons -->
                <div class="pdp-storage-picker">
                    <span class="color-label">Storage:</span>
                    <div class="storage-options">
                        <button class="storage-btn active">512GB SSD</button>
                        <button class="storage-btn">1TB SSD</button>
                        <button class="storage-btn">2TB SSD</button>
                    </div>
                </div>

                <!-- Quantity Selector -->
                <div class="quantity-picker">
                    <span class="color-label">Quantity:</span>
                    <div class="qty-container">
                        <button class="qty-btn" id="btnMinus">-</button>
                        <input type="text" class="qty-input" id="qtyVal" value="1" readonly>
                        <button class="qty-btn" id="btnPlus">+</button>
                    </div>
                </div>
            </div>

            <!-- Column 3: Cart Action Box Card -->
            <div class="pdp-action-card">
                <div class="pdp-action-bullets">
                    <div class="pdp-action-bullet-item">
                        <span class="pdp-action-bullet-icon">🚚</span>
                        <div>
                            <span class="pdp-action-bullet-title">Free Delivery</span>
                            <div class="pdp-action-bullet-desc">On orders above $100</div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet-item">
                        <span class="pdp-action-bullet-icon">🔒</span>
                        <div>
                            <span class="pdp-action-bullet-title">Secure Checkout</span>
                            <div class="pdp-action-bullet-desc">100% secure payments</div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet-item">
                        <span class="pdp-action-bullet-icon">🔄</span>
                        <div>
                            <span class="pdp-action-bullet-title">Easy Returns</span>
                            <div class="pdp-action-bullet-desc">7 days return policy</div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet-item">
                        <span class="pdp-action-bullet-icon">🏅</span>
                        <div>
                            <span class="pdp-action-bullet-title">2 Year Warranty</span>
                            <div class="pdp-action-bullet-desc">On all products</div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet-item">
                        <span class="pdp-action-bullet-icon">💳</span>
                        <div>
                            <span class="pdp-action-bullet-title">EMI Available</span>
                            <div class="pdp-action-bullet-desc">Starting from $299/month</div>
                        </div>
                    </div>
                </div>

                <div class="pdp-low-stock-alert">🔥 Only 6 left in stock!</div>

                <button class="btn-pdp btn-pdp-cart" id="pdpAddToCart" data-title="<%= product.title %>">
                    <span>🛒</span> Add to Cart
                </button>
                <button class="btn-pdp btn-pdp-buy">⚡ Buy Now</button>
                <button class="btn-pdp btn-pdp-wishlist">♡ Add to Wishlist</button>
                <button class="btn-pdp btn-pdp-compare">⇄ Compare</button>

                <div class="payment-methods-box">
                    <span>Payment Methods</span>
                    <div class="payment-logos">
                        💳 💱 🏦 💵
                    </div>
                </div>
            </div>
        </div>

        <!-- High-level specs chips row below top fold (dynamic from product.specifications) -->
        <div class="specs-chips-row">
            <% const chipSpecs = product.specifications && product.specifications.length > 0 ? product.specifications.slice(0, 4) : []; %>
            <% if (chipSpecs.length > 0) { %>
                <% chipSpecs.forEach((spec, i) => { %>
                    <%
                        const chipIcons = ['⚙️', '📊', '🔋', '🖥️'];
                        const chipDescs = ['Core performance', 'Seamless multitasking', 'Long-lasting power', 'Crystal clear view'];
                    %>
                    <div class="specs-chip-card">
                        <div class="specs-chip-icon"><%= chipIcons[i] || '✨' %></div>
                        <div>
                            <div class="specs-chip-title"><%= spec.key %>: <%= spec.value %></div>
                            <div class="specs-chip-desc"><%= chipDescs[i] || '' %></div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="specs-chip-card">
                    <div class="specs-chip-icon">📦</div>
                    <div>
                        <div class="specs-chip-title"><%= product.brand %></div>
                        <div class="specs-chip-desc"><%= product.subcategory %></div>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Tabbed Section matching user layout -->
        <div>
            <div class="tabs-navigation">
                <button class="tab-link active" data-tab="descTab">Description</button>
                <button class="tab-link" data-tab="specsTab">Specifications</button>
                <button class="tab-link" data-tab="reviewsTab">Reviews (<%= product.ratings.count %>)</button>
                <button class="tab-link" data-tab="faqTab">FAQ</button>
                <button class="tab-link" data-tab="shippingTab">Shipping & Delivery</button>
                <button class="tab-link" data-tab="warrantyTab">Warranty</button>
            </div>

            <!-- Description Tab Panel -->
            <div class="tab-pane active" id="descTab">
                <div>
                    <p class="desc-col-text">
                        <%= product.description %>
                    </p>
                    <ul class="desc-bullet-list">
                        <% const listItems = (product.highlights && product.highlights.length > 0)
                            ? product.highlights
                            : (product.bulletPoints && product.bulletPoints.length > 0 ? product.bulletPoints : []); %>
                        <% if (listItems.length > 0) { %>
                            <% listItems.forEach(item => { %>
                                <li>✓ <%= item %></li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>

                <!-- Right cards grid inside tab description -->
                <div class="tab-right-grid">
                    <div class="tab-grid-card">
                        <span class="tab-grid-card-title">Delivery</span>
                        <span class="tab-grid-card-value"><%= product.delivery || 'Standard delivery in 3–5 business days' %></span>
                        <span class="tab-grid-card-desc">Free on orders over ₹999</span>
                    </div>
                    <div class="tab-grid-card">
                        <span class="tab-grid-card-title">Returns</span>
                        <span class="tab-grid-card-value"><%= product.returnPolicy || '7-day easy returns' %></span>
                        <span class="tab-grid-card-desc">Hassle-free process</span>
                    </div>
                    <div class="tab-grid-card">
                        <span class="tab-grid-card-title">Warranty</span>
                        <span class="tab-grid-card-value"><%= product.warranty || '1 Year Warranty' %></span>
                        <span class="tab-grid-card-desc">Brand authorized service</span>
                    </div>
                    <div class="tab-grid-card">
                        <span class="tab-grid-card-title">EMI</span>
                        <span class="tab-grid-card-value">EMI Available</span>
                        <span class="tab-grid-card-desc"><%= product.emi || 'EMI options at checkout' %></span>
                    </div>
                </div>
            </div>

            <!-- Specifications Tab Panel -->
            <div class="tab-pane" id="specsTab" style="grid-template-columns: 1fr;">
                <div class="info-block-card">
                    <% if (product.specifications && product.specifications.length > 0) { %>
                    <table class="pdp-specs" style="width:100%">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--border-color);">
                                <th style="padding:12px 0; font-size:13px; font-weight:700; color:var(--text-sub); text-transform:uppercase; letter-spacing:0.5px;">Feature</th>
                                <th style="padding:12px 0; font-size:13px; font-weight:700; color:var(--text-sub); text-transform:uppercase; letter-spacing:0.5px;">Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% product.specifications.forEach((spec, i) => { %>
                                <tr style="background:<%= i % 2 === 0 ? 'transparent' : 'rgba(124,58,237,0.02)' %>;">
                                    <td style="font-weight:600; padding:14px 0; border-bottom:1px solid var(--border-color);"><%= spec.key %></td>
                                    <td style="color:var(--text-sub); padding:14px 0; border-bottom:1px solid var(--border-color);"><%= spec.value %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <% } else { %>
                        <p style="color:var(--text-sub); font-size:14px;">No specifications available for this product.</p>
                    <% } %>
                </div>
            </div>

            <!-- Reviews Tab Panel -->
            <div class="tab-pane" id="reviewsTab" style="grid-template-columns: 1fr;">
                <p style="color:var(--text-sub)">Refer to Customer Reviews section below.</p>
            </div>

            <!-- FAQ Tab Panel -->
            <div class="tab-pane" id="faqTab" style="grid-template-columns: 1fr;">
                <div class="info-block-card" style="display:flex; flex-direction:column; gap:16px;">
                    <div>
                        <h4 style="font-size:14px; font-weight:700; margin-bottom:6px;">Is this product original?</h4>
                        <p style="font-size:13px; color:var(--text-sub)">Yes, NeuraCart guarantees 100% original products sourced directly from brand suppliers.</p>
                    </div>
                </div>
            </div>

            <!-- Shipping & Delivery Tab -->
            <div class="tab-pane" id="shippingTab" style="grid-template-columns: 1fr;">
                <div class="info-block-card" style="display:flex; flex-direction:column; gap:16px;">
                    <% if (product.delivery) { %>
                    <div style="display:flex; align-items:flex-start; gap:12px;">
                        <span style="font-size:24px;">🚚</span>
                        <div>
                            <div style="font-weight:700; font-size:15px; margin-bottom:4px;">Delivery</div>
                            <p style="font-size:14px; line-height:1.6; color:var(--text-sub); margin:0;"><%= product.delivery %></p>
                        </div>
                    </div>
                    <% } %>
                    <% if (product.returnPolicy) { %>
                    <div style="display:flex; align-items:flex-start; gap:12px; padding-top:12px; border-top:1px solid var(--border-color);">
                        <span style="font-size:24px;">↩️</span>
                        <div>
                            <div style="font-weight:700; font-size:15px; margin-bottom:4px;">Return Policy</div>
                            <p style="font-size:14px; line-height:1.6; color:var(--text-sub); margin:0;"><%= product.returnPolicy %></p>
                        </div>
                    </div>
                    <% } %>
                    <% if (product.emi) { %>
                    <div style="display:flex; align-items:flex-start; gap:12px; padding-top:12px; border-top:1px solid var(--border-color);">
                        <span style="font-size:24px;">💳</span>
                        <div>
                            <div style="font-weight:700; font-size:15px; margin-bottom:4px;">EMI Options</div>
                            <p style="font-size:14px; line-height:1.6; color:var(--text-sub); margin:0;"><%= product.emi %></p>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Warranty Tab -->
            <div class="tab-pane" id="warrantyTab" style="grid-template-columns: 1fr;">
                <div class="info-block-card" style="display:flex; flex-direction:column; gap:16px;">
                    <div style="display:flex; align-items:flex-start; gap:12px;">
                        <span style="font-size:24px;">🛡️</span>
                        <div>
                            <div style="font-weight:700; font-size:15px; margin-bottom:4px;">Warranty Coverage</div>
                            <p style="font-size:14px; line-height:1.6; color:var(--text-sub); margin:0;">
                                <%= product.warranty || '1 Year Manufacturer Warranty' %>
                            </p>
                        </div>
                    </div>
                    <div style="display:flex; align-items:flex-start; gap:12px; padding-top:12px; border-top:1px solid var(--border-color);">
                        <span style="font-size:24px;">✅</span>
                        <div>
                            <div style="font-weight:700; font-size:15px; margin-bottom:4px;">What's Covered</div>
                            <p style="font-size:14px; line-height:1.6; color:var(--text-sub); margin:0;">Manufacturing defects, hardware failures, and component malfunctions under normal usage conditions.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feature Highlights Banner (dynamic from product.features) -->
        <% if (product.features && product.features.length > 0) { %>
        <div class="highlights-banner">
            <% product.features.forEach(feat => { %>
            <div class="highlight-banner-item">
                <span class="highlight-banner-icon"><%= feat.icon %></span>
                <div>
                    <div class="highlight-banner-title"><%= feat.title %></div>
                    <div class="highlight-banner-desc"><%= feat.description %></div>
                </div>
            </div>
            <% }) %>
        </div>
        <% } %>

        <!-- Customer Reviews Section -->
        <div class="reviews-section-card">
            <!-- Section Header -->
            <div class="reviews-header-block">
                <div>
                    <h3 class="reviews-header-title">⭐ Customer Reviews</h3>
                    <div style="font-size: 13px; color: var(--text-sub); margin-top: 4px;">See what our customers are saying about this product</div>
                </div>
                <button class="btn-premium-review" data-bs-toggle="modal" data-bs-target="#writeReviewModal">
                    <i class="bi bi-pencil-square"></i> Write a Review
                </button>
            </div>

            <!-- Review Summary Cards -->
            <div class="reviews-summary-grid">
                <!-- Card 1: Main Stats -->
                <div class="summary-card-premium text-center">
                    <div class="big-rating-val"><%= product.ratings.average %> <span style="font-size:20px; color:var(--text-mute); font-weight:500">/ 5</span></div>
                    <div class="rating-total-stars">
                        <%= "★".repeat(Math.round(product.ratings.average)) %><%= "☆".repeat(5-Math.round(product.ratings.average)) %>
                    </div>
                    <div style="font-size: 12px; color: var(--text-mute); margin-bottom: 8px;">Based on <%= product.ratings.count %> verified reviews</div>
                    <div class="recommend-text justify-content-center">
                        <i class="bi bi-hand-thumbs-up-fill"></i> 96% of customers recommend this product
                    </div>
                </div>

                <!-- Card 2: Rating Distribution -->
                <div class="summary-card-premium gap-2">
                    <div class="dist-row">
                        <span>5 ★</span>
                        <div class="progress-premium">
                            <div class="progress-bar-premium" style="width: 82%; background:#7c3aed"></div>
                        </div>
                        <span class="text-end">82%</span>
                    </div>
                    <div class="dist-row">
                        <span>4 ★</span>
                        <div class="progress-premium">
                            <div class="progress-bar-premium" style="width: 13%; background:#a855f7"></div>
                        </div>
                        <span class="text-end">13%</span>
                    </div>
                    <div class="dist-row">
                        <span>3 ★</span>
                        <div class="progress-premium">
                            <div class="progress-bar-premium" style="width: 3%; background:#fb923c"></div>
                        </div>
                        <span class="text-end">3%</span>
                    </div>
                    <div class="dist-row">
                        <span>2 ★</span>
                        <div class="progress-premium">
                            <div class="progress-bar-premium" style="width: 1%; background:#f472b6"></div>
                        </div>
                        <span class="text-end">1%</span>
                    </div>
                    <div class="dist-row">
                        <span>1 ★</span>
                        <div class="progress-premium">
                            <div class="progress-bar-premium" style="width: 1%; background:#ef4444"></div>
                        </div>
                        <span class="text-end">0.5%</span>
                    </div>
                </div>

                <!-- Card 3: Metrics -->
                <div class="summary-card-premium">
                    <div class="stats-cards-grid">
                        <div class="stat-item-premium">
                            <div class="stat-item-icon"><i class="bi bi-chat-left-text"></i></div>
                            <div class="stat-item-num"><%= product.ratings.count %></div>
                            <div class="stat-item-lbl">Total Reviews</div>
                        </div>
                        <div class="stat-item-premium">
                            <div class="stat-item-icon"><i class="bi bi-patch-check"></i></div>
                            <div class="stat-item-num">1,196</div>
                            <div class="stat-item-lbl">Verified Buyers</div>
                        </div>
                        <div class="stat-item-premium">
                            <div class="stat-item-icon"><i class="bi bi-image"></i></div>
                            <div class="stat-item-num">642</div>
                            <div class="stat-item-lbl">With Photos</div>
                        </div>
                        <div class="stat-item-premium">
                            <div class="stat-item-icon"><i class="bi bi-hand-thumbs-up"></i></div>
                            <div class="stat-item-num">1,198</div>
                            <div class="stat-item-lbl">Helpful Votes</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filter Chips Bar -->
            <div class="filter-bar-premium">
                <div class="filter-chips">
                    <button class="filter-chip-btn active" data-filter="all">All Reviews</button>
                    <button class="filter-chip-btn" data-filter="5">5 ★</button>
                    <button class="filter-chip-btn" data-filter="4">4 ★</button>
                    <button class="filter-chip-btn" data-filter="3">3 ★</button>
                    <button class="filter-chip-btn" data-filter="2">2 ★</button>
                    <button class="filter-chip-btn" data-filter="1">1 ★</button>
                    <button class="filter-chip-btn" data-filter="photos">With Photos</button>
                    <button class="filter-chip-btn" data-filter="verified">Verified Buyers</button>
                </div>
                
                <div class="d-flex align-items-center gap-2">
                    <span style="font-size:12px; font-weight:600; color:var(--text-sub)">Sort by:</span>
                    <select class="sort-select-premium" id="reviewSort">
                        <option value="newest">Latest</option>
                        <option value="helpful">Most Helpful</option>
                        <option value="highest">Highest Rating</option>
                        <option value="lowest">Lowest Rating</option>
                    </select>
                </div>
            </div>

            <!-- Review Cards Grid -->
            <div class="reviews-grid-premium" id="reviewsGrid">
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach((review, index) => { %>
                        <div class="review-card-premium" data-rating="<%= review.rating %>" data-verified="true" data-photos="<%= index === 0 ? 'true' : 'false' %>">
                            <div>
                                <!-- Card Header -->
                                <div class="review-header-premium">
                                    <div class="review-avatar-premium">
                                        <%= review.user.name.charAt(0) %>
                                    </div>
                                    <div class="review-meta-premium">
                                        <span class="review-author-name"><%= review.user.name %></span>
                                        <span class="review-verified-badge"><i class="bi bi-patch-check-fill"></i> Verified Purchase</span>
                                    </div>
                                    <span class="review-date-premium ms-auto"><%= review.createdAt.toLocaleDateString() %></span>
                                    <button class="review-menu-btn"><i class="bi bi-three-dots-vertical"></i></button>
                                </div>

                                <!-- Rating & Title -->
                                <div class="review-stars-row my-2">
                                    <span><%= "★".repeat(review.rating) %><%= "☆".repeat(5-review.rating) %></span>
                                    <span class="review-stars-val"><%= review.rating.toFixed(1) %></span>
                                </div>
                                <div class="review-title-premium">
                                    <%= index === 0 ? "Amazing performance and battery life!" : (index === 1 ? "Perfect for designers and developers" : "Super fast and sleek design") %>
                                </div>

                                <!-- Review Body Description -->
                                <p class="review-body-premium">
                                    <%= review.comment %>
                                </p>
                                <button class="read-more-btn">Read More</button>

                                <!-- Review Photos (For mockup first review has photos) -->
                                <% if (index === 0) { %>
                                    <div class="review-photos-grid">
                                        <div class="review-photo-item"><img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=150" alt="review upload" class="lightbox-trigger"></div>
                                        <div class="review-photo-item"><img src="https://images.unsplash.com/photo-1541807084-5c52b6b3adef?w=150" alt="review upload" class="lightbox-trigger"></div>
                                        <div class="review-photo-item"><img src="https://images.unsplash.com/photo-1496181130204-7552cc1524e2?w=150" alt="review upload" class="lightbox-trigger"></div>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Footer Actions -->
                            <div class="review-footer-premium">
                                <div class="review-footer-actions">
                                    <button class="btn-footer-action btn-helpful-action">
                                        <i class="bi bi-hand-thumbs-up"></i> Helpful (<span class="helpful-count-val"><%= index === 0 ? "12" : (index === 1 ? "8" : "5") %></span>)
                                    </button>
                                    <button class="btn-footer-action"><i class="bi bi-reply"></i> Reply</button>
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn-footer-action" style="padding:4px"><i class="bi bi-share"></i></button>
                                    <button class="btn-footer-action" style="padding:4px"><i class="bi bi-flag"></i></button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="color:var(--text-sub); grid-column:1/-1; text-align:center">No reviews yet. Be the first to review this product!</p>
                <% } %>
            </div>

            <!-- Bottom CTA ribbon -->
            <div class="bottom-cta-premium">
                <div>
                    <div class="bottom-cta-title">Have you purchased this product?</div>
                    <div class="bottom-cta-desc">Share your experience to help other customers make the right choice.</div>
                </div>
                <button class="btn-premium-review" data-bs-toggle="modal" data-bs-target="#writeReviewModal">
                    <i class="bi bi-pencil-square"></i> Write a Review
                </button>
            </div>
        </div>

        <!-- Write Review Modal -->
        <div class="modal fade" id="writeReviewModal" tabindex="-1" aria-labelledby="writeReviewModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" style="max-width:700px;">
                <div class="modal-content modal-content-premium">

                    <!-- Product Context Header -->
                    <div style="display:flex; align-items:center; gap:14px; padding:20px 28px 16px; border-bottom:1px solid var(--border-color); background:linear-gradient(135deg, rgba(124,58,237,0.04), rgba(168,85,247,0.04));">
                        <div style="width:56px; height:56px; border-radius:12px; overflow:hidden; border:1px solid var(--border-color); flex-shrink:0; background:#f9fafb; display:flex; align-items:center; justify-content:center;">
                            <% if (product.image) { %>
                                <img src="<%= product.image %>" alt="<%= product.title %>" style="width:100%; height:100%; object-fit:cover;">
                            <% } else { %>
                                <span style="font-size:28px;"><%= product.category.icon %></span>
                            <% } %>
                        </div>
                        <div style="flex:1; min-width:0;">
                            <div style="font-size:11px; font-weight:700; color:var(--purple-primary); text-transform:uppercase; letter-spacing:0.6px; margin-bottom:2px;">Writing a review for</div>
                            <div style="font-size:15px; font-weight:800; color:var(--text-main); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= product.title %></div>
                            <div style="font-size:12px; color:var(--text-mute); margin-top:1px;"><%= product.brand %> &middot; <%= product.subcategory %></div>
                        </div>
                        <button type="button" class="modal-close-btn-premium" data-bs-dismiss="modal" aria-label="Close" id="reviewModalCloseBtn">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                    <form action="#" method="POST" id="writeReviewForm">
                        <div class="modal-body-premium" style="padding:24px 28px; display:flex; flex-direction:column; gap:22px; max-height:65vh; overflow-y:auto;">

                            <!-- Star Rating Selector -->
                            <div class="star-rating-selector-premium">
                                <label class="form-label-premium">Overall Rating <span style="color:#ef4444">*</span></label>
                                <div class="stars-row-premium" id="modalStarSelector">
                                    <span data-value="1">★</span>
                                    <span data-value="2">★</span>
                                    <span data-value="3">★</span>
                                    <span data-value="4">★</span>
                                    <span data-value="5">★</span>
                                </div>
                                <div class="stars-text-premium" id="modalStarText">Tap to rate</div>
                                <input type="hidden" name="rating" id="reviewRatingInput" value="">
                            </div>

                            <!-- Review Title -->
                            <div>
                                <label for="reviewTitle" class="form-label-premium">Review Title <span style="color:#ef4444">*</span></label>
                                <input type="text" class="form-control-premium" id="reviewTitle" name="reviewTitle" placeholder="e.g. Amazing product, highly recommend!" required>
                            </div>

                            <!-- Review Description -->
                            <div>
                                <label for="reviewComment" class="form-label-premium">Your Experience <span style="color:#ef4444">*</span></label>
                                <textarea class="form-control-premium" id="reviewComment" name="comment" rows="5" style="min-height:130px; resize:vertical;" placeholder="What did you like or dislike? How was the quality, packaging, delivery?" required></textarea>
                            </div>

                            <!-- Image Upload Box -->
                            <div>
                                <label class="form-label-premium">Photos <span style="font-size:12px; font-weight:400; color:var(--text-mute)">(Optional)</span></label>
                                <div class="upload-drag-box-premium" id="modalDragBox">
                                    <i class="bi bi-cloud-upload"></i>
                                    <div class="upload-drag-text">Drag & Drop or <span style="color:var(--purple-primary); text-decoration:underline; cursor:pointer;">Browse Files</span></div>
                                    <div class="upload-drag-sub">PNG, JPG, JPEG &middot; Max 5MB per image</div>
                                </div>
                                <input type="file" id="modalImageUpload" name="images" multiple accept="image/*" style="display:none">
                                <div class="preview-thumbnails-container" id="modalPreviewsContainer"></div>
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="modal-footer-premium" style="padding:16px 28px 20px; border-top:1px solid var(--border-color); display:flex; justify-content:space-between; align-items:center;">
                            <div style="font-size:12px; color:var(--text-mute);">All fields marked <span style="color:#ef4444;">*</span> are required.</div>
                            <div style="display:flex; gap:12px;">
                                <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn-modal-submit" id="reviewSubmitBtn">
                                    <i class="bi bi-check-circle" style="margin-right:6px;"></i>Submit Review
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Lightbox popup modal -->
        <div class="lightbox-modal-premium" id="lightboxModal">
            <div class="lightbox-content-box">
                <button class="lightbox-close-btn" id="lightboxClose">&times;</button>
                <img src="" alt="expanded review photo" class="lightbox-img" id="lightboxImage">
            </div>
        </div>



        <!-- You May Also Like Section -->
        <div>
            <h3 class="similar-section-title">You May Also Like</h3>
            <div class="slider-grid" id="similarProductsGrid">
                <!-- Mockup slider cards -->
                <a href="#" class="slider-card">
                    <div class="slider-card-img">💻</div>
                    <div class="slider-card-title">NeuraBook Air 14</div>
                    <div class="slider-card-rating">★★★★★ 4.8</div>
                    <div class="slider-card-price">₹1,299.00</div>
                </a>
                <a href="#" class="slider-card">
                    <div class="slider-card-img">💻</div>
                    <div class="slider-card-title">NeuraBook Pro 14</div>
                    <div class="slider-card-rating">★★★★★ 4.7</div>
                    <div class="slider-card-price">₹1,799.00</div>
                </a>
                <a href="#" class="slider-card active-card">
                    <div class="slider-card-img">💻</div>
                    <div class="slider-card-title">NeuraBook Pro 16</div>
                    <div class="slider-card-rating">★★★★★ 4.9</div>
                    <div class="slider-card-price">₹1,999.00</div>
                </a>
                <a href="#" class="slider-card">
                    <div class="slider-card-img">💻</div>
                    <div class="slider-card-title">NeuraBook Max 16</div>
                    <div class="slider-card-rating">★★★★★ 4.8</div>
                    <div class="slider-card-price">₹2,299.00</div>
                </a>
                <a href="#" class="slider-card">
                    <div class="slider-card-img">💻</div>
                    <div class="slider-card-title">NeuraBook Studio</div>
                    <div class="slider-card-rating">★★★★☆ 4.6</div>
                    <div class="slider-card-price">₹1,599.00</div>
                </a>
                <a href="#" class="slider-card">
                    <div class="slider-card-img">💻</div>
                    <div class="slider-card-title">NeuraBook Lite</div>
                    <div class="slider-card-rating">★★★★☆ 4.5</div>
                    <div class="slider-card-price">₹999.00</div>
                </a>
            </div>
        </div>

        <!-- Global Bottom Assurance Bar -->
        <div class="bottom-assurance-bar">
            <div class="assurance-item">
                <span class="assurance-icon">🛍️</span>
                <div>
                    <div class="assurance-title">100% Original Products</div>
                    <div class="assurance-desc">Sourced directly from brands</div>
                </div>
            </div>
            <div class="assurance-item">
                <span class="assurance-icon">💳</span>
                <div>
                    <div class="assurance-title">Secure Payments</div>
                    <div class="assurance-desc">Multiple payment options</div>
                </div>
            </div>
            <div class="assurance-item">
                <span class="assurance-icon">📞</span>
                <div>
                    <div class="assurance-title">24/7 Customer Support</div>
                    <div class="assurance-desc">We're here to help you</div>
                </div>
            </div>
            <div class="assurance-item">
                <span class="assurance-icon">⭐</span>
                <div>
                    <div class="assurance-title">Trusted by 1M+ Customers</div>
                    <div class="assurance-desc">4.9 average store rating</div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="toast-container">
    <div class="toast-box" id="pdpToast">
        <span style="color:#10b981; font-weight:bold">✓</span> <span id="pdpToastMsg">Added to cart!</span>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Main image reference (thumbnails removed)
        const mainImageDisplay = document.getElementById("mainImageDisplay");

        // Color selector active state switching
        const colorRings = document.querySelectorAll(".color-ring");
        const colorLabel = document.querySelector(".color-label strong");
        colorRings.forEach(ring => {
            ring.addEventListener("click", () => {
                colorRings.forEach(r => r.classList.remove("active"));
                ring.classList.add("active");
                if (colorLabel) {
                    colorLabel.textContent = ring.getAttribute("data-color");
                }
            });
        });

        // Storage selector active state switching
        const storageBtns = document.querySelectorAll(".storage-btn");
        storageBtns.forEach(btn => {
            btn.addEventListener("click", () => {
                storageBtns.forEach(b => b.classList.remove("active"));
                btn.classList.add("active");
            });
        });

        // Quantity controls
        const btnMinus = document.getElementById("btnMinus");
        const btnPlus = document.getElementById("btnPlus");
        const qtyVal = document.getElementById("qtyVal");
        
        if (btnMinus && btnPlus && qtyVal) {
            btnMinus.addEventListener("click", () => {
                let v = parseInt(qtyVal.value);
                if (v > 1) qtyVal.value = v - 1;
            });
            btnPlus.addEventListener("click", () => {
                let v = parseInt(qtyVal.value);
                qtyVal.value = v + 1;
            });
        }

        // Add to Cart Action & Toast
        const pdpAddToCart = document.getElementById("pdpAddToCart");
        const pdpToast = document.getElementById("pdpToast");
        const pdpToastMsg = document.getElementById("pdpToastMsg");
        
        if (pdpAddToCart && pdpToast && pdpToastMsg) {
            pdpAddToCart.addEventListener("click", () => {
                const title = pdpAddToCart.getAttribute("data-title");
                const qty = qtyVal ? qtyVal.value : 1;
                
                pdpToastMsg.innerHTML = `Added <strong>${qty}x ${title}</strong> to cart successfully!`;
                pdpToast.classList.add("show");
                
                setTimeout(() => {
                    pdpToast.classList.remove("show");
                }, 3000);
            });
        }

        // Horizontal tabs click switching
        const tabLinks = document.querySelectorAll(".tab-link");
        const tabPanes = document.querySelectorAll(".tab-pane");
        
        tabLinks.forEach(link => {
            link.addEventListener("click", () => {
                tabLinks.forEach(l => l.classList.remove("active"));
                tabPanes.forEach(p => {
                    p.classList.remove("active");
                    p.style.display = "none";
                });
                
                link.classList.add("active");
                const targetPane = document.getElementById(link.getAttribute("data-tab"));
                if (targetPane) {
                    targetPane.classList.add("active");
                    targetPane.style.display = (link.getAttribute("data-tab") === "descTab") ? "grid" : "block";
                }
            });
        });

        // Fetch AI recommendations asynchronously and populate similar products grid
        const productId = "<%= product._id %>";
        const similarProductsGrid = document.getElementById("similarProductsGrid");
        
        if (productId && similarProductsGrid) {
            fetch(`/api/products/${productId}/recommendations`)
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.data && data.data.length > 0) {
                        const html = data.data.map(p => `
                            <a href="/product/${p._id}" class="slider-card ${p._id === productId ? 'active-card' : ''}">
                                <div class="slider-card-img">
                                    ${p.category ? p.category.icon : '📁'}
                                </div>
                                <div class="slider-card-title">${p.title}</div>
                                <div class="slider-card-rating">
                                    ★ ${p.ratings ? p.ratings.average : '0'} (${p.ratings ? p.ratings.count : '0'})
                                </div>
                                <div class="slider-card-price">₹${p.price.toFixed(2)}</div>
                            </a>
                        `).join('');
                        similarProductsGrid.innerHTML = html;
                    }
                })
                .catch(err => console.error("Error loading recommendations", err));
        }

        // --------------------------------------------------
        // Redesigned Review Interactions
        // --------------------------------------------------

        // 1. Read More / Read Less toggles
        document.querySelectorAll(".review-card-premium").forEach(card => {
            const body = card.querySelector(".review-body-premium");
            const btn = card.querySelector(".read-more-btn");
            if (body && btn) {
                // If text is short, hide the button
                if (body.scrollHeight <= body.clientHeight) {
                    btn.style.display = "none";
                }
                btn.addEventListener("click", () => {
                    const isExpanded = body.classList.toggle("expanded");
                    btn.textContent = isExpanded ? "Read Less" : "Read More";
                });
            }
        });

        // 2. Helpful vote click counter
        document.querySelectorAll(".btn-helpful-action").forEach(btn => {
            btn.addEventListener("click", () => {
                const countSpan = btn.querySelector(".helpful-count-val");
                const icon = btn.querySelector("i");
                if (countSpan && icon) {
                    let count = parseInt(countSpan.textContent.trim()) || 0;
                    const isLiked = icon.classList.toggle("bi-hand-thumbs-up-fill");
                    icon.classList.toggle("bi-hand-thumbs-up", !isLiked);
                    if (isLiked) {
                        count++;
                        btn.style.color = "var(--purple-primary)";
                        btn.style.background = "var(--purple-light)";
                    } else {
                        count--;
                        btn.style.color = "";
                        btn.style.background = "";
                    }
                    countSpan.textContent = count;
                }
            });
        });

        // 3. Photo Lightbox Modal
        const lightbox = document.getElementById("lightboxModal");
        const lightboxImg = document.getElementById("lightboxImage");
        const lightboxClose = document.getElementById("lightboxClose");

        if (lightbox && lightboxImg && lightboxClose) {
            document.querySelectorAll(".lightbox-trigger").forEach(img => {
                img.addEventListener("click", () => {
                    lightboxImg.src = img.src;
                    lightbox.style.display = "flex";
                });
            });

            lightboxClose.addEventListener("click", () => {
                lightbox.style.display = "none";
            });

            lightbox.addEventListener("click", (e) => {
                if (e.target === lightbox) {
                    lightbox.style.display = "none";
                }
            });
        }

        // ============================================================
        // 4. Write a Review Modal — Full UX Logic
        // ============================================================
        (function () {
            const reviewModal = document.getElementById('writeReviewModal');
            if (!reviewModal) return;

            const bsModal = new bootstrap.Modal(reviewModal, { backdrop: true, keyboard: true });

            // ---------- Open Triggers ----------
            document.querySelectorAll('[data-bs-target="#writeReviewModal"]').forEach(btn => {
                btn.addEventListener('click', () => bsModal.show());
            });

            // ---------- Body Scroll Lock ----------
            reviewModal.addEventListener('show.bs.modal', () => {
                document.body.style.overflow = 'hidden';
                resetForm();
            });
            reviewModal.addEventListener('hidden.bs.modal', () => {
                document.body.style.overflow = '';
            });

            // ---------- Reset form on open ----------
            function resetForm() {
                const form = document.getElementById('writeReviewForm');
                if (form) form.reset();
                ratingInput.value = '';
                if (starText) starText.textContent = 'Tap to rate';
                if (starText) starText.style.color = '#94a3b8';
                modalStars.forEach(s => { s.classList.remove('selected'); s.classList.remove('hovered'); });
                if (previewsContainer) previewsContainer.innerHTML = '';
                if (reviewSubmitBtn) {
                    reviewSubmitBtn.disabled = false;
                    reviewSubmitBtn.innerHTML = '<i class="bi bi-check-circle" style="margin-right:6px;"></i>Submit Review';
                }
            }

            // ---------- Star Rating ----------
            const modalStars = document.querySelectorAll('#modalStarSelector span');
            const ratingInput = document.getElementById('reviewRatingInput');
            const starText = document.getElementById('modalStarText');
            const ratingLabels = { 1: '😞 Poor', 2: '😐 Fair', 3: '🙂 Good', 4: '😊 Very Good', 5: '🤩 Excellent' };

            if (starText) starText.style.color = '#94a3b8';

            modalStars.forEach(star => {
                star.addEventListener('click', () => {
                    const val = parseInt(star.getAttribute('data-value'));
                    ratingInput.value = val;
                    if (starText) {
                        starText.textContent = ratingLabels[val] || '';
                        starText.style.color = '#f59e0b';
                    }
                    modalStars.forEach(s => {
                        s.classList.toggle('selected', parseInt(s.getAttribute('data-value')) <= val);
                    });
                });

                star.addEventListener('mouseenter', () => {
                    const val = parseInt(star.getAttribute('data-value'));
                    modalStars.forEach(s => {
                        s.classList.toggle('hovered', parseInt(s.getAttribute('data-value')) <= val);
                    });
                });

                star.addEventListener('mouseleave', () => {
                    modalStars.forEach(s => s.classList.remove('hovered'));
                });
            });

            // ---------- Form Submit ----------
            const reviewSubmitBtn = document.getElementById('reviewSubmitBtn');
            const writeReviewForm = document.getElementById('writeReviewForm');
            if (writeReviewForm) {
                writeReviewForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    if (!ratingInput.value) {
                        if (starText) {
                            starText.textContent = '⚠️ Please select a rating';
                            starText.style.color = '#ef4444';
                        }
                        return;
                    }
                    // Show loading state
                    if (reviewSubmitBtn) {
                        reviewSubmitBtn.disabled = true;
                        reviewSubmitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';
                    }
                    // Simulate async submission — replace with real fetch/form post
                    setTimeout(() => {
                        bsModal.hide();
                        // Optionally show a toast/success notification here
                    }, 1200);
                });
            }

            // ---------- Drag & Drop Image Uploader ----------
            const dragBox = document.getElementById('modalDragBox');
            const fileInput = document.getElementById('modalImageUpload');
            const previewsContainer = document.getElementById('modalPreviewsContainer');

            if (dragBox && fileInput && previewsContainer) {
                dragBox.addEventListener('click', () => fileInput.click());

                dragBox.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    dragBox.style.borderColor = 'var(--purple-primary)';
                    dragBox.style.background = 'var(--purple-light)';
                });

                dragBox.addEventListener('dragleave', () => {
                    dragBox.style.borderColor = '';
                    dragBox.style.background = '';
                });

                dragBox.addEventListener('drop', (e) => {
                    e.preventDefault();
                    dragBox.style.borderColor = '';
                    dragBox.style.background = '';
                    if (e.dataTransfer.files.length > 0) {
                        fileInput.files = e.dataTransfer.files;
                        handleFiles(e.dataTransfer.files);
                    }
                });

                fileInput.addEventListener('change', () => handleFiles(fileInput.files));

                function handleFiles(files) {
                    previewsContainer.innerHTML = '';
                    Array.from(files).forEach((file, index) => {
                        if (!file.type.startsWith('image/')) return;
                        const reader = new FileReader();
                        reader.onload = (e) => {
                            const item = document.createElement('div');
                            item.className = 'preview-thumb-item';
                            item.innerHTML = `
                                <img src="${e.target.result}" alt="preview">
                                <button type="button" class="preview-thumb-delete" data-index="${index}">&times;</button>
                            `;
                            item.querySelector('.preview-thumb-delete').addEventListener('click', (evt) => {
                                evt.stopPropagation();
                                item.remove();
                            });
                            previewsContainer.appendChild(item);
                        };
                        reader.readAsDataURL(file);
                    });
                }
            }
        })();

        // 5. Filter Chips Interactivity
        const filterBtns = document.querySelectorAll(".filter-chip-btn");
        const reviewCards = document.querySelectorAll(".review-card-premium");

        filterBtns.forEach(btn => {
            btn.addEventListener("click", () => {
                filterBtns.forEach(b => b.classList.remove("active"));
                btn.classList.add("active");

                const filter = btn.getAttribute("data-filter");
                reviewCards.forEach(card => {
                    if (filter === "all") {
                        card.style.display = "flex";
                    } else if (filter === "photos") {
                        card.style.display = card.getAttribute("data-photos") === "true" ? "flex" : "none";
                    } else if (filter === "verified") {
                        card.style.display = card.getAttribute("data-verified") === "true" ? "flex" : "none";
                    } else {
                        // Rating filters (5, 4, 3, 2, 1)
                        const rating = card.getAttribute("data-rating");
                        card.style.display = rating === filter ? "flex" : "none";
                    }
                });
            });
        });

        // 6. Review Sorting Interactivity
        const sortSelect = document.getElementById("reviewSort");
        const reviewsContainer = document.getElementById("reviewsGrid");

        if (sortSelect && reviewsContainer && reviewCards.length > 0) {
            sortSelect.addEventListener("change", () => {
                const sortBy = sortSelect.value;
                const cardsArray = Array.from(reviewCards);

                cardsArray.sort((a, b) => {
                    const ratingA = parseFloat(a.getAttribute("data-rating")) || 0;
                    const ratingB = parseFloat(b.getAttribute("data-rating")) || 0;
                    const helpfulA = parseInt(a.querySelector(".helpful-count-val")?.textContent || 0);
                    const helpfulB = parseInt(b.querySelector(".helpful-count-val")?.textContent || 0);

                    if (sortBy === "highest") {
                        return ratingB - ratingA;
                    } else if (sortBy === "lowest") {
                        return ratingA - ratingB;
                    } else if (sortBy === "helpful") {
                        return helpfulB - helpfulA;
                    } else {
                        // Latest
                        return 0; 
                    }
                });

                // Clear and re-append sorted nodes
                cardsArray.forEach(card => reviewsContainer.appendChild(card));
            });
        }
    });
</script>
