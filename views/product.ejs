<% if (typeof product === 'undefined' || !product) { %>
<div class="pdp-page" style="display: flex; justify-content: center; align-items: center; min-height: 70vh;">
    <div class="pdp-error-container" style="text-align: center; padding: 40px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; max-width: 500px; backdrop-filter: blur(10px);">
        <div style="font-size: 64px; margin-bottom: 20px;">🔍</div>
        <h1 style="font-size: 24px; margin-bottom: 12px; font-weight: 600;">Product Not Found</h1>
        <p style="color: var(--text-muted); font-size: 15px; line-height: 1.6; margin-bottom: 24px;">
            <%= typeof error !== 'undefined' ? error : "The product you're looking for might have been removed or does not exist." %>
        </p>
        <a href="/shop" style="display: inline-block; padding: 10px 24px; background: var(--grad-main); color: white; border-radius: 8px; text-decoration: none; font-weight: 500; font-size: 14px;">Back to Shop</a>
    </div>
</div>
<% } else { %>
<div class="pdp-page">
    <div class="pdp-container">
        
        <!-- Breadcrumbs -->
        <div class="pdp-breadcrumb">
            <a href="/">Home</a> <span>›</span> 
            <a href="/shop">Shop</a> <span>›</span>
            <a href="/shop?category=<%= (product.category && product.category.slug) ? product.category.slug : 'general' %>"><%= (product.category && product.category.name) ? product.category.name : 'General' %></a> <span>›</span>
            <span><%= product.title || 'Untitled Product' %></span>
        </div>

        <!-- Top Fold -->
        <div class="pdp-top-fold">
            
            <!-- Gallery -->
            <div class="pdp-gallery-col">
                <div class="pdp-main-img-box">
                    <% if (product.isFeatured) { %>
                        <span class="pdp-badge">Featured</span>
                    <% } %>
                    <div class="pdp-main-img" id="mainImageDisplay">
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.title || 'Product Image' %>" data-product-image>
                        <% } else { %>
                            <span style="font-size: 80px"><%= (product.category && product.category.icon) ? product.category.icon : '📁' %></span>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Info -->
            <div class="pdp-info-col">
                <h1 class="pdp-title"><%= product.title || 'Untitled Product' %></h1>
                
                <div class="pdp-rating-row">
                    <span class="pdp-rating-stars">
                        <% for(let i=1; i<=5; i++) { %>
                            <i class="<%= i <= Math.round(product.ratings ? product.ratings.average : (product.rating || 0)) ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                        <% } %>
                    </span>
                    <span><%= product.ratings ? product.ratings.average : (product.rating || 0) %></span>
                    <span>(<%= product.ratings ? product.ratings.count : 0 %> reviews)</span>
                </div>

                <div class="pdp-price-row">
                    <span class="pdp-price">₹<%= (product.price || 0).toFixed(2) %></span>
                    <span class="pdp-price-old">₹<%= ((product.price || 0) * 1.25).toFixed(2) %></span>
                    <span class="pdp-stock-pill"><%= (product.stock || 0) > 0 ? 'In Stock' : 'Out of Stock' %></span>
                </div>

                <div class="pdp-meta-table">
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Brand</span>
                        <span class="pdp-meta-value"><%= product.brand || 'NeuraCart' %></span>
                    </div>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Category</span>
                        <span class="pdp-meta-value"><%= (product.category && product.category.name) ? product.category.name : 'General' %></span>
                    </div>
                    <% if(product.subcategory) { %>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Subcategory</span>
                        <span class="pdp-meta-value"><%= product.subcategory %></span>
                    </div>
                    <% } %>
                </div>

                <div class="pdp-desc-text">
                    <%- product.description %>
                </div>
            </div>

            <!-- Action Card -->
            <div class="pdp-action-card">
                <div class="pdp-action-bullets">
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-truck pdp-action-icon"></i>
                        <div>
                            <div class="pdp-action-title">Free Delivery</div>
                            <div class="pdp-action-desc"><%= product.delivery || 'On orders above ₹999' %></div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-shield-halved pdp-action-icon"></i>
                        <div>
                            <div class="pdp-action-title">Warranty</div>
                            <div class="pdp-action-desc"><%= product.warranty || '1 Year Brand Warranty' %></div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-rotate-left pdp-action-icon"></i>
                        <div>
                            <div class="pdp-action-title">Easy Returns</div>
                            <div class="pdp-action-desc"><%= product.returnPolicy || '7 Days Replacement' %></div>
                        </div>
                    </div>
                </div>

                <button class="pdp-btn-cart" id="pdpAddToCart" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                    <i class="fa-solid fa-cart-plus"></i> Add to Cart
                </button>
                <button class="pdp-btn-wish">
                    <i class="fa-regular fa-heart"></i> Add to Wishlist
                </button>
            </div>
        </div>

        <!-- Tabs -->
        <div>
            <div class="pdp-tabs">
                <button class="pdp-tab active" data-tab="specs">Specifications</button>
                <button class="pdp-tab" data-tab="reviews">Reviews (<%= reviews ? reviews.length : 0 %>)</button>
            </div>
            
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="auth-alert auth-alert-success" style="margin-top: 16px;">
                    <i class="fa-solid fa-circle-check"></i> <%= success_msg %>
                </div>
            <% } %>
            
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="auth-alert auth-alert-error" style="margin-top: 16px;">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= error_msg %>
                </div>
            <% } %>

            <div class="pdp-tab-content active" id="tab-specs">
                <% if (product.specifications && product.specifications.length > 0) { %>
                    <div class="pdp-meta-table" style="max-width: 600px; border: none;">
                        <% product.specifications.forEach((spec) => { %>
                            <div class="pdp-meta-row" style="padding: 12px 0; border-bottom: 1px solid var(--border);">
                                <span class="pdp-meta-label"><%= spec.key %></span>
                                <span class="pdp-meta-value"><%= spec.value %></span>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p class="pdp-desc-text">No detailed specifications available.</p>
                <% } %>
            </div>

            <div class="pdp-tab-content" id="tab-reviews">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
                    <h3 style="color:var(--text-hi);">Customer Reviews</h3>
                    <% if (locals.user) { %>
                        <button id="toggleReviewFormBtn" class="btn btn-primary" style="background:var(--grad-purple); color:#fff; border:none; padding:8px 16px; border-radius:8px; cursor: pointer;">Write a Review</button>
                    <% } else { %>
                        <a href="/auth/login" class="nc-cta" style="padding: 8px 16px; font-size: 14px; text-decoration: none;">Login to Review</a>
                    <% } %>
                </div>
                
                <% if (locals.user) { %>
                <div id="reviewFormContainer" style="display: none; background: var(--surface-2); padding: 24px; border-radius: var(--r-lg); margin-bottom: 32px; border: 1px solid var(--border);">
                    <form action="/api/products/<%= product._id %>/review" method="POST" enctype="multipart/form-data" class="auth-form" style="max-width: 600px;">
                        <h4 style="margin-top: 0; margin-bottom: 16px; color: var(--text-hi);">Share your thoughts</h4>
                        <div class="input-group">
                            <label for="rating">Rating (1-5)</label>
                            <div class="input-wrap">
                                <select name="rating" id="rating" required style="width: 100%; height: 48px; padding: 0 16px; background: var(--surface); border: 1.5px solid var(--border-2); border-radius: var(--r-md); color: var(--text-hi); font-size: 14.5px; outline: none; appearance: none;">
                                    <option value="5">5 ★ - Excellent</option>
                                    <option value="4">4 ★ - Very Good</option>
                                    <option value="3">3 ★ - Good</option>
                                    <option value="2">2 ★ - Fair</option>
                                    <option value="1">1 ★ - Poor</option>
                                </select>
                                <i class="fa-solid fa-chevron-down"></i>
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="comment">Your Review</label>
                            <div class="input-wrap">
                                <textarea name="comment" id="comment" rows="4" required placeholder="What did you like or dislike?" style="width: 100%; padding: 12px 16px; background: var(--surface); border: 1.5px solid var(--border-2); border-radius: var(--r-md); color: var(--text-hi); font-size: 14.5px; outline: none; resize: vertical;"></textarea>
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="media">Attach Images / Videos (Optional, Max 3)</label>
                            <div class="input-wrap">
                                <input type="file" name="media" id="media" accept="image/*,video/*" multiple style="width: 100%; padding: 12px 16px; background: var(--surface); border: 1.5px solid var(--border-2); border-radius: var(--r-md); color: var(--text-hi); font-size: 14.5px; outline: none;">
                            </div>
                        </div>
                        <button type="submit" class="auth-btn" style="margin-top: 8px; width: fit-content; padding: 0 24px;">Submit Review</button>
                    </form>
                </div>
                <% } %>
                
                <div class="reviews-grid">
                    <% if (reviews && reviews.length > 0) { %>
                        <% reviews.forEach((review) => { %>
                            <div class="review-card">
                                <div class="review-header" style="display: flex; justify-content: space-between; align-items: flex-start;">
                                    <div class="review-author">
                                        <div class="review-avatar"><%= review.user.name.charAt(0) %></div>
                                        <div>
                                            <div class="review-name"><%= review.user.name %></div>
                                            <div class="review-date"><%= review.createdAt.toLocaleDateString() %></div>
                                        </div>
                                    </div>
                                    <% if (locals.user && (review.user._id.toString() === locals.user._id.toString() || locals.user.role === 'admin')) { %>
                                        <button onclick="deleteReview('<%= product._id %>', '<%= review._id %>')" style="background: none; border: none; color: var(--text-lo); cursor: pointer; transition: color var(--ease);" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--text-lo)'" title="Delete Review">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    <% } %>
                                </div>
                                <div class="review-rating">
                                    <% for(let i=1; i<=5; i++) { %>
                                        <i class="<%= i <= review.rating ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                                    <% } %>
                                </div>
                                <div class="review-body">
                                    <%= review.comment %>
                                </div>
                                <% if (review.media && review.media.length > 0) { %>
                                    <div class="review-media-grid" style="display: flex; gap: 12px; margin-top: 16px; overflow-x: auto; padding-bottom: 8px;">
                                        <% review.media.forEach((mediaPath) => { %>
                                            <% if (mediaPath.match(/\.(mp4|webm|ogg)$/i)) { %>
                                                <video src="<%= mediaPath %>" controls style="height: 80px; width: auto; border-radius: 8px; border: 1px solid var(--border);"></video>
                                            <% } else { %>
                                                <img src="<%= mediaPath %>" alt="Review Media" style="height: 80px; width: auto; border-radius: 8px; border: 1px solid var(--border); object-fit: cover; cursor: pointer;" onclick="window.open(this.src, '_blank')">
                                            <% } %>
                                        <% }) %>
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="pdp-desc-text">No reviews yet. Be the first to review this product!</p>
                    <% } %>
                </div>
            </div>
        </div>

    </div>
</div>

<% if (similarProducts && similarProducts.length > 0) { %>
<div class="container" style="padding-top: 24px; padding-bottom: 64px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px;">
        <h2 style="font-size: 24px; font-weight: 700; color: var(--text-hi);">Similar Products</h2>
        <a href="/shop?category=<%= product.category.slug %>" style="color: var(--purple-lt); font-size: 14px; font-weight: 500; text-decoration: none;">View Category</a>
    </div>
    <div class="product-grid">
        <% similarProducts.forEach((simProduct) => { %>
            <div class="product-card" data-product-id="<%= simProduct._id %>">
                <% if (simProduct.isFeatured) { %>
                    <span class="product-badge product-badge-ai">Hot</span>
                <% } %>
                <button class="product-wishlist" aria-label="Add to wishlist" data-product-id="<%= simProduct._id %>"><i class="fa-regular fa-heart"></i></button>
                <div class="product-card-image">
                    <% if (simProduct.image) { %>
                        <img src="<%= simProduct.image %>" alt="<%= simProduct.title %>" loading="lazy" decoding="async" data-product-image>
                    <% } else { %>
                        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:var(--surface-2); font-size:48px; color:var(--text-lo)">
                            <%= product.category.icon %>
                        </div>
                    <% } %>
                </div>
                <div class="product-card-body">
                    <span class="product-category-tag"><%= product.category.name %></span>
                    <h3 class="product-title"><a href="/product/<%= simProduct._id %>"><%= simProduct.title %></a></h3>
                    <div class="product-price-row">
                        <span class="product-price">₹<%= simProduct.price.toFixed(2) %></span>
                    </div>
                </div>
                <div class="product-card-footer">
                    <button class="btn-add-cart" type="button" data-add-to-cart data-product-id="<%= simProduct._id %>">
                        Add to Cart
                    </button>
                </div>
            </div>
        <% }) %>
    </div>
</div>
<% } %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Tab switching
        const tabs = document.querySelectorAll('.pdp-tab');
        const contents = document.querySelectorAll('.pdp-tab-content');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                contents.forEach(c => c.classList.remove('active'));
                
                tab.classList.add('active');
                document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
            });
        });

        // Toggle review form
        const toggleBtn = document.getElementById('toggleReviewFormBtn');
        const formContainer = document.getElementById('reviewFormContainer');
        if (toggleBtn && formContainer) {
            toggleBtn.addEventListener('click', () => {
                if (formContainer.style.display === 'none') {
                    formContainer.style.display = 'block';
                    toggleBtn.textContent = 'Cancel Review';
                } else {
                    formContainer.style.display = 'none';
                    toggleBtn.textContent = 'Write a Review';
                }
            });
        }
    });

    // Delete review function
    async function deleteReview(productId, reviewId) {
        if (!confirm('Are you sure you want to delete this review?')) return;
        
        try {
            const response = await fetch(`/api/products/${productId}/review/${reviewId}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            });
            const data = await response.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.message || 'Failed to delete review.');
            }
        } catch (error) {
            console.error('Error deleting review:', error);
            alert('An error occurred while deleting the review.');
        }
    }
</script>
<% } %>
