<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

/* Redesigned Premium Styles matching user mockup exactly */
:root {
    --purple-primary: #7c3aed;
    --purple-hover: #6d28d9;
    --purple-light: #f5f3ff;
    --purple-accent: #a78bfa;
    --text-main: #1f2937;
    --text-sub: #4b5563;
    --text-mute: #9ca3af;
    --bg-light: #f9fafb;
    --border-color: #f3f4f6;
    --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.02), 0 1px 3px rgba(0, 0, 0, 0.01);
    --shadow-premium: 0 20px 40px rgba(124, 58, 237, 0.04);
    --radius-lg: 16px;
    --radius-xl: 24px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.pdp-wrapper {
    font-family: 'Poppins', sans-serif;
    background-color: #ffffff;
    color: var(--text-main);
    min-height: 100vh;
    padding-bottom: 60px;
}

.pdp-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 36px;
}

/* Breadcrumb navigation */
.pdp-breadcrumb {
    font-size: 13px;
    color: var(--text-sub);
    padding: 20px 0 8px 0;
    display: flex;
    gap: 8px;
    align-items: center;
}
.pdp-breadcrumb a {
    color: var(--text-sub);
    text-decoration: none;
    transition: var(--transition);
}
.pdp-breadcrumb a:hover {
    color: var(--purple-primary);
}
.pdp-breadcrumb span {
    color: var(--text-mute);
}

/* Top Fold - 3 Columns */
.pdp-top-fold {
    display: grid;
    grid-template-columns: 1.2fr 1.1fr 0.7fr;
    gap: 32px;
    align-items: flex-start;
}

/* Gallery Column (single centered main image) */
.pdp-gallery-col {
    display: block;
}

.pdp-main-image-box {
    position: relative;
    background: #fcfcff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: var(--shadow-soft);
}

.pdp-discount-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--purple-primary);
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 8px;
    z-index: 10;
}

.pdp-wish-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    background: #ffffff;
    border: 1px solid var(--border-color);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    font-size: 16px;
    z-index: 10;
    transition: var(--transition);
}
.pdp-wish-btn:hover {
    transform: scale(1.1);
}

.pdp-expand-btn {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background: #ffffff;
    border: 1px solid var(--border-color);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    font-size: 16px;
    z-index: 10;
    transition: var(--transition);
}

.pdp-nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: #ffffff;
    border: 1px solid var(--border-color);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    font-size: 18px;
    z-index: 10;
    transition: var(--transition);
    opacity: 0;
}
.pdp-main-image-box:hover .pdp-nav-arrow {
    opacity: 1;
}
.pdp-nav-arrow:hover {
    background: var(--purple-light);
    color: var(--purple-primary);
}
.pdp-nav-arrow.left { left: 16px; }
.pdp-nav-arrow.right { right: 16px; }

.pdp-main-img {
    font-size: 180px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    user-select: none;
}
.pdp-main-image-box:hover .pdp-main-img {
    transform: scale(1.15);
}

/* Product Info Column */
.pdp-info-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.pdp-best-seller-badge {
    background: var(--purple-light);
    color: var(--purple-primary);
    font-size: 11px;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 100px;
    width: fit-content;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.pdp-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-main);
}

.pdp-rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 14px;
    color: var(--text-sub);
}
.pdp-rating-row .stars {
    color: #f59e0b;
    font-weight: bold;
    letter-spacing: 1px;
}
.pdp-rating-row .rating-val {
    font-weight: 700;
    color: var(--text-main);
}
.pdp-rating-row .rating-count {
    color: var(--text-sub);
}
.pdp-rating-row .divider {
    color: var(--text-mute);
}
.pdp-rating-row .bought-tag {
    font-weight: 600;
    color: var(--text-sub);
}

/* Price Block */
.pdp-price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
}
.price-large {
    font-size: 32px;
    font-weight: 800;
    color: var(--purple-primary);
}
.mrp-text {
    font-size: 16px;
    color: var(--text-mute);
    text-decoration: line-through;
}
.pdp-discount-tag {
    background: #fef2f2;
    color: #ef4444;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 100px;
}
.tax-text {
    font-size: 12px;
    color: var(--text-mute);
    margin-top: -8px;
    display: flex;
    align-items: center;
    gap: 4px;
}

/* Stock status pill */
.pdp-stock-status {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
}
.stock-pill {
    background: #ecfdf5;
    color: #10b981;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 12px;
}
.delivery-estimation {
    color: var(--text-sub);
    display: flex;
    align-items: center;
    gap: 4px;
}

/* Specs/Metadata table */
.pdp-meta-table {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    font-size: 13px;
}
.pdp-meta-row {
    display: grid;
    grid-template-columns: 120px 1fr;
}
.pdp-meta-label {
    color: var(--text-mute);
    font-weight: 500;
}
.pdp-meta-value {
    color: var(--text-main);
    font-weight: 600;
}

/* Color Options Selector */
.pdp-color-picker {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.color-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-sub);
}
.color-options {
    display: flex;
    gap: 10px;
}
.color-ring {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 1px solid var(--border-color);
    transition: var(--transition);
}
.color-circle {
    width: 18px;
    height: 18px;
    border-radius: 50%;
}
.color-ring.active {
    border-color: var(--purple-primary);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15);
}

/* Storage Options Selector */
.pdp-storage-picker {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.storage-options {
    display: flex;
    gap: 10px;
}
.storage-btn {
    background: #ffffff;
    border: 1px solid var(--border-color);
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
}
.storage-btn.active {
    border-color: var(--purple-primary);
    color: var(--purple-primary);
    background: var(--purple-light);
}

/* Quantity selector */
.quantity-picker {
    display: flex;
    align-items: center;
    gap: 12px;
}
.qty-container {
    display: flex;
    align-items: center;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: #ffffff;
}
.qty-btn {
    border: none;
    background: transparent;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-sub);
    font-weight: 600;
    transition: var(--transition);
}
.qty-btn:hover {
    color: var(--purple-primary);
    background: var(--purple-light);
}
.qty-input {
    width: 40px;
    height: 36px;
    text-align: center;
    border: none;
    border-left: 1px solid var(--border-color);
    border-right: 1px solid var(--border-color);
    font-weight: 600;
    outline: none;
}

/* Action Box Card - Right Column */
.pdp-action-card {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 24px;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 90px;
}
.pdp-action-bullets {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 13px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 16px;
}
.pdp-action-bullet-item {
    display: flex;
    gap: 10px;
    align-items: center;
}
.pdp-action-bullet-icon {
    font-size: 16px;
    color: var(--purple-primary);
}
.pdp-action-bullet-title {
    font-weight: 700;
}
.pdp-action-bullet-desc {
    color: var(--text-sub);
}
.pdp-low-stock-alert {
    color: #ef4444;
    font-weight: 700;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.btn-pdp {
    width: 100%;
    padding: 14px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    transition: var(--transition);
    border: none;
}
.btn-pdp-cart {
    background: linear-gradient(135deg, #a78bfa, var(--purple-primary));
    color: #ffffff;
}
.btn-pdp-cart:hover {
    background: linear-gradient(135deg, #8b5cf6, var(--purple-hover));
    transform: translateY(-1px);
}
.btn-pdp-buy {
    background: #000000;
    color: #ffffff;
}
.btn-pdp-buy:hover {
    background: #1f2937;
    transform: translateY(-1px);
}
.btn-pdp-wishlist {
    background: #ffffff;
    border: 1px solid var(--border-color);
    color: var(--text-sub);
}
.btn-pdp-wishlist:hover {
    background: var(--purple-light);
    color: var(--purple-primary);
    border-color: var(--purple-accent);
}
.btn-pdp-compare {
    background: #ffffff;
    border: 1px solid var(--border-color);
    color: var(--text-sub);
}
.btn-pdp-compare:hover {
    background: #f9fafb;
    border-color: #cbd5e1;
}

.payment-methods-box {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 11px;
    color: var(--text-mute);
    align-items: center;
}
.payment-logos {
    display: flex;
    gap: 8px;
    font-size: 18px;
    color: var(--text-sub);
}

/* High-level specs chips row */
.specs-chips-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-top: 16px;
}
.specs-chip-card {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: var(--shadow-soft);
}
.specs-chip-icon {
    font-size: 24px;
    color: var(--purple-primary);
    background: var(--purple-light);
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.specs-chip-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-main);
}
.specs-chip-desc {
    font-size: 11px;
    color: var(--text-mute);
}

/* Tabbed Content Navigation */
.tabs-navigation {
    display: flex;
    border-bottom: 1px solid var(--border-color);
    gap: 32px;
    overflow-x: auto;
}
.tab-link {
    background: transparent;
    border: none;
    font-size: 15px;
    font-weight: 600;
    color: var(--text-sub);
    padding: 14px 0;
    cursor: pointer;
    position: relative;
    transition: var(--transition);
}
.tab-link:hover {
    color: var(--purple-primary);
}
.tab-link.active {
    color: var(--purple-primary);
}
.tab-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--purple-primary);
    border-radius: 10px;
}

.tab-pane {
    display: none;
    padding: 24px 0;
}
.tab-pane.active {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 32px;
}

.desc-col-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-sub);
    margin-bottom: 20px;
}
.desc-bullet-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    padding: 0;
}
.desc-bullet-list li {
    font-size: 13px;
    color: var(--text-main);
    display: flex;
    gap: 10px;
    align-items: center;
    font-weight: 500;
}
.desc-bullet-list li::before {
    content: '✓';
    color: var(--purple-primary);
    font-weight: 900;
    font-size: 14px;
}

/* Tab pane right side grid cards */
.tab-right-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}
.tab-grid-card {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 16px;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    gap: 4px;
}
.tab-grid-card-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--text-mute);
    text-transform: uppercase;
}
.tab-grid-card-value {
    font-size: 14px;
    font-weight: 700;
    color: var(--purple-primary);
}
.tab-grid-card-desc {
    font-size: 11px;
    color: var(--text-sub);
}

/* Highlights Banner Row below Tabs */
.highlights-banner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    background: #fbfbfe;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 24px;
}
.highlight-banner-item {
    display: flex;
    align-items: center;
    gap: 12px;
}
.highlight-banner-icon {
    font-size: 24px;
    color: var(--purple-primary);
    background: #ffffff;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-soft);
}
.highlight-banner-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-main);
}
.highlight-banner-desc {
    font-size: 11px;
    color: var(--text-sub);
}

/* Premium Customer Reviews Section Styling */
.reviews-section-card {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02), 0 1px 3px rgba(0, 0, 0, 0.01);
    margin-bottom: 32px;
}

.reviews-header-block {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 16px;
}

.reviews-header-title {
    font-size: 24px;
    font-weight: 800;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 10px;
}

.btn-premium-review {
    background: linear-gradient(135deg, #a855f7, #7c3aed);
    color: #ffffff;
    font-weight: 700;
    padding: 12px 24px;
    border-radius: 100px;
    border: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.2);
}

.btn-premium-review:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(124, 58, 237, 0.35);
    background: linear-gradient(135deg, #9333ea, #6d28d9);
}

.reviews-summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
}

@media (max-width: 992px) {
    .reviews-summary-grid {
        grid-template-columns: 1fr;
    }
}

.summary-card-premium {
    background: #fbfbfe;
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 24px;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: all 0.3s ease;
}

.summary-card-premium:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.04);
}

.big-rating-val {
    font-size: 64px;
    font-weight: 800;
    color: var(--text-main);
    line-height: 1;
}

.rating-total-stars {
    color: #f59e0b;
    font-size: 20px;
    margin: 8px 0;
}

.recommend-text {
    font-size: 13px;
    color: #10b981;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 6px;
}

/* Distribution Bars */
.dist-row {
    display: grid;
    grid-template-columns: 40px 1fr 40px;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-sub);
}

.progress-premium {
    height: 8px;
    background: #f1f5f9;
    border-radius: 100px;
    overflow: hidden;
}

.progress-bar-premium {
    height: 100%;
    border-radius: 100px;
    background: var(--purple-primary);
    width: 0;
    transition: width 1s ease-out;
}

/* Stat Grid Inside Card 3 */
.stats-cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.stat-item-premium {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 12px;
    text-align: center;
    box-shadow: var(--shadow-soft);
}

.stat-item-icon {
    font-size: 18px;
    color: var(--purple-primary);
    margin-bottom: 4px;
}

.stat-item-num {
    font-size: 16px;
    font-weight: 800;
    color: var(--text-main);
}

.stat-item-lbl {
    font-size: 11px;
    color: var(--text-mute);
    font-weight: 600;
}

/* Filter Chips */
.filter-bar-premium {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
}

.filter-chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.filter-chip-btn {
    background: #ffffff;
    border: 1px solid var(--border-color);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-sub);
    cursor: pointer;
    transition: all 0.2s ease;
}

.filter-chip-btn:hover {
    border-color: var(--purple-accent);
    color: var(--purple-primary);
    background: var(--purple-light);
}

.filter-chip-btn.active {
    background: var(--purple-primary);
    color: #ffffff;
    border-color: var(--purple-primary);
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.2);
}

.sort-select-premium {
    padding: 8px 16px;
    border-radius: 100px;
    border: 1px solid var(--border-color);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-sub);
    outline: none;
    background: #ffffff;
    cursor: pointer;
}

/* Review Cards Layout */
.reviews-grid-premium {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
}

@media (max-width: 992px) {
    .reviews-grid-premium {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .reviews-grid-premium {
        grid-template-columns: 1fr;
    }
}

.review-card-premium {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 24px;
    box-shadow: var(--shadow-soft);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    gap: 12px;
}

.review-card-premium:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05);
}

.review-header-premium {
    display: flex;
    align-items: center;
    gap: 12px;
}

.review-avatar-premium {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a855f7, #7c3aed);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    box-shadow: 0 4px 8px rgba(124, 58, 237, 0.15);
}

.review-meta-premium {
    display: flex;
    flex-direction: column;
}

.review-author-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-main);
}

.review-verified-badge {
    font-size: 10px;
    font-weight: 700;
    color: #10b981;
    display: flex;
    align-items: center;
    gap: 2px;
}

.review-date-premium {
    font-size: 11px;
    color: var(--text-mute);
}

.review-menu-btn {
    background: transparent;
    border: none;
    color: var(--text-mute);
    cursor: pointer;
    font-size: 16px;
    margin-left: auto;
}

.review-stars-row {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #f59e0b;
}

.review-stars-val {
    font-weight: 700;
    color: var(--text-main);
}

.review-title-premium {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-main);
    margin: 4px 0;
}

.review-body-premium {
    font-size: 12px;
    line-height: 1.6;
    color: var(--text-sub);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    transition: all 0.3s ease;
}

.review-body-premium.expanded {
    display: block;
    -webkit-line-clamp: unset;
}

.read-more-btn {
    background: transparent;
    border: none;
    color: var(--purple-primary);
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    padding: 0;
    margin-top: 4px;
    display: block;
}

.review-photos-grid {
    display: flex;
    gap: 8px;
    margin-top: 8px;
}

.review-photo-item {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    background-size: cover;
    background-position: center;
    border: 1px solid var(--border-color);
    cursor: pointer;
    transition: all 0.3s ease;
    overflow: hidden;
}

.review-photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.review-photo-item:hover img {
    transform: scale(1.15);
}

.review-footer-premium {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border-color);
    padding-top: 14px;
    margin-top: 12px;
}

.review-footer-actions {
    display: flex;
    gap: 12px;
}

.btn-footer-action {
    background: transparent;
    border: none;
    color: var(--text-sub);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: all 0.2s ease;
    padding: 4px 8px;
    border-radius: 6px;
}

.btn-footer-action:hover {
    color: var(--purple-primary);
    background: var(--purple-light);
}

/* Lightbox Modal */
.lightbox-modal-premium {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
}

.lightbox-content-box {
    position: relative;
    max-width: 90%;
    max-height: 80%;
}

.lightbox-img {
    max-width: 100%;
    max-height: 80vh;
    border-radius: 12px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}

.lightbox-close-btn {
    position: absolute;
    top: -40px;
    right: 0;
    color: #ffffff;
    font-size: 28px;
    background: transparent;
    border: none;
    cursor: pointer;
}

/* ======== Write a Review Modal — Premium UX ======== */
.modal-backdrop-custom {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1040;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
}
.modal-backdrop-custom.show {
    opacity: 1;
    pointer-events: auto;
}

@keyframes modalSlideIn {
    from { opacity: 0; transform: scale(0.92) translateY(20px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes modalSlideOut {
    from { opacity: 1; transform: scale(1) translateY(0); }
    to   { opacity: 0; transform: scale(0.92) translateY(20px); }
}

.modal.fade .modal-dialog {
    transform: scale(0.92) translateY(20px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
}
.modal.show .modal-dialog {
    transform: scale(1) translateY(0);
}

.modal-content-premium {
    border-radius: 20px;
    border: none;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.18), 0 8px 24px rgba(0, 0, 0, 0.08);
    background: #ffffff;
    padding: 0;
    overflow: hidden;
    max-width: 700px;
}

.modal-header-premium {
    border: none;
    padding: 0 0 20px 0;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border-color);
    position: relative;
}

.modal-title-premium {
    font-size: 24px;
    font-weight: 800;
    color: var(--text-main);
    line-height: 1.2;
}

.modal-subtitle-premium {
    font-size: 14px;
    color: var(--text-sub);
    margin-top: 4px;
}

.modal-close-btn-premium {
    position: absolute;
    top: 0;
    right: 0;
    background: #f1f5f9;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-sub);
    cursor: pointer;
    transition: all 0.2s ease;
}

.modal-close-btn-premium:hover {
    background: #e2e8f0;
    color: var(--text-main);
}

.modal-body-premium {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.star-rating-selector-premium {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
}

.stars-row-premium {
    display: flex;
    gap: 12px;
    font-size: 40px;
    color: #cbd5e1;
    cursor: pointer;
}

.stars-row-premium span {
    transition: transform 0.2s ease, color 0.2s ease;
}

.stars-row-premium span:hover {
    transform: scale(1.2);
}

.stars-row-premium span.hovered,
.stars-row-premium span.selected {
    color: #f59e0b !important;
}

.stars-text-premium {
    font-size: 14px;
    font-weight: 700;
    color: #f59e0b;
    height: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.form-label-premium {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 8px;
}

.form-control-premium {
    border-radius: 12px;
    border: 1px solid var(--border-color);
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s ease;
    background: #fbfbfe;
    width: 100%;
}

.form-control-premium:focus {
    border-color: var(--purple-primary);
    box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
    background: #ffffff;
    outline: none;
}

.upload-drag-box-premium {
    border: 2px dashed var(--border-color);
    border-radius: 16px;
    padding: 32px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    background: #fbfbfe;
}

.upload-drag-box-premium:hover {
    border-color: var(--purple-primary);
    background: var(--purple-light);
}

.upload-drag-box-premium i {
    font-size: 32px;
    color: var(--purple-primary);
    margin-bottom: 8px;
    display: inline-block;
    transition: transform 0.2s ease;
}

.upload-drag-box-premium:hover i {
    transform: translateY(-4px);
}

.upload-drag-text {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-main);
}

.upload-drag-sub {
    font-size: 12px;
    color: var(--text-mute);
    margin-top: 4px;
}

.preview-thumbnails-container {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 12px;
}

.preview-thumb-item {
    position: relative;
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border-color);
}

.preview-thumb-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.preview-thumb-delete {
    position: absolute;
    top: 2px;
    right: 2px;
    background: rgba(0, 0, 0, 0.6);
    color: #ffffff;
    border: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    cursor: pointer;
}

.preview-thumb-delete:hover {
    background: rgba(239, 68, 68, 0.9);
}

.modal-footer-premium {
    border: none;
    padding: 24px 0 0 0;
    margin-top: 24px;
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
}

.btn-modal-cancel {
    background: #ffffff;
    border: 1px solid var(--border-color);
    color: var(--text-sub);
    font-weight: 700;
    padding: 12px 28px;
    border-radius: 100px;
    transition: all 0.2s ease;
}

.btn-modal-cancel:hover {
    background: #f1f5f9;
    color: var(--text-main);
    border-color: #cbd5e1;
}

.btn-modal-submit {
    background: linear-gradient(135deg, #a855f7, #7c3aed);
    color: #ffffff;
    font-weight: 700;
    padding: 12px 32px;
    border-radius: 100px;
    border: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.2);
}

.btn-modal-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(124, 58, 237, 0.35);
    background: linear-gradient(135deg, #9333ea, #6d28d9);
}

/* Bottom CTA block */
.bottom-cta-premium {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.04), rgba(124, 58, 237, 0.04));
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 32px;
}

.bottom-cta-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--text-main);
    margin-bottom: 4px;
}

.bottom-cta-desc {
    font-size: 13px;
    color: var(--text-sub);
}
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
}

/* Frequently Bought Together Box */
.fbt-card {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 24px;
    box-shadow: var(--shadow-soft);
}
.fbt-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
}
.fbt-row {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
}
.fbt-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 120px;
    text-align: center;
}
.fbt-item-img {
    width: 90px;
    height: 90px;
    background: #f9fafb;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
}
.fbt-item-title {
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
}
.fbt-item-price {
    font-size: 12px;
    font-weight: 700;
    color: var(--text-main);
}
.fbt-plus-symbol {
    font-size: 20px;
    color: var(--text-mute);
    font-weight: 600;
}
.fbt-action-panel {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 24px;
    background: var(--bg-light);
    padding: 16px 24px;
    border-radius: 12px;
    min-width: 320px;
}
.fbt-total-info {
    display: flex;
    flex-direction: column;
}
.fbt-total-label {
    font-size: 12px;
    color: var(--text-sub);
}
.fbt-total-price {
    font-size: 20px;
    font-weight: 800;
    color: var(--text-main);
}
.btn-fbt-add {
    background: var(--purple-primary);
    color: #ffffff;
    border: none;
    padding: 12px 20px;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
    font-size: 13px;
    transition: var(--transition);
}
.btn-fbt-add:hover {
    background: var(--purple-hover);
}

/* Similar Products / You May Also Like Section */
.similar-section-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 20px;
}
.slider-grid {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding-bottom: 16px;
}
.slider-card {
    min-width: 200px;
    max-width: 200px;
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 16px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
}
.slider-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-soft);
}
.slider-card.active-card {
    border: 2px solid var(--purple-primary);
}
.slider-card-img {
    width: 100%;
    height: 120px;
    background: #f9fafb;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 44px;
    margin-bottom: 12px;
}
.slider-card-title {
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 6px;
}
.slider-card-rating {
    color: #f59e0b;
    font-size: 11px;
    margin-bottom: 8px;
}
.slider-card-price {
    font-size: 14px;
    font-weight: 800;
    color: var(--purple-primary);
}

/* Bottom Assurance Footer Bar */
.bottom-assurance-bar {
    border-top: 1px solid var(--border-color);
    padding: 32px 0;
    margin-top: 40px;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
}
.assurance-item {
    display: flex;
    align-items: center;
    gap: 12px;
}
.assurance-icon {
    font-size: 28px;
    color: var(--purple-primary);
}
.assurance-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-main);
}
.assurance-desc {
    font-size: 11px;
    color: var(--text-sub);
}

/* Toast Container */
.toast-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
}
.toast-box {
    background: #1f2937;
    color: #ffffff;
    padding: 14px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    gap: 10px;
    transform: translateY(30px);
    opacity: 0;
    transition: var(--transition);
}
.toast-box.show {
    transform: translateY(0);
    opacity: 1;
}

/* Responsiveness adjustments */
@media (max-width: 1200px) {
    .pdp-top-fold {
        grid-template-columns: 1.2fr 1fr;
    }
    .pdp-action-card {
        grid-column: 1 / -1;
        position: static;
        flex-direction: row;
        align-items: center;
    }
}
@media (max-width: 900px) {
    .pdp-top-fold {
        grid-template-columns: 1fr;
    }
    .reviews-section-wrapper {
        grid-template-columns: 1fr;
    }
    .tab-pane.active {
        grid-template-columns: 1fr;
    }
}

