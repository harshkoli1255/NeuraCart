<style>
/* Specific CSS for Product Page - Amazon Density + NeuraCart Flavor */
.pdp-container {
    max-width: 1400px;
    margin: 40px auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
}

/* TOP FOLD: 3 Columns */
.pdp-top-fold {
    display: grid;
    grid-template-columns: 2fr 2.5fr 1.2fr;
    gap: 30px;
    align-items: flex-start;
}

/* Column 1: Gallery */
.pdp-gallery-col {
    display: flex;
    gap: 20px;
}
.pdp-thumbnails {
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.pdp-thumb {
    width: 60px; height: 60px;
    border-radius: 12px;
    background: var(--surface);
    border: 2px solid #e2e8f0;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    cursor: pointer;
    transition: all 0.2s;
}
.pdp-thumb.active { border-color: var(--primary); box-shadow: 0 4px 12px rgba(99,102,241,0.2); }
.pdp-thumb:hover { border-color: var(--accent); }
.pdp-main-image {
    flex: 1;
    background: #f8fafc;
    border-radius: 24px;
    min-height: 500px;
    display: flex; align-items: center; justify-content: center;
    font-size: 180px;
    box-shadow: inset 0 2px 20px rgba(0,0,0,0.02);
}

/* Column 2: Info */
.pdp-info-col {
    display: flex;
    flex-direction: column;
}
.pdp-brand-link {
    color: var(--accent);
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    text-decoration: none;
}
.pdp-title {
    font-size: 32px;
    font-weight: 800;
    color: var(--text-dark);
    line-height: 1.2;
    margin-bottom: 12px;
}
.pdp-ratings-block {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid #e2e8f0;
}
.stars { color: #eab308; font-weight: bold; font-size: 18px; }
.rating-count { color: var(--primary); font-weight: 600; cursor: pointer; }

.pdp-price-block {
    margin-bottom: 24px;
}
.price-large {
    font-size: 36px;
    font-weight: 800;
    color: #ef4444;
    display: flex; align-items: flex-start;
}
.price-symbol { font-size: 18px; margin-top: 6px; }
.mrp-text { font-size: 14px; color: var(--text-light); text-decoration: line-through; margin-left: 8px; }

.pdp-bullet-points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.pdp-bullet-points li {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-dark);
    display: flex;
    gap: 10px;
}
.pdp-bullet-points li::before {
    content: "✨";
    font-size: 14px;
    flex-shrink: 0;
    margin-top: 2px;
}

/* Column 3: Buy Box */
.pdp-buybox-col {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 24px;
    padding: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    position: sticky;
    top: 40px;
}
.buybox-price { font-size: 28px; font-weight: 800; color: var(--text-dark); margin-bottom: 12px; }
.buybox-delivery { font-size: 14px; color: var(--text-dark); margin-bottom: 16px; line-height: 1.5; }
.buybox-delivery strong { color: var(--primary); }
.buybox-stock { font-size: 16px; font-weight: 700; color: #10b981; margin-bottom: 16px; }
.buybox-stock.low { color: #f59e0b; }

.quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
    width: 120px;
}
.qty-btn { background: #f8fafc; border: none; padding: 10px 15px; cursor: pointer; font-weight: bold; }
.qty-btn:hover { background: #e2e8f0; }
.qty-input { width: 40px; text-align: center; border: none; border-left: 1px solid #cbd5e1; border-right: 1px solid #cbd5e1; font-weight: 600; outline: none; }

.btn-add, .btn-buy {
    width: 100%;
    padding: 16px;
    border-radius: 100px;
    border: none;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    margin-bottom: 12px;
    transition: all 0.2s;
}
.btn-add {
    background: linear-gradient(135deg, var(--accent), var(--primary));
    color: white;
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4);
}
.btn-add:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(99, 102, 241, 0.6); }
.btn-buy {
    background: var(--text-dark);
    color: white;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
}
.btn-buy:hover { background: #000; transform: translateY(-2px); }

.buybox-meta {
    font-size: 12px;
    color: var(--text-light);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 16px;
    margin-top: 16px;
}
.buybox-meta span { color: var(--text-dark); }

/* A+ Content / From Manufacturer */
.aplus-content {
    background: linear-gradient(135deg, #1e293b, #0f172a);
    border-radius: 30px;
    padding: 60px;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-top: 20px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
}
.aplus-badge { background: rgba(255,255,255,0.1); padding: 8px 20px; border-radius: 100px; font-weight: 600; letter-spacing: 1px; margin-bottom: 20px; }
.aplus-title { font-size: 48px; font-weight: 900; margin-bottom: 24px; background: linear-gradient(to right, #a78bfa, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.aplus-desc { font-size: 18px; max-width: 600px; line-height: 1.6; opacity: 0.8; margin-bottom: 40px; }
.aplus-features {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 30px;
    width: 100%;
}
.aplus-feature-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 30px;
    border-radius: 20px;
    backdrop-filter: blur(10px);
}
.aplus-feature-icon { font-size: 40px; margin-bottom: 16px; }
.aplus-feature-title { font-size: 20px; font-weight: 700; margin-bottom: 10px; }
.aplus-feature-desc { font-size: 14px; opacity: 0.7; line-height: 1.5; }

/* Lower Split: Reviews & Specs */
.pdp-lower-split {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 40px;
}

/* Reviews Histogram */
.reviews-section {
    background: var(--surface);
    border-radius: 30px;
    padding: 40px;
    box-shadow: var(--shadow-sm);
}
.review-header-flex { display: flex; align-items: flex-end; gap: 20px; margin-bottom: 30px; }
.global-rating { font-size: 64px; font-weight: 900; line-height: 1; color: var(--text-dark); }
.histogram-box { flex: 1; }
.histogram-row { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; font-size: 14px; font-weight: 600; color: var(--primary); }
.hist-bar-bg { flex: 1; height: 12px; background: #f1f5f9; border-radius: 10px; overflow: hidden; }
.hist-bar-fill { height: 100%; background: #f59e0b; border-radius: 10px; }
.hist-pct { width: 40px; text-align: right; color: var(--text-light); }

.review-card {
    border-bottom: 1px solid #e2e8f0;
    padding: 24px 0;
}
.review-card:last-child { border-bottom: none; }
.review-author { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; font-weight: 700; }
.review-avatar { width: 40px; height: 40px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; }
.review-text { font-size: 15px; color: var(--text-dark); line-height: 1.6; margin: 12px 0; }
.btn-helpful {
    background: transparent; border: 1px solid #cbd5e1; padding: 6px 16px; border-radius: 100px;
    font-size: 13px; font-weight: 600; cursor: pointer; color: var(--text-dark); transition: 0.2s;
}
.btn-helpful:hover { background: #f8fafc; }

/* Specs Table */
.specs-section {
    background: var(--surface);
    border-radius: 30px;
    padding: 40px;
    box-shadow: var(--shadow-sm);
    align-self: start;
}
.pdp-specs { width: 100%; border-collapse: collapse; }
.pdp-specs tr { border-bottom: 1px solid #f1f5f9; }
.pdp-specs tr:last-child { border-bottom: none; }
.pdp-specs td { padding: 16px 0; font-size: 15px; }
.pdp-specs td:first-child { font-weight: 600; color: var(--text-dark); width: 45%; }
.pdp-specs td:last-child { color: var(--text-light); }

/* Fade In Animation */
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}
.pdp-container > div {
    animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.pdp-top-fold { animation-delay: 0.1s; }
.fbt-section { animation-delay: 0.2s; }
.aplus-content { animation-delay: 0.3s; }
.ai-recommendations { animation-delay: 0.4s; }
.qa-section { animation-delay: 0.5s; }
.pdp-lower-split { animation-delay: 0.6s; }

/* Responsive Media Queries */
@media (max-width: 1200px) {
    .pdp-top-fold {
        grid-template-columns: 1fr 1.2fr;
    }
    .pdp-buybox-col {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        position: static;
    }
    .pdp-lower-split {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    .pdp-top-fold {
        grid-template-columns: 1fr;
    }
    .pdp-gallery-col {
        flex-direction: column-reverse;
    }
    .pdp-thumbnails {
        flex-direction: row;
        justify-content: center;
    }
    .pdp-main-image {
        min-height: 300px;
        font-size: 100px;
    }
    .pdp-buybox-col {
        grid-template-columns: 1fr;
    }
    .aplus-features {
        grid-template-columns: 1fr;
    }
    .fbt-section > div {
        flex-direction: column;
        align-items: center;
    }
    .fbt-section > div > div:last-child {
        margin-left: 0;
        width: 100%;
        align-items: center;
        text-align: center;
    }
}
</style>

<div class="pdp-container">
    <!-- TOP FOLD: Amazon Style 3-Column -->
    <div class="pdp-top-fold">
        
        <!-- Col 1: Gallery -->
        <div class="pdp-gallery-col">
            <div class="pdp-thumbnails">
                <div class="pdp-thumb active"><%= product.category.icon %></div>
                <div class="pdp-thumb" style="opacity:0.5"><%= product.category.icon %></div>
                <div class="pdp-thumb" style="opacity:0.3"><%= product.category.icon %></div>
            </div>
            <div class="pdp-main-image">
                <%= product.category.icon %>
            </div>
        </div>

        <!-- Col 2: Info & Bullets -->
        <div class="pdp-info-col">
            <a href="#" class="pdp-brand-link">Visit the <%= product.brand || 'NeuraCart' %> Store</a>
            <h1 class="pdp-title"><%= product.title %></h1>
            
            <div class="pdp-ratings-block">
                <span class="stars"><%= "★".repeat(Math.round(product.ratings.average)) %><%= "☆".repeat(5-Math.round(product.ratings.average)) %></span>
                <span><%= product.ratings.average %></span>
                <span class="rating-count"><%= product.ratings.count %> ratings</span>
                | <span style="font-weight:600; color:#10b981;">1K+ bought in past month</span>
            </div>

            <div class="pdp-price-block">
                <div class="price-large">
                    <span class="price-symbol">$</span><%= product.price.toFixed(2) %>
                </div>
                <div class="mrp-text">M.R.P: $<%= (product.price * 1.2).toFixed(2) %> (Save 20%)</div>
                <div style="font-size:14px; margin-top:8px;">Inclusive of all taxes</div>
            </div>

            <h3 style="margin-bottom: 12px; font-size: 18px;">About this item</h3>
            <ul class="pdp-bullet-points">
                <% if (product.bulletPoints && product.bulletPoints.length > 0) { %>
                    <% product.bulletPoints.forEach(bp => { %>
                        <li><%= bp %></li>
                    <% }) %>
                <% } else { %>
                    <li><%= product.description %></li>
                <% } %>
            </ul>
        </div>

        <!-- Col 3: Buy Box -->
        <div class="pdp-buybox-col">
            <div class="buybox-price">$<%= product.price.toFixed(2) %></div>
            <div class="buybox-delivery">
                FREE delivery <strong>Tomorrow, 8 AM - 12 PM</strong> on eligible orders.
            </div>
            
            <div class="buybox-stock <%= product.stock < 20 ? 'low' : '' %>">
                <% if (product.stock > 0) { %>
                    In Stock.
                <% } else { %>
                    Temporarily Out of Stock.
                <% } %>
            </div>

            <div class="quantity-selector">
                <button class="qty-btn" id="qtyMinus">-</button>
                <input type="text" class="qty-input" id="qtyInput" value="1" readonly>
                <button class="qty-btn" id="qtyPlus">+</button>
            </div>

            <button class="btn-add" id="addToCartBtn" data-title="<%= product.title %>">Add to Cart</button>
            <button class="btn-buy">Buy Now</button>
            <button style="width:100%; margin-top:8px; padding:12px; background:transparent; border:1px solid #cbd5e1; border-radius:100px; cursor:pointer;">Add to Wish List</button>

            <div class="buybox-meta">
                Payment <span>Secure transaction</span>
                Ships from <span>NeuraCart Fulfillment</span>
                Sold by <span><%= product.brand || 'NeuraCart' %> Retail</span>
            </div>
        </div>
    </div>

    <!-- MIDDLE: A+ Content Simulation -->
    <div class="aplus-content">
        <div class="aplus-badge">FROM THE MANUFACTURER</div>
        <h2 class="aplus-title">Elevate Your Experience</h2>
        <p class="aplus-desc">Designed for comfort, stability, and everyday productivity. <%= product.title %> sets a new standard for quality and performance in its category.</p>
        
        <div class="aplus-features">
            <div class="aplus-feature-card">
                <div class="aplus-feature-icon">✨</div>
                <div class="aplus-feature-title">Premium Build</div>
                <div class="aplus-feature-desc">Crafted with the highest grade materials to ensure durability and a sleek aesthetic that fits anywhere.</div>
            </div>
            <div class="aplus-feature-card">
                <div class="aplus-feature-icon">⚡️</div>
                <div class="aplus-feature-title">Maximum Performance</div>
                <div class="aplus-feature-desc">Engineered for extreme efficiency, giving you the power you need when you need it most.</div>
            </div>
            <div class="aplus-feature-card">
                <div class="aplus-feature-icon">🛡️</div>
                <div class="aplus-feature-title">Reliable Protection</div>
                <div class="aplus-feature-desc">Built-in safeguards and ergonomic design keep you safe and comfortable during extended use.</div>
            </div>
        </div>
    </div>

    <!-- NEW SECTION: Frequently Bought Together -->
    <div class="fbt-section" style="background: var(--surface); border-radius: 30px; padding: 40px; box-shadow: var(--shadow-sm); margin: 20px 0;">
        <h2 style="font-size: 24px; margin-bottom: 24px;">Frequently bought together</h2>
        <div style="display: flex; align-items: center; gap: 30px; flex-wrap: wrap;">
            <!-- Current Product -->
            <div style="width: 140px; text-align: center;">
                <div style="width: 140px; height: 140px; background:#f8fafc; border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:60px; margin-bottom:12px; border:2px solid var(--primary);">
                    <%= product.category.icon %>
                </div>
                <div style="font-size:13px; font-weight:600; text-overflow: ellipsis; white-space: nowrap; overflow: hidden;"><%= product.title %></div>
                <div style="color:var(--text-dark); font-weight:700; margin-top:4px;">$<%= product.price.toFixed(2) %></div>
            </div>
            
            <div style="font-size: 30px; color: #cbd5e1;">+</div>
            
            <!-- Dummy Accessory -->
            <div style="width: 140px; text-align: center; opacity: 0.8;">
                <div style="width: 140px; height: 140px; background:#f8fafc; border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:60px; margin-bottom:12px;">
                    🛡️
                </div>
                <div style="font-size:13px; font-weight:600; text-overflow: ellipsis; white-space: nowrap; overflow: hidden;">Premium Care Kit</div>
                <div style="color:var(--text-dark); font-weight:700; margin-top:4px;">$19.99</div>
            </div>

            <div style="margin-left: auto; background:#f8fafc; padding:20px; border-radius:20px; display:flex; flex-direction:column; gap:12px; min-width: 250px;">
                <div style="font-size:14px;">Total price: <span style="font-size:24px; font-weight:800; color:#ef4444;">$<%= (product.price + 19.99).toFixed(2) %></span></div>
                <button class="btn-add" style="width:100%; margin:0;" onclick="alert('Added both items to cart!')">Add both to Cart</button>
            </div>
        </div>
    </div>

    <!-- NEW SECTION: AI Recommendations (Asynchronous) -->
    <div class="ai-recommendations" style="margin: 40px 0;">
        <h2 style="font-size: 24px; margin-bottom: 24px; display:flex; align-items:center; gap:10px;">
            <span style="font-size:30px;">✨</span> AI Recommends: Similar Products
        </h2>
        
        <!-- Skeleton Loader -->
        <div id="ai-skeleton" style="display: flex; gap: 20px; overflow-x: auto; padding-bottom:20px;">
            <% for(let i=0; i<4; i++) { %>
            <div style="min-width: 250px; background:var(--surface); border-radius:24px; padding:20px; box-shadow:var(--shadow-sm); animation: pulse 1.5s infinite;">
                <div style="width:100%; height:180px; background:#f1f5f9; border-radius:16px; margin-bottom:16px;"></div>
                <div style="width:80%; height:20px; background:#f1f5f9; border-radius:4px; margin-bottom:8px;"></div>
                <div style="width:50%; height:20px; background:#f1f5f9; border-radius:4px;"></div>
            </div>
            <% } %>
        </div>

        <!-- Render Target -->
        <div id="ai-results" style="display: none; gap: 20px; overflow-x: auto; padding-bottom:20px;"></div>
    </div>

    <!-- NEW SECTION: Q&A -->
    <div class="qa-section" style="background: var(--surface); border-radius: 30px; padding: 40px; box-shadow: var(--shadow-sm); margin: 20px 0 40px 0;">
        <h2 style="font-size: 24px; margin-bottom: 24px;">Customer Questions & Answers</h2>
        <input type="text" placeholder="Have a question? Search for answers" style="width:100%; padding:16px 20px; border-radius:16px; border:1px solid #cbd5e1; font-size:16px; margin-bottom: 30px; outline:none;">
        
        <div style="display:flex; flex-direction:column; gap:24px;">
            <div style="display:flex; gap:16px;">
                <div style="font-weight:900; color:var(--text-dark); font-size:18px;">Q:</div>
                <div>
                    <div style="font-weight:700; color:var(--text-dark); margin-bottom:8px;">Is this product compatible with older models?</div>
                    <div style="display:flex; gap:16px; align-items:flex-start;">
                        <div style="font-weight:900; color:var(--primary); font-size:18px;">A:</div>
                        <div style="color:var(--text-light); line-height:1.5;">
                            Yes, it is fully backwards compatible. However, to utilize all the advanced features, we recommend using it with current generation hardware.
                            <div style="font-size:13px; margin-top:8px;">By NeuraCart Support on <%= new Date().toLocaleDateString() %></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <hr style="border:none; border-top:1px solid #e2e8f0;">

            <div style="display:flex; gap:16px;">
                <div style="font-weight:900; color:var(--text-dark); font-size:18px;">Q:</div>
                <div>
                    <div style="font-weight:700; color:var(--text-dark); margin-bottom:8px;">Does it come with an international warranty?</div>
                    <div style="display:flex; gap:16px; align-items:flex-start;">
                        <div style="font-weight:900; color:var(--primary); font-size:18px;">A:</div>
                        <div style="color:var(--text-light); line-height:1.5;">
                            Yes, all <%= product.brand || 'NeuraCart' %> products include a 1-year international warranty covering manufacturing defects.
                            <div style="font-size:13px; margin-top:8px;">By Customer Service on <%= new Date().toLocaleDateString() %></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- LOWER: Histogram & Specs -->
    <div class="pdp-lower-split">
        
        <div class="reviews-section">
            <h2 style="font-size:24px; margin-bottom: 24px;">Customer reviews</h2>
            
            <div class="review-header-flex">
                <div class="global-rating"><%= product.ratings.average %></div>
                <div class="histogram-box">
                    <div class="histogram-row">
                        5 star
                        <div class="hist-bar-bg"><div class="hist-bar-fill" style="width: 78%;"></div></div>
                        <div class="hist-pct">78%</div>
                    </div>
                    <div class="histogram-row">
                        4 star
                        <div class="hist-bar-bg"><div class="hist-bar-fill" style="width: 14%;"></div></div>
                        <div class="hist-pct">14%</div>
                    </div>
                    <div class="histogram-row">
                        3 star
                        <div class="hist-bar-bg"><div class="hist-bar-fill" style="width: 5%;"></div></div>
                        <div class="hist-pct">5%</div>
                    </div>
                    <div class="histogram-row">
                        2 star
                        <div class="hist-bar-bg"><div class="hist-bar-fill" style="width: 2%;"></div></div>
                        <div class="hist-pct">2%</div>
                    </div>
                    <div class="histogram-row">
                        1 star
                        <div class="hist-bar-bg"><div class="hist-bar-fill" style="width: 1%;"></div></div>
                        <div class="hist-pct">1%</div>
                    </div>
                </div>
            </div>

            <hr style="border:none; border-top:1px solid #e2e8f0; margin: 30px 0;">

            <h3 style="font-size: 20px; margin-bottom:20px;">Top reviews</h3>
            <% if (reviews && reviews.length > 0) { %>
                <% reviews.forEach(review => { %>
                    <div class="review-card">
                        <div class="review-author">
                            <div class="review-avatar"><%= review.user.name.charAt(0) %></div>
                            <%= review.user.name %>
                        </div>
                        <div class="stars" style="font-size:16px;"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></div>
                        <div style="font-size:13px; color:var(--text-light); margin-top:4px;">Reviewed in the United States on <%= review.createdAt.toLocaleDateString() %></div>
                        <div style="font-size:13px; color:#f97316; font-weight:600; margin-top:4px;">Verified Purchase</div>
                        <p class="review-text"><%= review.comment %></p>
                        <div style="font-size:13px; color:var(--text-light); margin-bottom:12px;">One person found this helpful</div>
                        <button class="btn-helpful">Helpful</button>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No reviews yet.</p>
            <% } %>
        </div>

        <div class="specs-section">
            <h2 style="font-size:24px; margin-bottom: 24px;">Product Specifications</h2>
            <% if (product.specifications && product.specifications.length > 0) { %>
                <table class="pdp-specs">
                    <% product.specifications.forEach(spec => { %>
                        <tr>
                            <td><%= spec.key %></td>
                            <td><%= spec.value %></td>
                        </tr>
                    <% }) %>
                </table>
            <% } else { %>
                <p>No specifications available.</p>
            <% } %>
        </div>

    </div>
</div>

<div id="toastContainer" class="toast-container"></div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Qty controls
        const qtyMinus = document.getElementById("qtyMinus");
        const qtyPlus = document.getElementById("qtyPlus");
        const qtyInput = document.getElementById("qtyInput");
        
        if(qtyMinus && qtyPlus && qtyInput) {
            qtyMinus.addEventListener("click", () => {
                let val = parseInt(qtyInput.value);
                if(val > 1) qtyInput.value = val - 1;
            });
            qtyPlus.addEventListener("click", () => {
                let val = parseInt(qtyInput.value);
                qtyInput.value = val + 1;
            });
        }

        // Add to Cart Toast
        const addToCartBtn = document.getElementById("addToCartBtn");
        const toastContainer = document.getElementById("toastContainer");
        
        if (addToCartBtn) {
            addToCartBtn.addEventListener("click", () => {
                const title = addToCartBtn.getAttribute("data-title");
                const qty = qtyInput ? qtyInput.value : 1;
                
                const toast = document.createElement("div");
                toast.className = "toast";
                toast.innerHTML = \`<div class="toast-icon">✓</div><div>Added <strong>\${qty}x \${title}</strong> to cart!</div>\`;
                
                toastContainer.appendChild(toast);
                setTimeout(() => toast.classList.add("show"), 10);
                setTimeout(() => {
                    toast.classList.remove("show");
                    setTimeout(() => toast.remove(), 400);
                }, 3000);
            });
        }

        // Fetch AI Recommendations Asynchronously
        const productId = "<%= product._id %>";
        const aiSkeleton = document.getElementById('ai-skeleton');
        const aiResults = document.getElementById('ai-results');
        
        if(productId && aiSkeleton && aiResults) {
            fetch(`/api/products/${productId}/recommendations`)
                .then(res => res.json())
                .then(data => {
                    if(data.success && data.data && data.data.length > 0) {
                        const html = data.data.map(p => `
                            <a href="/product/${p._id}" style="min-width: 250px; background:var(--surface); border-radius:24px; padding:20px; box-shadow:var(--shadow-sm); display:block; text-decoration:none; color:inherit; transition:transform 0.2s;">
                                <div style="width:100%; height:180px; background:#f8fafc; border-radius:16px; margin-bottom:16px; display:flex; align-items:center; justify-content:center; font-size:60px;">
                                    ${p.category ? p.category.icon : '📁'}
                                </div>
                                <div style="font-size:13px; font-weight:700; color:var(--accent); margin-bottom:4px;">${p.brand || 'Generic'}</div>
                                <div style="font-weight:700; font-size:16px; margin-bottom:8px; line-height:1.2; text-overflow:ellipsis; white-space:nowrap; overflow:hidden;">${p.title}</div>
                                <div style="display:flex; align-items:center; gap:6px; margin-bottom:12px;">
                                    <span style="color:#eab308; font-size:14px;">★ ${p.ratings ? p.ratings.average : '0'}</span>
                                </div>
                                <div style="font-size:20px; font-weight:800; color:var(--primary);">$${p.price.toFixed(2)}</div>
                            </a>
                        `).join('');
                        
                        // Add hover effect via JS dynamically or rely on CSS. 
                        // To keep it simple, we use inline transition.
                        aiResults.innerHTML = html;
                        aiSkeleton.style.display = 'none';
                        aiResults.style.display = 'flex';
                        
                        // Add basic hover lift manually
                        Array.from(aiResults.children).forEach(child => {
                            child.addEventListener('mouseenter', () => child.style.transform = 'translateY(-5px)');
                            child.addEventListener('mouseleave', () => child.style.transform = 'translateY(0)');
                        });
                    } else {
                        aiSkeleton.style.display = 'none';
                        aiResults.innerHTML = '<p>No recommendations found at this time.</p>';
                        aiResults.style.display = 'block';
                    }
                })
                .catch(err => {
                    console.error("Failed to load recommendations", err);
                    aiSkeleton.style.display = 'none';
                    aiResults.innerHTML = '<p>Failed to load recommendations.</p>';
                    aiResults.style.display = 'block';
                });
        }
    });
</script>
