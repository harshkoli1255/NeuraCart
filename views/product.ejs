<div class="pdp-page">
    <div class="pdp-container">
        
        <!-- Breadcrumbs -->
        <div class="pdp-breadcrumb">
            <a href="/">Home</a> <span>›</span> 
            <a href="/shop">Shop</a> <span>›</span>
            <a href="/shop?category=<%= product.category.slug %>"><%= product.category.name %></a> <span>›</span>
            <span><%= product.title %></span>
        </div>

        <!-- Top Fold -->
        <div class="pdp-top-fold">
            
            <!-- Gallery -->
            <div class="pdp-gallery-col">
                <div class="pdp-main-img-box">
                    <% if (product.isFeatured) { %>
                        <span class="pdp-badge">Featured</span>
                    <% } %>
                    <div class="pdp-main-img" id="mainImageDisplay">
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.title %>" data-product-image>
                        <% } else { %>
                            <span style="font-size: 80px"><%= product.category.icon %></span>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Info -->
            <div class="pdp-info-col">
                <h1 class="pdp-title"><%= product.title %></h1>
                
                <div class="pdp-rating-row">
                    <span class="pdp-rating-stars">
                        <% for(let i=1; i<=5; i++) { %>
                            <i class="<%= i <= Math.round(product.ratings.average) ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                        <% } %>
                    </span>
                    <span><%= product.ratings.average %></span>
                    <span>(<%= product.ratings.count %> reviews)</span>
                </div>

                <div class="pdp-price-row">
                    <span class="pdp-price">₹<%= product.price.toFixed(2) %></span>
                    <span class="pdp-price-old">₹<%= (product.price * 1.25).toFixed(2) %></span>
                    <span class="pdp-stock-pill"><%= product.stock > 0 ? 'In Stock' : 'Out of Stock' %></span>
                </div>

                <div class="pdp-meta-table">
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Brand</span>
                        <span class="pdp-meta-value"><%= product.brand || 'NeuraCart' %></span>
                    </div>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Category</span>
                        <span class="pdp-meta-value"><%= product.category.name %></span>
                    </div>
                    <% if(product.subcategory) { %>
                    <div class="pdp-meta-row">
                        <span class="pdp-meta-label">Subcategory</span>
                        <span class="pdp-meta-value"><%= product.subcategory %></span>
                    </div>
                    <% } %>
                </div>

                <div class="pdp-desc-text">
                    <%= product.description %>
                </div>
            </div>

            <!-- Action Card -->
            <div class="pdp-action-card">
                <div class="pdp-action-bullets">
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-truck pdp-action-icon"></i>
                        <div>
                            <div class="pdp-action-title">Free Delivery</div>
                            <div class="pdp-action-desc"><%= product.delivery || 'On orders above ₹999' %></div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-shield-halved pdp-action-icon"></i>
                        <div>
                            <div class="pdp-action-title">Warranty</div>
                            <div class="pdp-action-desc"><%= product.warranty || '1 Year Brand Warranty' %></div>
                        </div>
                    </div>
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-rotate-left pdp-action-icon"></i>
                        <div>
                            <div class="pdp-action-title">Easy Returns</div>
                            <div class="pdp-action-desc"><%= product.returnPolicy || '7 Days Replacement' %></div>
                        </div>
                    </div>
                </div>

                <button class="pdp-btn-cart" id="pdpAddToCart" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                    <i class="fa-solid fa-cart-plus"></i> Add to Cart
                </button>
                <button class="pdp-btn-wish">
                    <i class="fa-regular fa-heart"></i> Add to Wishlist
                </button>
            </div>
        </div>

        <!-- Tabs -->
        <div>
            <div class="pdp-tabs">
                <button class="pdp-tab active" data-tab="specs">Specifications</button>
                <button class="pdp-tab" data-tab="reviews">Reviews (<%= product.ratings.count %>)</button>
            </div>
            
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="auth-alert auth-alert-success" style="margin-top: 16px;">
                    <i class="fa-solid fa-circle-check"></i> <%= success_msg %>
                </div>
            <% } %>
            
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="auth-alert auth-alert-error" style="margin-top: 16px;">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= error_msg %>
                </div>
            <% } %>

            <div class="pdp-tab-content active" id="tab-specs">
                <% if (product.specifications && product.specifications.length > 0) { %>
                    <div class="pdp-meta-table" style="max-width: 600px; border: none;">
                        <% product.specifications.forEach((spec) => { %>
                            <div class="pdp-meta-row" style="padding: 12px 0; border-bottom: 1px solid var(--border);">
                                <span class="pdp-meta-label"><%= spec.key %></span>
                                <span class="pdp-meta-value"><%= spec.value %></span>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p class="pdp-desc-text">No detailed specifications available.</p>
                <% } %>
            </div>

            <div class="pdp-tab-content" id="tab-reviews">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
                    <h3 style="color:var(--text-hi);">Customer Reviews</h3>
                    <% if (locals.user) { %>
                        <button id="toggleReviewFormBtn" class="btn btn-primary" style="background:var(--grad-purple); color:#fff; border:none; padding:8px 16px; border-radius:8px; cursor: pointer;">Write a Review</button>
                    <% } else { %>
                        <a href="/auth/login" class="btn btn-primary" style="background:var(--surface-2); color:var(--text-hi); border:1px solid var(--border); padding:8px 16px; border-radius:8px; text-decoration: none;">Login to Review</a>
                    <% } %>
                </div>
                
                <% if (locals.user) { %>
                <div id="reviewFormContainer" style="display: none; background: var(--surface-2); padding: 24px; border-radius: var(--r-lg); margin-bottom: 32px; border: 1px solid var(--border);">
                    <form action="/api/products/<%= product._id %>/review" method="POST" class="auth-form" style="max-width: 600px;">
                        <h4 style="margin-top: 0; margin-bottom: 16px; color: var(--text-hi);">Share your thoughts</h4>
                        <div class="input-group">
                            <label for="rating">Rating (1-5)</label>
                            <div class="input-wrap">
                                <select name="rating" id="rating" required style="width: 100%; height: 48px; padding: 0 16px; background: var(--surface); border: 1.5px solid var(--border-2); border-radius: var(--r-md); color: var(--text-hi); font-size: 14.5px; outline: none; appearance: none;">
                                    <option value="5">5 ★ - Excellent</option>
                                    <option value="4">4 ★ - Very Good</option>
                                    <option value="3">3 ★ - Good</option>
                                    <option value="2">2 ★ - Fair</option>
                                    <option value="1">1 ★ - Poor</option>
                                </select>
                                <i class="fa-solid fa-chevron-down"></i>
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="comment">Your Review</label>
                            <div class="input-wrap">
                                <textarea name="comment" id="comment" rows="4" required placeholder="What did you like or dislike?" style="width: 100%; padding: 12px 16px; background: var(--surface); border: 1.5px solid var(--border-2); border-radius: var(--r-md); color: var(--text-hi); font-size: 14.5px; outline: none; resize: vertical;"></textarea>
                            </div>
                        </div>
                        <button type="submit" class="auth-btn" style="margin-top: 8px; width: fit-content; padding: 0 24px;">Submit Review</button>
                    </form>
                </div>
                <% } %>
                
                <div class="reviews-grid">
                    <% if (reviews && reviews.length > 0) { %>
                        <% reviews.forEach((review) => { %>
                            <div class="review-card">
                                <div class="review-header">
                                    <div class="review-author">
                                        <div class="review-avatar"><%= review.user.name.charAt(0) %></div>
                                        <div>
                                            <div class="review-name"><%= review.user.name %></div>
                                            <div class="review-date"><%= review.createdAt.toLocaleDateString() %></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="review-rating">
                                    <% for(let i=1; i<=5; i++) { %>
                                        <i class="<%= i <= review.rating ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                                    <% } %>
                                </div>
                                <div class="review-body">
                                    <%= review.comment %>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="pdp-desc-text">No reviews yet. Be the first to review this product!</p>
                    <% } %>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Tab switching
        const tabs = document.querySelectorAll('.pdp-tab');
        const contents = document.querySelectorAll('.pdp-tab-content');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                contents.forEach(c => c.classList.remove('active'));
                
                tab.classList.add('active');
                document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
            });
        });

        // Toggle review form
        const toggleBtn = document.getElementById('toggleReviewFormBtn');
        const formContainer = document.getElementById('reviewFormContainer');
        if (toggleBtn && formContainer) {
            toggleBtn.addEventListener('click', () => {
                if (formContainer.style.display === 'none') {
                    formContainer.style.display = 'block';
                    toggleBtn.textContent = 'Cancel Review';
                } else {
                    formContainer.style.display = 'none';
                    toggleBtn.textContent = 'Write a Review';
                }
            });
        }
    });
</script>
