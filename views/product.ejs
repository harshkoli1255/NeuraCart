<%# ── product.ejs ────────────────────────────────────────────────────── -%>
<% if (typeof product === 'undefined' || !product) { %>
<div class="pdp-page" style="display:flex;justify-content:center;align-items:center;min-height:70vh;">
    <div style="text-align:center;padding:40px;background:var(--surface);border:1px solid var(--border);border-radius:24px;max-width:500px;">
        <div style="font-size:64px;margin-bottom:20px;">🔍</div>
        <h1 style="font-size:24px;margin-bottom:12px;font-weight:700;">Product Not Found</h1>
        <p style="color:var(--text-lo);font-size:15px;line-height:1.6;margin-bottom:24px;">
            <%= typeof error !== 'undefined' ? error : "The product you're looking for doesn't exist." %>
        </p>
        <a href="/shop" class="btn btn-primary">Back to Shop</a>
    </div>
</div>
<% } else { %>

<style>
/* ── PDP overrides (scoped to this page) ─────────────────────────────── */
.pdp-page { padding-top: 40px; padding-bottom: 80px; background: var(--bg); }
.pdp-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

/* Breadcrumb */
.pdp-breadcrumb { font-size: 13px; color: var(--text-lo); display: flex; gap: 6px; align-items: center; margin-bottom: 28px; }
.pdp-breadcrumb a { color: var(--text-lo); text-decoration: none; transition: color 0.2s; }
.pdp-breadcrumb a:hover { color: var(--purple-lt); }

/* Top fold */
.pdp-top-fold { display: grid; grid-template-columns: 1.15fr 1fr; gap: 48px; align-items: start; }
@media (max-width: 1024px) { .pdp-top-fold { grid-template-columns: 1fr; gap: 32px; } }

/* Gallery */
.pdp-gallery-col { display: flex; flex-direction: column; gap: 12px; }
.pdp-main-img-box {
    width: 100%; aspect-ratio: 1;
    background: var(--surface-2);
    border: 1px solid transparent; /* removed hard border */
    border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
}
.pdp-main-img-box img { width: 100%; height: 100%; object-fit: contain; padding: 8px; }
.pdp-thumb-row { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; }
.pdp-thumb-row::-webkit-scrollbar { display: none; }
.pdp-thumb {
    width: 70px; height: 70px; flex-shrink: 0;
    border: 2px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s;
    background: var(--surface-2);
}
.pdp-thumb:hover, .pdp-thumb.active { border-color: var(--purple); transform: scale(1.05); }
.pdp-thumb img { width: 100%; height: 100%; object-fit: contain; padding: 4px; }
.pdp-badge { position: absolute; top: 16px; left: 16px; background: var(--grad-purple); color: #fff; padding: 5px 14px; border-radius: 100px; font-size: 12px; font-weight: 700; }

/* Info Column */
.pdp-info-col { display: flex; flex-direction: column; gap: 14px; }
.pdp-title { font-size: 24px; font-weight: 800; color: var(--text-hi); line-height: 1.25; letter-spacing: -0.02em; }
.pdp-rating-row { display: flex; align-items: center; gap: 8px; color: var(--text-lo); font-size: 13px; }
.pdp-rating-stars { color: var(--warning); }
.pdp-price-row { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
.pdp-price { font-size: 32px; font-weight: 900; color: var(--purple-lt); font-family: 'Outfit', sans-serif; }
.pdp-price-old { font-size: 18px; color: var(--text-lo); text-decoration: line-through; }
.pdp-discount-pill { background: rgba(16,185,129,0.12); color: var(--success); padding: 4px 10px; border-radius: 100px; font-size: 12px; font-weight: 700; }
.pdp-stock-pill { background: rgba(16,185,129,0.1); color: var(--success); padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 700; }
.pdp-stock-pill.out { background: rgba(239,68,68,0.1); color: #ef4444; }
.pdp-meta-table { display: flex; flex-direction: column; gap: 0; padding: 4px 0; }
.pdp-meta-row { display: grid; grid-template-columns: 90px 1fr; font-size: 13px; padding: 6px 0; border-bottom: 1px dashed var(--border-2); }
.pdp-meta-row:last-child { border-bottom: none; }
.pdp-meta-label { color: var(--text-lo); font-weight: 500; }
.pdp-meta-value { color: var(--text-hi); font-weight: 600; }
.pdp-desc-text { color: var(--text-md); line-height: 1.6; font-size: 14px; }

/* AI Summary box */
.ai-summary-box {
    background: linear-gradient(135deg, rgba(139,92,246,0.06) 0%, rgba(34,211,238,0.04) 100%);
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 14px;
    padding: 16px 20px;
    position: relative;
    overflow: hidden;
}
.ai-summary-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: linear-gradient(to bottom, var(--purple), var(--cyan));
}

/* Action Card - integrated */
.pdp-action-card {
    background: transparent;
    border: none;
    padding: 0;
    margin-top: 4px;
    display: flex; flex-direction: column; gap: 12px;
}
.pdp-action-bullets { display: flex; flex-direction: column; gap: 8px; }
.pdp-action-bullet { display: flex; gap: 10px; align-items: flex-start; }
.pdp-action-icon { color: var(--purple-lt); font-size: 16px; width: 16px; flex-shrink: 0; }
.pdp-action-title { font-size: 13px; font-weight: 600; color: var(--text-hi); }
.pdp-action-desc { font-size: 12px; color: var(--text-lo); }
.pdp-divider { height: 1px; background: var(--border); }
.pdp-seller-row { display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
.pdp-btn-cart {
    background: var(--grad-purple); color: #fff;
    width: 100%; border: none; border-radius: 12px; height: 50px;
    font-weight: 700; font-size: 15px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: transform 0.2s, box-shadow 0.2s;
}
.pdp-btn-cart:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(139,92,246,0.35); }
.pdp-btn-wish {
    background: var(--surface-2); color: var(--text-hi);
    border: 1px solid var(--border-2); width: 100%; border-radius: 12px; height: 50px;
    font-weight: 600; font-size: 14px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background 0.2s, border-color 0.2s;
}
.pdp-btn-wish:hover { background: var(--surface-3); border-color: var(--purple-lt); }
.pdp-action-buttons { display: grid; grid-template-columns: 2fr 1fr; gap: 12px; margin-top: 12px; margin-bottom: 8px; }
@media (max-width: 600px) { .pdp-action-buttons { grid-template-columns: 1fr; } }

/* Tabs */
.pdp-tabs-row { border-bottom: 1px solid var(--border); margin-top: 32px; display: flex; gap: 32px; overflow-x: auto; }
.pdp-tab { background: none; border: none; padding: 16px 0; color: var(--text-lo); font-size: 15px; font-weight: 600; cursor: pointer; position: relative; white-space: nowrap; transition: color 0.2s; }
.pdp-tab.active { color: var(--purple-lt); }
.pdp-tab.active::after { content:''; position:absolute; bottom:-1px; left:0; right:0; height:3px; background: var(--grad-purple); border-radius: 3px 3px 0 0; }
.pdp-tab-content { display: none; padding: 28px 0; }
.pdp-tab-content.active { display: block; }

/* Specs table */
.specs-table { width: 100%; border-collapse: collapse; max-width: 640px; }
.specs-table tr:nth-child(even) td { background: var(--surface-2); }
.specs-table td { padding: 12px 16px; font-size: 14px; border-bottom: 1px solid var(--border); }
.specs-table td:first-child { color: var(--text-lo); font-weight: 500; width: 45%; }
.specs-table td:last-child { color: var(--text-hi); font-weight: 600; }
.specs-table tr:first-child td { border-radius: 8px 8px 0 0; }
.specs-table tr:last-child td { border-bottom: none; }

/* Reviews */
.reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 20px; }
.review-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 20px; }
.review-avatar { width: 38px; height: 38px; background: var(--grad-purple); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; }
.review-name { font-size: 14px; font-weight: 600; color: var(--text-hi); }
.review-date { font-size: 12px; color: var(--text-lo); }
.review-rating { color: var(--warning); font-size: 13px; margin: 8px 0; }
.review-body { color: var(--text-lo); font-size: 14px; line-height: 1.55; }

/* Similar Products Section */
.pdp-similar { padding: 48px 0 64px; }
.pdp-similar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }

/* Search result "no exact match" banner */
.pdp-no-match-banner { background: linear-gradient(135deg, rgba(139,92,246,0.08), rgba(34,211,238,0.05)); border: 1px solid rgba(139,92,246,0.2); border-radius: 12px; padding: 14px 20px; display: flex; align-items: center; gap: 12px; font-size: 14px; color: var(--text-md); margin-bottom: 20px; }
</style>

<div class="pdp-page">
<div class="pdp-container">

    <%# Breadcrumb %>
    <div class="pdp-breadcrumb">
        <a href="/">Home</a> <span>›</span>
        <a href="/shop">Shop</a> <span>›</span>
        <a href="/shop?category=<%= (product.category && product.category.slug) ? product.category.slug : 'general' %>"><%= (product.category && product.category.name) ? product.category.name : 'General' %></a> <span>›</span>
        <span style="color:var(--text-hi)"><%= product.title || 'Product' %></span>
    </div>

    <%# ── Top Fold ── %>
    <div class="pdp-top-fold">

        <%# Gallery %>
        <div class="pdp-gallery-col">
            <div class="pdp-main-img-box" id="mainImgBox">
                <% if (product.isFeatured) { %><span class="pdp-badge">Featured</span><% } %>
                <% if (product.image) { %>
                    <img src="<%= product.image %>" alt="<%= product.title %>" id="mainProductImg" data-product-image>
                <% } else { %>
                    <span style="font-size:80px"><%= (product.category && product.category.icon) ? product.category.icon : '📦' %></span>
                <% } %>
            </div>
            <% if (product.images && product.images.length > 1) { %>
            <div class="pdp-thumb-row" id="thumbRow">
                <% product.images.slice(0, 6).forEach((img, idx) => { %>
                    <div class="pdp-thumb <%= idx === 0 ? 'active' : '' %>" data-img="<%= img %>">
                        <img src="<%= img %>" alt="View <%= idx + 1 %>">
                    </div>
                <% }); %>
            </div>
            <% } %>
        </div>

        <%# Info Column %>
        <div class="pdp-info-col">
            <div>
                <% if (product.brand) { %>
                    <div style="font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--purple-lt);margin-bottom:8px"><%= product.brand %></div>
                <% } %>
                <h1 class="pdp-title"><%= product.title || 'Untitled Product' %></h1>
            </div>

            <div class="pdp-rating-row">
                <span class="pdp-rating-stars">
                    <% for(let i=1;i<=5;i++) { %>
                        <i class="<%= i <= Math.round(product.ratings ? product.ratings.average : (product.rating || 0)) ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                    <% } %>
                </span>
                <span style="color:var(--text-hi);font-weight:600"><%= product.ratings ? product.ratings.average : (product.rating || 0) %></span>
                <span>(<%= product.ratings ? product.ratings.count : 0 %> reviews)</span>
            </div>

            <div class="pdp-price-row">
                <span class="pdp-price">₹<%= (product.price || 0).toLocaleString('en-IN', {maximumFractionDigits:2}) %></span>
                <span class="pdp-price-old">₹<%= ((product.price || 0) * 1.25).toLocaleString('en-IN', {maximumFractionDigits:0}) %></span>
                <span class="pdp-discount-pill">20% off</span>
            </div>

            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
                <span class="pdp-stock-pill <%= (product.stock || 0) <= 0 ? 'out' : '' %>">
                    <i class="fa-solid <%= (product.stock || 0) > 0 ? 'fa-circle-check' : 'fa-circle-xmark' %>" style="margin-right:5px"></i>
                    <%= (product.stock || 0) > 0 ? `In Stock (${product.stock} left)` : 'Out of Stock' %>
                </span>
            </div>

            <%# Add to Cart right near price %>
            <div class="pdp-action-buttons">
                <button class="pdp-btn-cart" id="pdpAddToCart" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                    <i class="fa-solid fa-cart-plus"></i> Add to Cart
                </button>
                <button class="pdp-btn-wish" data-product-id="<%= product._id %>" aria-label="Add to wishlist">
                    <i class="fa-regular fa-heart"></i> Wishlist
                </button>
            </div>

            <div class="pdp-meta-table">
                <div class="pdp-meta-row"><span class="pdp-meta-label">Category</span><span class="pdp-meta-value"><%= (product.category && product.category.name) ? product.category.name : 'General' %></span></div>
                <% if(product.brand) { %><div class="pdp-meta-row"><span class="pdp-meta-label">Brand</span><span class="pdp-meta-value"><%= product.brand %></span></div><% } %>
                <% if(product.subcategory) { %><div class="pdp-meta-row"><span class="pdp-meta-label">Type</span><span class="pdp-meta-value"><%= product.subcategory.replace(/-/g,' ') %></span></div><% } %>
            </div>

            <div class="pdp-desc-text"><%- product.description %></div>

            <%# AI Smart Summary %>
            <div class="ai-summary-box">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                    <h4 style="margin:0;font-size:14px;display:flex;align-items:center;gap:8px;color:var(--text-hi)">
                        <i class="fa-solid fa-sparkles" style="color:var(--purple)"></i> AI Smart Summary
                    </h4>
                    <button id="btnAiSummary" style="background:var(--purple);color:white;border:none;padding:5px 14px;border-radius:100px;cursor:pointer;font-size:12px;font-weight:600;transition:opacity 0.2s" data-id="<%= product._id %>">Generate ✦</button>
                </div>
                <div id="aiSummaryContent" style="font-size:13px;color:var(--text-md);line-height:1.6">
                    Click <strong>Generate</strong> for an AI analysis of this product.
                </div>
                <div style="margin-top: 12px; border-top: 1px solid rgba(139,92,246,0.15); padding-top: 12px;">
                    <div id="aiQaLog" style="display:none; max-height: 150px; overflow-y: auto; margin-bottom: 12px; font-size: 13px; color: var(--text-md); display:flex; flex-direction:column; gap:8px;"></div>
                    <form id="aiQaForm" data-id="<%= product._id %>" style="display: flex; gap: 8px;">
                        <input type="text" id="aiQaInput" placeholder="Ask Neura AI about this product..." required style="flex:1; background: var(--surface); border: 1px solid var(--border-2); border-radius: 100px; padding: 8px 16px; color: var(--text-hi); font-size: 13px; outline: none;">
                        <button type="submit" style="background: var(--surface-3); color: var(--text-hi); border: none; border-radius: 100px; padding: 0 16px; cursor: pointer; transition: background 0.2s;"><i class="fa-solid fa-arrow-right"></i></button>
                    </form>
                </div>
            </div>

            <%# Action Card integrated %>
            <div class="pdp-action-card">
                <div class="pdp-action-bullets" style="margin-top:8px;">
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-truck pdp-action-icon" style="margin-top:2px;"></i>
                        <div><div class="pdp-action-title">Free Delivery</div><div class="pdp-action-desc"><%= product.delivery || 'On orders above ₹999' %></div></div>
                    </div>
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-shield-halved pdp-action-icon" style="margin-top:2px;"></i>
                        <div><div class="pdp-action-title">Warranty</div><div class="pdp-action-desc"><%= product.warranty || '1 Year Brand Warranty' %></div></div>
                    </div>
                    <div class="pdp-action-bullet">
                        <i class="fa-solid fa-rotate-left pdp-action-icon" style="margin-top:2px;"></i>
                        <div><div class="pdp-action-title">Easy Returns</div><div class="pdp-action-desc"><%= product.returnPolicy || '7-Day Replacement' %></div></div>
                    </div>
                </div>

                <div class="pdp-seller-row" style="margin-top:8px;border-top:1px dashed var(--border-2);padding-top:12px;">
                    <span style="color:var(--text-lo)">Ships from</span>
                    <strong style="color:var(--text-hi)"><%= product.seller ? product.seller.name : 'NeuraCart Fulfillment' %></strong>
                </div>
            </div>

        </div>

    </div><%# end pdp-top-fold %>

    <%# ── Tabs ── %>
    <div>
        <div class="pdp-tabs-row" role="tablist">
            <button class="pdp-tab active" data-tab="specs">Specifications</button>
            <button class="pdp-tab" data-tab="reviews">Reviews (<%= reviews ? reviews.length : 0 %>)</button>
        </div>

        <% if (success_msg && success_msg.length > 0) { %>
            <div class="auth-alert auth-alert-success" style="margin-top:16px"><i class="fa-solid fa-circle-check"></i> <%= success_msg %></div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="auth-alert auth-alert-error" style="margin-top:16px"><i class="fa-solid fa-circle-exclamation"></i> <%= error_msg %></div>
        <% } %>

        <%# Specs Tab %>
        <div class="pdp-tab-content active" id="tab-specs">
            <% if (product.specifications && product.specifications.length > 0) { %>
                <table class="specs-table">
                    <% product.specifications.forEach(spec => { %>
                    <tr><td><%= spec.key %></td><td><%= spec.value %></td></tr>
                    <% }); %>
                </table>
            <% } else { %>
                <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:12px;padding:32px;text-align:center;color:var(--text-lo)">
                    <div style="font-size:36px;margin-bottom:12px">📋</div>
                    <p>No detailed specifications available for this product.</p>
                </div>
            <% } %>
        </div>

        <%# Reviews Tab %>
        <div class="pdp-tab-content" id="tab-reviews">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
                <h3 style="font-size:20px;font-weight:700;color:var(--text-hi)">Customer Reviews</h3>
                <% if (locals.user) { %>
                    <button id="toggleReviewFormBtn" class="btn btn-primary" style="font-size:13px;padding:8px 18px">Write a Review</button>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-ghost" style="font-size:13px;padding:8px 18px">Login to Review</a>
                <% } %>
            </div>

            <% if (reviews && reviews.length > 0) { %>
            <div id="aiReviewSummaryBox" style="background:var(--surface-3); border:1px solid rgba(139,92,246,0.3); border-radius:12px; padding:16px; margin-bottom:24px; position:relative; overflow:hidden;">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                    <i class="fa-solid fa-sparkles" style="color:var(--purple);"></i>
                    <h4 style="margin:0; font-size:14px; color:var(--text-hi); font-weight:700;">AI Review Summary</h4>
                </div>
                <p id="aiReviewSummaryText" style="margin:0; font-size:14px; color:var(--text-md); line-height:1.5;">
                    <button id="btnGenerateReviewSummary" style="background:none; border:none; color:var(--purple-lt); font-weight:600; cursor:pointer; padding:0; font-size:14px;" data-id="<%= product._id %>">Generate Sentiment Summary ✦</button>
                </p>
            </div>
            <% } %>

            <% if (locals.user) { %>
            <div id="reviewFormContainer" style="display:none;background:var(--surface-2);padding:24px;border-radius:16px;margin-bottom:28px;border:1px solid var(--border)">
                <form action="/api/products/<%= product._id %>/review" method="POST" enctype="multipart/form-data">
                    <h4 style="margin:0 0 16px;color:var(--text-hi)">Share your experience</h4>
                    <div class="input-group">
                        <label>Rating</label>
                        <div class="input-wrap">
                            <select name="rating" required style="width:100%;height:44px;padding:0 16px;background:var(--surface);border:1.5px solid var(--border-2);border-radius:var(--r-md);color:var(--text-hi);font-size:14px;outline:none;appearance:none">
                                <option value="5">5 ★ — Excellent</option>
                                <option value="4">4 ★ — Very Good</option>
                                <option value="3">3 ★ — Good</option>
                                <option value="2">2 ★ — Fair</option>
                                <option value="1">1 ★ — Poor</option>
                            </select>
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Your Review</label>
                        <div class="input-wrap">
                            <textarea name="comment" rows="3" required placeholder="What did you like or dislike?" style="width:100%;padding:12px 16px;background:var(--surface);border:1.5px solid var(--border-2);border-radius:var(--r-md);color:var(--text-hi);font-size:14px;outline:none;resize:vertical"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:fit-content;padding:10px 24px">Submit Review</button>
                </form>
            </div>
            <% } %>

            <div class="reviews-grid">
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach(review => { %>
                    <div class="review-card">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px">
                            <div style="display:flex;align-items:center;gap:10px">
                                <div class="review-avatar"><%= review.user.name.charAt(0).toUpperCase() %></div>
                                <div>
                                    <div class="review-name"><%= review.user.name %></div>
                                    <div class="review-date"><%= review.createdAt.toLocaleDateString('en-IN', {year:'numeric',month:'short',day:'numeric'}) %></div>
                                </div>
                            </div>
                            <% if (locals.user && (review.user._id.toString() === locals.user._id.toString() || locals.user.role === 'admin')) { %>
                                <button onclick="deleteReview('<%= product._id %>', '<%= review._id %>')" style="background:none;border:none;color:var(--text-lo);cursor:pointer;padding:4px" title="Delete"><i class="fa-solid fa-trash-can fa-sm"></i></button>
                            <% } %>
                        </div>
                        <div class="review-rating">
                            <% for(let i=1;i<=5;i++) { %><i class="<%= i <= review.rating ? 'fa-solid' : 'fa-regular' %> fa-star"></i><% } %>
                        </div>
                        <div class="review-body"><%= review.comment %></div>
                        <% if (review.media && review.media.length > 0) { %>
                        <div style="display:flex;gap:8px;margin-top:12px;overflow-x:auto">
                            <% review.media.forEach(mediaPath => { %>
                                <% if (mediaPath.match(/\.(mp4|webm|ogg)$/i)) { %>
                                    <video src="<%= mediaPath %>" controls style="height:70px;border-radius:6px;border:1px solid var(--border)"></video>
                                <% } else { %>
                                    <img src="<%= mediaPath %>" alt="Review" style="height:70px;border-radius:6px;border:1px solid var(--border);cursor:pointer" onclick="window.open(this.src,'_blank')">
                                <% } %>
                            <% }); %>
                        </div>
                        <% } %>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column:1/-1;text-align:center;padding:48px 24px;background:var(--surface-2);border-radius:16px;border:1px solid var(--border)">
                        <div style="font-size:40px;margin-bottom:12px">💬</div>
                        <p style="color:var(--text-lo)">No reviews yet. Be the first!</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</div><%# end pdp-container %>
</div><%# end pdp-page %>

<%# ── Similar Products ── %>
<% if (similarProducts && similarProducts.length > 0) { %>
<div style="background:var(--surface-2);border-top:1px solid var(--border);padding:48px 0 64px">
    <div class="container">
        <div class="pdp-similar-header">
            <div>
                <h2 style="font-size:24px;font-weight:800;color:var(--text-hi);margin-bottom:4px">Frequently Bought Together</h2>
                <p style="color:var(--text-lo);font-size:14px">Complete the look with these complementary items</p>
            </div>
            <a href="/shop?category=<%= (product.category && product.category.slug) ? product.category.slug : '' %>" style="color:var(--purple-lt);font-size:14px;font-weight:600;text-decoration:none">View all <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="product-grid">
            <% similarProducts.forEach(simProduct => { %>
            <div class="product-card" style="cursor: pointer;" onclick="if(!event.target.closest('button')) window.location.href='/product/<%= simProduct._id %>'">
                <% if (simProduct.isFeatured) { %><span class="product-badge product-badge-ai">Hot</span><% } %>
                <button class="product-wishlist" aria-label="Add to wishlist" data-product-id="<%= simProduct._id %>"><i class="fa-regular fa-heart"></i></button>
                <div class="product-card-image">
                    <% if (simProduct.image) { %>
                        <img src="<%= simProduct.image %>" alt="<%= simProduct.title %>" loading="lazy" data-product-image>
                    <% } else { %>
                        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:48px">
                            <%= (simProduct.category && simProduct.category.icon) ? simProduct.category.icon : '📦' %>
                        </div>
                    <% } %>
                </div>
                <div class="product-card-body">
                    <span class="product-category-tag"><%= (simProduct.category && simProduct.category.name) ? simProduct.category.name : 'General' %></span>
                    <h3 class="product-title"><%= simProduct.title %></h3>
                    <div class="product-price-row">
                        <span class="product-price">₹<%= simProduct.price.toLocaleString('en-IN', {maximumFractionDigits:0}) %></span>
                    </div>
                </div>
                <div class="product-card-footer">
                    <button class="btn-add-cart" type="button" data-add-to-cart data-product-id="<%= simProduct._id %>">Add to Cart</button>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</div>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // ── Tab switching ──
    const tabs = document.querySelectorAll('.pdp-tab');
    const contents = document.querySelectorAll('.pdp-tab-content');
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            contents.forEach(c => c.classList.remove('active'));
            tab.classList.add('active');
            document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        });
    });

    // ── Thumbnail gallery ──
    const thumbRow = document.getElementById('thumbRow');
    const mainImg = document.getElementById('mainProductImg');
    if (thumbRow && mainImg) {
        thumbRow.querySelectorAll('.pdp-thumb').forEach(thumb => {
            thumb.addEventListener('click', () => {
                thumbRow.querySelectorAll('.pdp-thumb').forEach(t => t.classList.remove('active'));
                thumb.classList.add('active');
                mainImg.src = thumb.dataset.img;
            });
        });
    }

    // ── Toggle review form ──
    const toggleBtn = document.getElementById('toggleReviewFormBtn');
    const formContainer = document.getElementById('reviewFormContainer');
    if (toggleBtn && formContainer) {
        toggleBtn.addEventListener('click', () => {
            const open = formContainer.style.display !== 'none' && formContainer.style.display !== '';
            formContainer.style.display = open ? 'none' : 'block';
            toggleBtn.textContent = open ? 'Write a Review' : 'Cancel';
        });
    }
});

async function deleteReview(productId, reviewId) {
    if (!confirm('Delete this review?')) return;
    try {
        const res = await fetch(`/api/products/${productId}/review/${reviewId}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) window.location.reload();
        else alert(data.message || 'Failed to delete.');
    } catch (e) { alert('Error deleting review.'); }
}
</script>

<% } %>
