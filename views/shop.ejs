<div class="shop-page">
    
    <!-- Category Strip -->
    <div class="shop-category-strip">
        <a href="/shop" class="shop-cat-pill <%= !activeCategory ? 'active' : '' %>">
            ✨ All Products
        </a>
        <% categories.forEach(category => { %>
            <a href="/shop?category=<%= category.slug %>" class="shop-cat-pill <%= activeCategory === category.slug ? 'active' : '' %>">
                <%= category.icon %> <%= category.name %>
            </a>
        <% }) %>
    </div>

    <!-- Shop Layout (Sidebar + Grid) -->
    <div class="shop-layout">
        
        <!-- Sidebar Filters -->
        <aside class="shop-sidebar">
            <h3 class="sidebar-title">Filters</h3>
            
            <div class="filter-group">
                <span class="filter-group-label">Categories</span>
                <a href="/shop" class="filter-link <%= !activeCategory ? 'selected' : '' %>">
                    <i class="<%= !activeCategory ? 'fa-solid fa-square-check' : 'fa-regular fa-square' %>"></i> All Categories
                </a>
                <% categories.forEach(category => { %>
                    <a href="/shop?category=<%= category.slug %>" class="filter-link <%= activeCategory === category.slug ? 'selected' : '' %>">
                        <i class="<%= activeCategory === category.slug ? 'fa-solid fa-square-check' : 'fa-regular fa-square' %>"></i> <%= category.name %>
                    </a>
                <% }) %>
            </div>

            <hr class="filter-sep">

            <div class="filter-group">
                <span class="filter-group-label">Price Range</span>
                <a href="#" class="filter-link"><i class="fa-regular fa-circle"></i> Under ₹5,000</a>
                <a href="#" class="filter-link"><i class="fa-regular fa-circle"></i> ₹5,000 - ₹20,000</a>
                <a href="#" class="filter-link"><i class="fa-regular fa-circle"></i> ₹20,000 - ₹50,000</a>
                <a href="#" class="filter-link"><i class="fa-regular fa-circle"></i> Over ₹50,000</a>
            </div>

            <hr class="filter-sep">

            <div class="filter-group">
                <span class="filter-group-label">Customer Rating</span>
                <a href="#" class="filter-link"><i class="fa-regular fa-circle"></i> 4★ & above</a>
                <a href="#" class="filter-link"><i class="fa-regular fa-circle"></i> 3★ & above</a>
            </div>
        </aside>

        <!-- Main Catalogue -->
        <main class="shop-main">
            
            <div class="shop-header">
                <div>
                    <h1 class="shop-heading">
                        <%= activeCategory ? categories.find(c => c.slug === activeCategory)?.name || 'Shop' : 'All Products' %>
                    </h1>
                    <span class="shop-count">Showing <%= products.length %> products</span>
                </div>
                
                <div class="sort-bar">
                    <span class="sort-label">Sort by:</span>
                    <a href="/shop?<%= activeCategory ? 'category=' + activeCategory + '&' : '' %>sort=popular" class="sort-btn <%= activeSort === 'popular' ? 'active' : '' %>">Popularity</a>
                    <a href="/shop?<%= activeCategory ? 'category=' + activeCategory + '&' : '' %>sort=price-low" class="sort-btn <%= activeSort === 'price-low' ? 'active' : '' %>">Price: Low to High</a>
                    <a href="/shop?<%= activeCategory ? 'category=' + activeCategory + '&' : '' %>sort=price-high" class="sort-btn <%= activeSort === 'price-high' ? 'active' : '' %>">Price: High to Low</a>
                </div>
            </div>

            <% if (products && products.length > 0) { %>
                <div class="catalogue-grid" id="product-grid">
                    <% products.forEach(product => { %>
                        <a href="/product/<%= product._id %>" class="product-card">
                            <% if (product.isFeatured) { %>
                                <span class="product-badge product-badge-ai">Hot</span>
                            <% } %>
                            <button class="product-wishlist" aria-label="Add to wishlist" data-product-id="<%= product._id %>"><i class="fa-regular fa-heart"></i></button>
                            <div class="product-card-image">
                                <% if (product.image) { %>
                                    <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" data-product-image>
                                <% } else { %>
                                    <%= product.category?.icon || '📁' %>
                                <% } %>
                            </div>
                            <div class="product-card-body">
                                <span class="product-category-tag"><%= product.brand || 'NeuraCart' %></span>
                                <h3 class="product-title"><%= product.title %></h3>
                                <div class="product-meta">
                                    <span class="product-price">₹<%= product.price.toFixed(2) %></span>
                                    <span class="product-rating">
                                        <i class="fa-solid fa-star"></i> <%= product.ratings.average %>
                                        <span class="product-rating-count">(<%= product.ratings.count %>)</span>
                                    </span>
                                </div>
                                <% if (product.stock < 10) { %>
                                    <div class="product-stock-low">Only <%= product.stock %> left!</div>
                                <% } %>
                                <button class="btn-add-cart" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                                    <i class="fa-solid fa-cart-plus"></i> Add to Cart
                                </button>
                            </div>
                        </a>
                    <% }) %>
                </div>

                <% if (hasNextPage) { %>
                    <!-- Infinite Scroll Observer Target -->
                    <div id="infinite-scroll-trigger" data-current-page="<%= currentPage %>" data-has-next="true" data-category="<%= activeCategory %>" data-sort="<%= activeSort %>" data-query="<%= searchQuery %>" style="display: flex; justify-content: center; padding: 40px; color: var(--purple-lt);">
                        <i class="fa-solid fa-circle-notch fa-spin fa-2x"></i>
                    </div>
                <% } %>
                
            <% } else { %>
                <div class="shop-empty">
                    <div class="shop-empty-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
                    <h2>No products found</h2>
                    <p>We couldn't find any products matching your criteria.</p>
                    <a href="/shop" class="btn btn-primary" style="margin-top: 16px;">Clear all filters</a>
                </div>
            <% } %>
            
        </main>
    </div>
</div>
