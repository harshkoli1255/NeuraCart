<div class="container" style="padding-top: 40px; padding-bottom: 80px;">
    
    <div class="profile-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px;">
        <div>
            <h1 style="font-size: 32px; font-weight: 700; color: var(--text-hi); margin-bottom: 8px;">My Profile</h1>
            <p style="color: var(--text-lo); font-size: 16px;">Welcome back, <strong><%= user.name %></strong>!</p>
        </div>
        <div>
            <span style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; background: var(--surface-2); border-radius: var(--r-full); border: 1px solid var(--border); font-size: 13px; font-weight: 600; color: var(--text-hi);">
                <% if (user.role === 'seller') { %>
                    <i class="fa-solid fa-store" style="color: var(--cyan);"></i> Seller Account
                <% } else { %>
                    <i class="fa-solid fa-bag-shopping" style="color: var(--purple-lt);"></i> Buyer Account
                <% } %>
            </span>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 300px 1fr; gap: 32px;">
        <!-- Sidebar -->
        <aside>
            <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 24px;">
                <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--grad-purple); display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 700; color: #fff; margin-bottom: 16px;">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <h2 style="font-size: 18px; font-weight: 600; color: var(--text-hi); margin-bottom: 4px;"><%= user.name %></h2>
                <p style="color: var(--text-lo); font-size: 14px; margin-bottom: 24px;"><%= user.email %></p>

                <hr style="border: none; border-top: 1px solid var(--border-2); margin-bottom: 24px;">

                <nav style="display: flex; flex-direction: column; gap: 12px;">
                    <a href="/auth/profile" style="color: <%= activeTab === 'details' ? 'var(--purple-lt)' : 'var(--text-lo)' %>; font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-solid fa-user" style="width: 20px;"></i> Account Details</a>
                    
                    <% if (user.role === 'seller') { %>
                        <a href="/seller/dashboard" style="color: var(--text-lo); font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-solid fa-gauge-high" style="width: 20px;"></i> Seller Dashboard</a>
                        <a href="/seller/products" style="color: var(--text-lo); font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-solid fa-box-open" style="width: 20px;"></i> Manage Products</a>
                    <% } else { %>
                        <a href="/auth/profile/orders" style="color: <%= activeTab === 'orders' ? 'var(--purple-lt)' : 'var(--text-lo)' %>; font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-solid fa-box-open" style="width: 20px;"></i> Order History</a>
                        <a href="/auth/profile/wishlist" style="color: <%= activeTab === 'wishlist' ? 'var(--purple-lt)' : 'var(--text-lo)' %>; font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-regular fa-heart" style="width: 20px;"></i> Wishlist</a>
                    <% } %>
                    
                    <a href="/auth/logout" style="color: #ef4444; font-weight: 500; display: flex; align-items: center; gap: 12px; margin-top: 12px; transition: opacity var(--ease);"><i class="fa-solid fa-right-from-bracket" style="width: 20px;"></i> Log Out</a>
                </nav>
            </div>
        </aside>

        <!-- Main Content -->
        <main>
            <% if (activeTab === 'details') { %>
                <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 32px;">
                    <h3 style="font-size: 20px; font-weight: 600; color: var(--text-hi); margin-bottom: 24px;">Account Details</h3>
                    
                    <form class="auth-form" style="max-width: 500px;">
                        <div class="input-group">
                            <label>Full Name</label>
                            <div class="input-wrap">
                                <input type="text" value="<%= user.name %>" readonly style="background: var(--surface-2); color: var(--text-lo);">
                                <i class="fa-regular fa-user"></i>
                            </div>
                        </div>
                        
                        <div class="input-group">
                            <label>Email Address</label>
                            <div class="input-wrap">
                                <input type="email" value="<%= user.email %>" readonly style="background: var(--surface-2); color: var(--text-lo);">
                                <i class="fa-regular fa-envelope"></i>
                            </div>
                        </div>
                        
                        <div class="input-group">
                            <label>Member Since</label>
                            <div class="input-wrap">
                                <input type="text" value="<%= new Date(user.createdAt).toLocaleDateString() %>" readonly style="background: var(--surface-2); color: var(--text-lo);">
                                <i class="fa-regular fa-calendar"></i>
                            </div>
                        </div>
                        
                        <p style="color: var(--text-lo); font-size: 13px; margin-top: 16px;"><i class="fa-solid fa-circle-info"></i> To update your details or change your password, please contact support.</p>
                    </form>
                </div>
            <% } %>

            <% if (activeTab === 'orders' && user.role === 'buyer') { %>
                <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 32px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                        <h3 style="font-size: 20px; font-weight: 600; color: var(--text-hi);">Order History</h3>
                    </div>
                    <div style="text-align: center; padding: 60px 20px;">
                        <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; font-size: 32px; color: var(--text-lo);">
                            <i class="fa-solid fa-box"></i>
                        </div>
                        <p style="color: var(--text-hi); font-size: 18px; font-weight: 600; margin-bottom: 12px;">No orders yet</p>
                        <p style="color: var(--text-lo); font-size: 15px; margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto;">When you purchase items, your complete order history, tracking details, and invoices will appear here.</p>
                        <a href="/shop" class="nc-btn-secondary">Start Shopping</a>
                    </div>
                </div>
            <% } %>

            <% if (activeTab === 'wishlist' && user.role === 'buyer') { %>
                <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 32px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                        <h3 style="font-size: 20px; font-weight: 600; color: var(--text-hi);">My Wishlist</h3>
                    </div>
                    <div style="text-align: center; padding: 60px 20px;">
                        <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; font-size: 32px; color: var(--text-lo);">
                            <i class="fa-regular fa-heart"></i>
                        </div>
                        <p style="color: var(--text-hi); font-size: 18px; font-weight: 600; margin-bottom: 12px;">Your wishlist is empty</p>
                        <p style="color: var(--text-lo); font-size: 15px; margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto;">Save items you love to your wishlist to easily find and purchase them later.</p>
                        <a href="/shop" class="nc-btn-secondary">Explore Products</a>
                    </div>
                </div>
            <% } %>
        </main>
    </div>
</div>
