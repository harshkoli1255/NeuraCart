<div class="auth-page">
    <!-- LEFT: Branding Panel / CSS Mesh -->
    <div class="auth-left">
        <div class="auth-left-content">
            <img src="/assets/favicon/favicon.png" alt="NeuraCart Logo" class="auth-hero-logo" />
            <h2>Welcome Back</h2>
            <p>Log in to your account to continue your journey and unlock personalized AI recommendations.</p>
        </div>
    </div>

    <!-- RIGHT: Login Form -->
    <div class="auth-right">
        <div class="auth-card">
            <div class="auth-header">
                <a href="/" class="auth-logo">
                    <img src="/images/favicon.png" alt="NeuraCart" style="border-radius: 12px; overflow: hidden;">
                    <span class="auth-logo-name">NeuraCart</span>
                </a>
                <p class="auth-subtitle">Sign in to continue</p>
                <h1>Welcome back 👋</h1>
            </div>
            
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="auth-alert auth-alert-success">
                    <i class="fa-solid fa-circle-check"></i> <%= success_msg %>
                </div>
            <% } %>
            
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="auth-alert auth-alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= error_msg %>
                </div>
            <% } %>

            <% if (error && error.length > 0) { %>
                <div class="auth-alert auth-alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
                </div>
            <% } %>

            <form action="/auth/login" method="POST" class="auth-form">
                <div class="input-group">
                    <label for="email">Email Address</label>
                    <div class="input-wrap">
                        <input type="email" id="email" name="email" placeholder="user@example.com" required autocomplete="email">
                        <i class="fa-regular fa-envelope"></i>
                    </div>
                </div>

                <div class="input-group">
                    <label for="password">Password</label>
                    <div class="input-wrap">
                        <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
                        <i class="fa-regular fa-lock"></i>
                    </div>
                </div>

                <div class="forgot-row">
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="auth-btn">Log In</button>
                
                <div class="auth-divider"><span>or</span></div>
                
                <a href="/auth/google" class="btn-google">
                    <i class="fa-brands fa-google" style="color: #EA4335;"></i>
                    Continue with Google
                </a>
            </form>

            <div class="auth-footer">
                <p>Don't have an account? <a href="/auth/register" class="auth-link">Sign up free →</a></p>
            </div>
        </div>
    </div>
</div>
