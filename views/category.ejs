<div class="category-page">

    <!-- Background blobs -->
    <div class="blob blob-pink"></div>
    <div class="blob blob-purple"></div>
    <div class="blob blob-blue"></div>

    <!-- ======== NAVBAR ======== -->
    <nav class="navbar" id="navbar">
        <!-- Column 1: Logo -->
        <a href="/" class="nav-logo">
            <img src="/images/favicon.png" alt="NeuraCart logo">
            <span class="nav-logo-name">NeuraCart</span>
            <span class="nav-logo-beta">Beta</span>
        </a>

        <!-- Column 2: Search + Links -->
        <div class="nav-middle">
            <div class="nav-search-wrap">
                <div class="nav-search-icon-sm" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" class="nav-search-input-sm" placeholder="Search products..." aria-label="Search">
                <button class="nav-search-submit" aria-label="Submit search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>
            <div class="nav-sep"></div>
            <div class="nav-links-row">
                <a href="/shop">Shop</a>
                <a href="/#">Deals</a>
                <a href="/#">AI Picks</a>
            </div>
        </div>

        <!-- Column 3: Right actions -->
        <div class="nav-right">
            <a href="#" class="nav-cart-btn" aria-label="Cart (0 items)">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <span class="cart-count">0</span>
            </a>
            <div class="nav-right-sep"></div>
            <a href="/auth/login" class="nav-login">Log In</a>
            <a href="/auth/register" class="nav-signup">
                Get Started
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
            </a>
            <button class="nav-hamburger" id="hamburger-btn" aria-label="Toggle menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <!-- Mobile slide-down drawer -->
    <div class="nav-mobile-menu" id="mobile-menu" role="navigation" aria-label="Mobile navigation">
        <div class="nav-mobile-search">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" placeholder="Search products..." aria-label="Mobile search">
        </div>
        <a href="/shop"><span>🛍️</span> Shop</a>
        <a href="/#"><span>📁</span> Categories</a>
        <a href="/#"><span>🔥</span> Deals</a>
        <a href="/#"><span>✨</span> AI Picks</a>
        <div class="mobile-divider"></div>
        <div class="mobile-auth-row">
            <a href="/auth/login" class="mobile-login">Log In</a>
            <a href="/auth/register" class="mobile-signup">Get Started →</a>
        </div>
    </div>

    <!-- ======== MAIN CATEGORY CONTENT LAYOUT ======== -->
    <div class="category-layout-container">
        
        <!-- Left Sidebar Filter Section -->
        <aside class="category-sidebar">
            <div class="sidebar-box">
                <h3 class="sidebar-title">Subcategories</h3>
                <ul class="sidebar-list">
                    <li>
                        <a href="/category/<%= categoryName %><%= selectedSort ? '?sort=' + selectedSort : '' %>" 
                           class="sidebar-link <%= !selectedSubcategory ? 'active' : '' %>">
                            All Subcategories
                        </a>
                    </li>
                    <% subcategories.forEach(sub => { %>
                        <li>
                            <a href="/category/<%= categoryName %>?subcategory=<%= encodeURIComponent(sub) %><%= selectedSort ? '&sort=' + selectedSort : '' %>" 
                               class="sidebar-link <%= selectedSubcategory === sub ? 'active' : '' %>">
                                <%= sub %>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            </div>

            <div class="sidebar-box">
                <h3 class="sidebar-title">Sort By Price</h3>
                <ul class="sidebar-list">
                    <li>
                        <a href="/category/<%= categoryName %>?sort=low<%= selectedSubcategory ? '&subcategory=' + encodeURIComponent(selectedSubcategory) : '' %>" 
                           class="sidebar-link <%= selectedSort === 'low' ? 'active' : '' %>">
                            Price: Low to High
                        </a>
                    </li>
                    <li>
                        <a href="/category/<%= categoryName %>?sort=high<%= selectedSubcategory ? '&subcategory=' + encodeURIComponent(selectedSubcategory) : '' %>" 
                           class="sidebar-link <%= selectedSort === 'high' ? 'active' : '' %>">
                            Price: High to Low
                        </a>
                    </li>
                    <% if (selectedSort) { %>
                        <li class="clear-sort-li">
                            <a href="/category/<%= categoryName %><%= selectedSubcategory ? '?subcategory=' + encodeURIComponent(selectedSubcategory) : '' %>" 
                               class="sidebar-link clear-link">
                                ✕ Clear Sorting
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </aside>

        <!-- Right Product Grid Section -->
        <main class="category-main">
            <div class="category-header-row">
                <div class="category-title-wrap">
                    <span class="category-badge-icon"><%= category.icon %></span>
                    <div>
                        <h1 class="category-main-title">Shop <%= category.name %></h1>
                        <p class="category-main-subtitle">
                            Displaying <%= products.length %> product<%= products.length === 1 ? '' : 's' %>
                            <% if (selectedSubcategory) { %> in <strong><%= selectedSubcategory %></strong><% } %>
                        </p>
                    </div>
                </div>
                
                <!-- Quick stats / active tags -->
                <div class="active-filters-row">
                    <% if (selectedSubcategory || selectedSort) { %>
                        <span class="filter-pill-label">Active Filters:</span>
                        <% if (selectedSubcategory) { %>
                            <span class="filter-pill">
                                <%= selectedSubcategory %>
                                <a href="/category/<%= categoryName %><%= selectedSort ? '?sort=' + selectedSort : '' %>" class="filter-pill-remove">✕</a>
                            </span>
                        <% } %>
                        <% if (selectedSort) { %>
                            <span class="filter-pill">
                                Sort: <%= selectedSort === 'low' ? 'Low to High' : 'High to Low' %>
                                <a href="/category/<%= categoryName %><%= selectedSubcategory ? '?subcategory=' + encodeURIComponent(selectedSubcategory) : '' %>" class="filter-pill-remove">✕</a>
                            </span>
                        <% } %>
                        <a href="/category/<%= categoryName %>" class="clear-all-filters">Clear All</a>
                    <% } %>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="product-grid">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(product => { %>
                        <a href="/product/<%= product._id %>" class="product-card" style="text-decoration: none; color: inherit; display: block;">
                            <% if (product.isFeatured) { %>
                                <span class="product-badge">Hot</span>
                            <% } %>
                            <button class="product-wishlist" aria-label="Add to wishlist" onclick="event.preventDefault();">♡</button>
                            <div class="product-image">
                                <% if (product.image) { %>
                                    <img src="<%= product.image %>" alt="<%= product.name %>" style="width:100%; height:100%; object-fit:cover;" data-product-image>
                                    <div class="fallback-icon-wrap" style="display:none; width:100%; height:100%; align-items:center; justify-content:center; font-size:60px;">
                                        <%= category.icon %>
                                    </div>
                                <% } else { %>
                                    <%= category.icon %>
                                <% } %>
                            </div>
                            <div class="product-info">
                                <span class="product-category-tag"><%= product.subcategory %></span>
                                <h3 class="product-title"><%= product.name %></h3>
                                <div class="product-meta">
                                    <span class="product-price">₹<%= product.price.toFixed(2) %></span>
                                    <span class="product-rating">★ <%= product.ratings.average %></span>
                                </div>
                                <button class="btn-add-cart" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                                    Add to Cart
                                </button>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="no-products-box">
                        <div class="no-products-icon">🔍</div>
                        <h3>No products match your criteria.</h3>
                        <p>Try widening your search or clearing active filters to see other products.</p>
                        <a href="/category/<%= categoryName %>" class="btn-reset-filters">Show All <%= category.name %> Products</a>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- ======== FOOTER ======== -->
    <footer class="site-footer">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="/" class="nav-logo">
                    <img src="/images/favicon.png" alt="NeuraCart">
                    <span class="nav-logo-name">NeuraCart</span>
                </a>
                <p class="footer-desc">The AI-powered e-commerce platform that finds the right product for you in seconds — so you can shop with confidence.</p>
                <div class="footer-social">
                    <a href="#" aria-label="Twitter">𝕏</a>
                    <a href="#" aria-label="Instagram">📸</a>
                    <a href="#" aria-label="LinkedIn">in</a>
                </div>
            </div>
            <div class="footer-col">
                <h4>Shop</h4>
                <ul>
                    <li><a href="#">New Arrivals</a></li>
                    <li><a href="#">Best Sellers</a></li>
                    <li><a href="#">Today's Deals</a></li>
                    <li><a href="#">AI Picks</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <ul>
                    <li><a href="#">Help Centre</a></li>
                    <li><a href="#">Track Order</a></li>
                    <li><a href="#">Returns</a></li>
                    <li><a href="#">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Company</h4>
                <ul>
                    <li><a href="#">About</a></li>
                    <li><a href="#">Blog</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="footer-copy">© 2025 NeuraCart Inc. All rights reserved.</p>
            <div class="footer-badges">
                <span class="footer-badge">🔒 Secure Checkout</span>
                <span class="footer-badge">⚡ AI-Powered</span>
                <span class="footer-badge">🚚 Free Shipping</span>
            </div>
        </div>
    </footer>

</div>
