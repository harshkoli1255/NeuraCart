<div class="deals-page">

    <!-- ======== DEALS HERO ======== -->
    <section class="deals-hero">
        <div class="deals-hero-badge">
            <i class="fa-solid fa-bolt"></i> Limited Time Offers
        </div>
        <h1>Today's <span>Hottest Deals</span></h1>
        <p>Handpicked discounts updated daily. Score massive savings on top-rated products before stock runs out.</p>

        <!-- Countdown Timer -->
        <div class="deals-countdown-row">
            <span class="deals-countdown-label">Deals end in</span>
            <div class="deals-timer" id="deals-timer">
                <div class="deals-timer-block">
                    <span class="deals-timer-num" id="timer-hours">08</span>
                    <span class="deals-timer-label">Hours</span>
                </div>
                <span class="deals-timer-sep">:</span>
                <div class="deals-timer-block">
                    <span class="deals-timer-num" id="timer-minutes">42</span>
                    <span class="deals-timer-label">Min</span>
                </div>
                <span class="deals-timer-sep">:</span>
                <div class="deals-timer-block">
                    <span class="deals-timer-num" id="timer-seconds">15</span>
                    <span class="deals-timer-label">Sec</span>
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="deals-stats">
            <div class="deals-stat">
                <i class="fa-solid fa-fire" style="color: #ff4757;"></i>
                <span class="stat-num"><%= totalDeals %></span> Active Deals
            </div>
            <div class="deals-stat">
                <i class="fa-solid fa-arrow-trend-down" style="color: #10b981;"></i>
                Up to <span class="stat-num">60%</span> Off
            </div>
            <div class="deals-stat">
                <i class="fa-solid fa-truck-fast" style="color: var(--cyan);"></i>
                Free Delivery
            </div>
            <div class="deals-stat">
                <i class="fa-solid fa-shield-check" style="color: var(--purple-lt);"></i>
                Buyer Protection
            </div>
        </div>
    </section>

    <div class="deals-container">

        <% if (featuredDeal) { %>
        <!-- ======== DEAL OF THE DAY ======== -->
        <div class="deals-section">
            <div class="deals-section-header">
                <div class="deals-section-title">
                    <div class="deals-section-icon" style="background: rgba(255,71,87,0.12); color: #ff4757;">
                        <i class="fa-solid fa-crown"></i>
                    </div>
                    <div>
                        <h2>Deal of the Day</h2>
                        <span class="deals-section-subtitle">Our biggest discount right now</span>
                    </div>
                </div>
            </div>

            <a href="/product/<%= featuredDeal._id %>" class="deal-featured">
                <div class="deal-featured-image">
                    <img src="<%= featuredDeal.image %>" alt="<%= featuredDeal.title %>" loading="lazy" onerror="this.parentElement.classList.add('image-load-failed');">
                </div>
                <div class="deal-featured-body">
                    <span class="deal-featured-badge">
                        <i class="fa-solid fa-fire"></i> Deal of the Day
                    </span>
                    <span class="deal-card-category"><%= featuredDeal.category ? featuredDeal.category.name : 'Featured' %></span>
                    <h3 class="deal-featured-title"><%= featuredDeal.title %></h3>
                    <p class="deal-featured-desc"><%= featuredDeal.description ? featuredDeal.description.substring(0, 150) + '...' : '' %></p>
                    <div class="deal-featured-prices">
                        <span class="deal-featured-price-current">$<%= featuredDeal.price.toFixed(2) %></span>
                        <span class="deal-featured-price-original">$<%= (featuredDeal.price * 1.6).toFixed(2) %></span>
                        <span class="deal-featured-savings"><i class="fa-solid fa-arrow-down"></i> Save 38%</span>
                    </div>
                    <span class="deal-featured-cta">
                        <i class="fa-solid fa-cart-plus"></i> Grab This Deal
                    </span>
                </div>
            </a>
        </div>
        <% } %>

        <% if (flashDeals && flashDeals.length > 0) { %>
        <!-- ======== FLASH DEALS ======== -->
        <div class="deals-section">
            <div class="deals-section-header">
                <div class="deals-section-title">
                    <div class="deals-section-icon" style="background: rgba(255,165,2,0.12); color: #ffa502;">
                        <i class="fa-solid fa-bolt"></i>
                    </div>
                    <div>
                        <h2>Flash Deals</h2>
                        <span class="deals-section-subtitle">Lowest prices — selling fast!</span>
                    </div>
                </div>
                <a href="/shop" class="deals-view-all">
                    View all <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>

            <div class="deals-grid">
                <% flashDeals.forEach((product, index) => { %>
                    <%
                        const discountPercents = [55, 42, 38, 30, 48, 35, 25, 60];
                        const discount = discountPercents[index % discountPercents.length];
                        const originalPrice = (product.price / (1 - discount / 100)).toFixed(2);
                        const claimed = Math.floor(Math.random() * 40) + 55;
                    %>
                    <div class="deal-card">
                        <a href="/product/<%= product._id %>" class="deal-card-link">
                            <div class="deal-card-image">
                                <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" onerror="this.parentElement.classList.add('image-load-failed');">
                                <span class="deal-card-discount">
                                    <i class="fa-solid fa-arrow-down"></i> <%= discount %>% OFF
                                </span>
                                <span class="deal-card-timer">
                                    <i class="fa-regular fa-clock"></i> <%= Math.floor(Math.random() * 8) + 1 %>h left
                                </span>
                            </div>
                            <div class="deal-card-body">
                                <span class="deal-card-category"><%= product.category ? product.category.name : 'General' %></span>
                                <h3 class="deal-card-title"><%= product.title %></h3>
                                <div class="deal-card-price-row">
                                    <span class="deal-card-price">$<%= product.price.toFixed(2) %></span>
                                    <span class="deal-card-original">$<%= originalPrice %></span>
                                    <span class="deal-card-save">Save <%= discount %>%</span>
                                </div>
                                <div class="deal-card-progress">
                                    <div class="deal-card-progress-bar">
                                        <div class="deal-card-progress-fill" style="width: <%= claimed %>%;"></div>
                                    </div>
                                    <span class="deal-card-progress-text"><%= claimed %>% claimed</span>
                                </div>
                            </div>
                        </a>
                        <div style="padding: 0 14px 14px;">
                            <button class="deal-card-btn" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                                <i class="fa-solid fa-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- ======== PROMO BANNER ======== -->
        <div class="deal-promo-banner">
            <div class="deal-promo-content">
                <h3><i class="fa-solid fa-bell" style="color: #ffa502; margin-right: 8px;"></i>Never Miss a Deal</h3>
                <p>Sign up for price drop alerts and get notified when your favorite products go on sale.</p>
            </div>
            <% if (locals.user) { %>
                <button class="deal-promo-cta" id="deal-alerts-btn" type="button" style="border: none; cursor: pointer;">
                    <i class="fa-solid fa-bell"></i> Get Deal Alerts
                </button>
            <% } else { %>
                <a href="/auth/login" class="deal-promo-cta">
                    <i class="fa-solid fa-bell"></i> Get Deal Alerts
                </a>
            <% } %>
        </div>

        <% if (moreDeals && moreDeals.length > 0) { %>
        <!-- ======== MORE DEALS ======== -->
        <div class="deals-section">
            <div class="deals-section-header">
                <div class="deals-section-title">
                    <div class="deals-section-icon" style="background: rgba(139,92,246,0.12); color: var(--purple-lt);">
                        <i class="fa-solid fa-percent"></i>
                    </div>
                    <div>
                        <h2>More Great Deals</h2>
                        <span class="deals-section-subtitle">Even more savings across all categories</span>
                    </div>
                </div>
            </div>

            <% if (dealCategories && dealCategories.length > 1) { %>
            <div class="deals-category-strip" id="deals-cat-strip">
                <button type="button" class="deals-cat-pill <%= activeCategory === 'all' ? 'active' : '' %>" data-filter="all">🔥 All Deals</button>
                <% dealCategories.forEach(cat => { %>
                    <button type="button" class="deals-cat-pill <%= activeCategory === cat.name ? 'active' : '' %>" data-filter="<%= cat.name %>"><%= cat.icon || '📁' %> <%= cat.name %></button>
                <% }) %>
            </div>
            <% } %>

            <!-- ── Filter Status Bar ── -->
            <div id="deals-filter-bar" style="display:none; align-items:center; justify-content:space-between; gap:12px; margin-bottom:16px; padding:14px 20px; background:var(--surface-2); border:1px solid var(--border); border-radius:var(--r-lg);">
                <div style="display:flex; align-items:center; gap:10px;">
                    <span id="deals-filter-label" style="font-weight:700; color:var(--text-hi); font-size:15px;"></span>
                    <span id="deals-filter-count" style="font-size:13px; color:var(--text-md);"></span>
                </div>
                <button id="deals-clear-filters" type="button" style="display:flex; align-items:center; gap:6px; padding:7px 16px; border-radius:999px; border:1.5px solid var(--border); background:none; color:var(--text-md); cursor:pointer; font-size:13px; font-weight:600; transition:all 0.2s;">
                    <i class="fa-solid fa-xmark"></i> Clear Filters
                </button>
            </div>

            <!-- ── Loading Overlay ── -->
            <div id="deals-loading" style="display:none; padding:60px 0; text-align:center;">
                <div style="display:inline-block; width:44px; height:44px; border:3px solid var(--border); border-top-color:var(--purple-lt); border-radius:50%; animation:spin-loader 0.8s linear infinite;"></div>
                <p style="margin-top:16px; color:var(--text-md); font-size:14px;">Filtering deals…</p>
            </div>

            <!-- ── Dynamic Filtered Results Grid ── -->
            <div id="deals-filter-results" style="display:none;">
                <div class="deals-grid" id="deals-filter-grid"></div>
            </div>

            <!-- ── Empty State ── -->
            <div id="deals-empty-state" style="display:none; padding:64px 24px; text-align:center;">
                <div style="font-size:56px; margin-bottom:16px;">🔍</div>
                <h3 style="font-size:20px; font-weight:700; color:var(--text-hi); margin-bottom:8px;">No deals found</h3>
                <p style="color:var(--text-md); font-size:14px; margin-bottom:24px;">No deals match the selected category and discount threshold.<br>Try a different combination.</p>
                <button id="deals-empty-clear" type="button" class="nc-cta" style="height:40px; font-size:14px; padding:0 24px;">View All Deals</button>
            </div>

            <div class="deals-grid" id="more-deals-grid">
                <% moreDeals.forEach((product, index) => { %>
                    <%
                        const moreDiscounts = [20, 33, 28, 45, 22, 40, 15, 50, 35, 18];
                        const disc = moreDiscounts[index % moreDiscounts.length];
                        const origPrice = (product.price / (1 - disc / 100)).toFixed(2);
                    %>
                    <div class="deal-card" data-category="<%= product.category ? product.category.name : 'General' %>">
                        <a href="/product/<%= product._id %>" class="deal-card-link">
                            <div class="deal-card-image">
                                <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" onerror="this.parentElement.classList.add('image-load-failed');">
                                <span class="deal-card-discount">
                                    <i class="fa-solid fa-arrow-down"></i> <%= disc %>% OFF
                                </span>
                            </div>
                            <div class="deal-card-body">
                                <span class="deal-card-category"><%= product.category ? product.category.name : 'General' %></span>
                                <h3 class="deal-card-title"><%= product.title %></h3>
                                <div class="deal-card-price-row">
                                    <span class="deal-card-price">$<%= product.price.toFixed(2) %></span>
                                    <span class="deal-card-original">$<%= origPrice %></span>
                                    <span class="deal-card-save">Save <%= disc %>%</span>
                                </div>
                            </div>
                        </a>
                        <div style="padding: 0 14px 14px;">
                            <button class="deal-card-btn" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                                <i class="fa-solid fa-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <% if (totalDeals === 0) { %>
        <!-- Empty State -->
        <div class="cart-empty" style="margin-top: 60px;">
            <div class="cart-empty-icon">
                <i class="fa-regular fa-face-frown-open"></i>
            </div>
            <h1>No deals right now</h1>
            <p>Check back later for massive discounts on your favorite products!</p>
            <a href="/shop" class="cart-empty-cta" style="display: inline-flex; gap: 8px; text-decoration: none; margin-top: 8px;">Explore Shop</a>
        </div>
        <% } %>

    </div>
</div>

<!-- Countdown Timer + Deal Buttons Script -->
<script>
(function() {
    // ── Countdown Timer ──
    function getEndTime() {
        const now = new Date();
        const end = new Date(now);
        end.setHours(23, 59, 59, 999);
        return end;
    }
    
    const endTime = getEndTime();
    
    function updateTimer() {
        const now = new Date();
        let diff = Math.max(0, endTime - now) / 1000;
        
        const hours = Math.floor(diff / 3600);
        diff %= 3600;
        const minutes = Math.floor(diff / 60);
        const seconds = Math.floor(diff % 60);
        
        const h = document.getElementById('timer-hours');
        const m = document.getElementById('timer-minutes');
        const s = document.getElementById('timer-seconds');
        
        if (h) h.textContent = String(hours).padStart(2, '0');
        if (m) m.textContent = String(minutes).padStart(2, '0');
        if (s) s.textContent = String(seconds).padStart(2, '0');
    }
    
    updateTimer();
    setInterval(updateTimer, 1000);

    // ── Deal Page Add-to-Cart Buttons ──
    function showNotice(msg, isError) {
        var notice = document.createElement('div');
        notice.className = 'cart-notice' + (isError ? ' cart-notice-error' : '');
        notice.setAttribute('role', 'status');
        notice.textContent = msg;
        document.body.appendChild(notice);
        setTimeout(function () { notice.remove(); }, 3200);
    }

    function updateBadge(count) {
        var badge = document.querySelector('.nc-cart-count');
        if (badge) {
            badge.textContent = count;
            badge.style.display = count > 0 ? '' : 'none';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.deal-card-btn').forEach(function (btn) {
            btn.addEventListener('click', async function (e) {
                e.preventDefault();
                e.stopPropagation();
                if (btn.disabled) return;

                var productId = btn.dataset.productId;
                if (!productId) return;

                var original = btn.innerHTML;
                btn.disabled = true;
                btn.textContent = 'Adding…';

                try {
                    var res = await fetch('/cart/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify({ productId: productId, quantity: 1 })
                    });
                    var data = await res.json();
                    if (!res.ok || !data.success) throw new Error(data.error || 'Could not add to cart.');

                    // Update global state
                    if (window.CART_ITEMS) {
                        var existing = window.CART_ITEMS.find(function (i) { return i.productId === productId; });
                        if (existing) existing.quantity += 1;
                        else window.CART_ITEMS.push({ productId: productId, quantity: 1 });
                    }
                    updateBadge(data.cartCount);
                    showNotice(data.message || 'Added to cart!');

                    // Swap to "Added ✓"
                    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" style="display:inline-block;height:1em;width:auto;vertical-align:-0.125em;fill:currentColor;overflow:visible;"><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg> Added';
                    btn.style.background = 'rgba(16,185,129,0.15)';
                    btn.style.borderColor = '#10b981';
                    btn.style.color = '#10b981';
                    btn.disabled = true;
                } catch (err) {
                    showNotice(err.message || 'Could not add to cart.', true);
                    btn.disabled = false;
                    btn.innerHTML = original;
                    if (window.ncReplaceIcons) window.ncReplaceIcons();
                }
            });
        });

        // ════════════════════════════════════════════════
        // ── DYNAMIC DEALS FILTER ENGINE ──────────────────
        // ════════════════════════════════════════════════

        const pills = document.querySelectorAll('.deals-cat-pill');
        const filterBar      = document.getElementById('deals-filter-bar');
        const filterLabel    = document.getElementById('deals-filter-label');
        const filterCount    = document.getElementById('deals-filter-count');
        const filterResults  = document.getElementById('deals-filter-results');
        const filterGrid     = document.getElementById('deals-filter-grid');
        const loadingEl      = document.getElementById('deals-loading');
        const emptyEl        = document.getElementById('deals-empty-state');
        const clearBtn       = document.getElementById('deals-clear-filters');
        const emptyClearBtn  = document.getElementById('deals-empty-clear');

        // The static EJS sections (flash + more deals)
        const staticSections = document.querySelectorAll('.deals-section');

        var currentCategory = '<%= activeCategory %>';
        var currentDiscount = parseInt('<%= activeDiscount %>') || 0;

        // ── Build a single product card HTML string ──────
        function buildCard(p) {
            const disc   = p._syntheticDiscount || 0;
            const orig   = p._originalPrice  || (p.price * 1.4).toFixed(2);
            const catName= (p.category && p.category.name) ? p.category.name : 'General';
            const img    = p.image || '/images/favicon.png';
            return `
            <div class="deal-card" data-category="${catName}">
                <a href="/product/${p._id}" class="deal-card-link">
                    <div class="deal-card-image">
                        <img src="${img}" alt="${p.title}" loading="lazy" decoding="async" onerror="this.parentElement.classList.add('image-load-failed');">
                        <span class="deal-card-discount"><i class="fa-solid fa-arrow-down"></i> ${disc}% OFF</span>
                    </div>
                    <div class="deal-card-body">
                        <span class="deal-card-category">${catName}</span>
                        <h3 class="deal-card-title">${p.title}</h3>
                        <div class="deal-card-price-row">
                            <span class="deal-card-price">$${parseFloat(p.price).toFixed(2)}</span>
                            <span class="deal-card-original">$${parseFloat(orig).toFixed(2)}</span>
                            <span class="deal-card-save">Save ${disc}%</span>
                        </div>
                    </div>
                </a>
                <div style="padding: 0 14px 14px;">
                    <button class="deal-card-btn" type="button" data-add-to-cart data-product-id="${p._id}">
                        <i class="fa-solid fa-cart-plus"></i> Add to Cart
                    </button>
                </div>
            </div>`;
        }

        // ── Wire add-to-cart for dynamic cards ──────────
        function wireCartButtons(container) {
            container.querySelectorAll('.deal-card-btn').forEach(function(btn) {
                btn.addEventListener('click', async function(e) {
                    e.preventDefault(); e.stopPropagation();
                    if (btn.disabled) return;
                    var productId = btn.dataset.productId;
                    if (!productId) return;
                    var original = btn.innerHTML;
                    btn.disabled = true; btn.textContent = 'Adding…';
                    try {
                        var r = await fetch('/cart/add', { method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, credentials:'same-origin', body: JSON.stringify({productId, quantity:1}) });
                        var d = await r.json();
                        if (!r.ok || !d.success) throw new Error(d.error || 'Could not add to cart.');
                        updateBadge(d.cartCount);
                        showNotice(d.message || 'Added to cart!');
                        btn.innerHTML = '<i class="fa-solid fa-check"></i> Added';
                        btn.style.background = 'rgba(16,185,129,0.15)'; btn.style.borderColor = '#10b981'; btn.style.color = '#10b981';
                        btn.disabled = true;
                    } catch(err) {
                        showNotice(err.message || 'Could not add to cart.', true);
                        btn.disabled = false; btn.innerHTML = original;
                    }
                });
            });
        }

        // ── Show / hide sections ─────────────────────────
        function showStatic() {
            staticSections.forEach(s => s.style.display = '');
            filterResults.style.display = 'none';
            loadingEl.style.display = 'none';
            emptyEl.style.display = 'none';
            filterBar.style.display = 'none';
        }

        function showLoading() {
            staticSections.forEach(s => s.style.display = 'none');
            filterResults.style.display = 'none';
            emptyEl.style.display = 'none';
            loadingEl.style.display = 'block';
        }

        function showFilteredResults(products, category, discount) {
            loadingEl.style.display = 'none';
            emptyEl.style.display = 'none';
            staticSections.forEach(s => s.style.display = 'none');

            if (products.length === 0) {
                filterResults.style.display = 'none';
                emptyEl.style.display = 'block';
            } else {
                filterGrid.innerHTML = products.map(buildCard).join('');
                wireCartButtons(filterGrid);
                filterResults.style.display = 'block';
            }

            // Status bar
            const catLabel = category === 'all' ? 'All Categories' : category;
            const discLabel = discount > 0 ? ` — ≥${discount}% off` : '';
            filterLabel.textContent = '🔎 Showing ' + catLabel + ' Deals' + discLabel;
            filterCount.textContent = '(' + products.length + ' result' + (products.length !== 1 ? 's' : '') + ')';
            filterBar.style.display = 'flex';
        }

        // ── Core fetch filter function ───────────────────
        async function applyFilter(category, discount, pushState) {
            currentCategory = category;
            currentDiscount = discount;

            // Sync pills
            pills.forEach(p => {
                p.classList.toggle('active', p.getAttribute('data-filter') === category);
            });

            // Update URL
            if (pushState) {
                const params = new URLSearchParams();
                if (category !== 'all') params.set('category', category);
                if (discount > 0)       params.set('discount', discount);
                const qs = params.toString();
                history.pushState({ category, discount }, '', '/deals' + (qs ? '?' + qs : ''));
            }

            if (category === 'all' && discount === 0) {
                showStatic();
                return;
            }

            showLoading();
            try {
                const resp = await fetch(`/api/deals/filter?category=${encodeURIComponent(category)}&discount=${discount}`, { credentials: 'same-origin' });
                const data = await resp.json();
                if (!data.success) throw new Error(data.error || 'Filter failed.');
                showFilteredResults(data.products, category, discount);
            } catch (err) {
                loadingEl.style.display = 'none';
                showNotice('Filter failed. Please try again.', true);
                showStatic();
            }
        }

        // ── Category Pills ───────────────────────────────
        pills.forEach(pill => {
            pill.addEventListener('click', () => {
                const filter = pill.getAttribute('data-filter');
                const dropdown = document.getElementById('da-category');
                if (dropdown) dropdown.value = filter;
                applyFilter(filter, currentDiscount, true);
            });
        });

        // ── Clear Filters ────────────────────────────────
        function clearFilters() {
            currentCategory = 'all';
            currentDiscount = 0;
            const dropdown = document.getElementById('da-category');
            if (dropdown) dropdown.value = 'all';
            const discountSel = document.getElementById('da-discount');
            if (discountSel) discountSel.value = '0';
            applyFilter('all', 0, true);
        }
        if (clearBtn) clearBtn.addEventListener('click', clearFilters);
        if (emptyClearBtn) emptyClearBtn.addEventListener('click', clearFilters);

        // ── On page load: restore from URL ──────────────
        (function restoreFromUrl() {
            const params = new URLSearchParams(window.location.search);
            const cat  = params.get('category') || 'all';
            const disc = parseInt(params.get('discount'), 10) || 0;
            if (cat !== 'all' || disc > 0) {
                applyFilter(cat, disc, false);
            }
        })();

        // Handle browser back/forward
        window.addEventListener('popstate', function(e) {
            const state = e.state || {};
            applyFilter(state.category || 'all', state.discount || 0, false);
        });

        // ── Deal Alerts Modal Interactivity ──
        var alertsBtn = document.getElementById('deal-alerts-btn');
        var alertsModal = document.getElementById('deal-alerts-modal');
        if (alertsBtn && alertsModal) {
            var overlay = alertsModal.querySelector('.da-modal-overlay');
            var closeBtn = alertsModal.querySelector('.da-modal-close');
            var form = document.getElementById('da-alerts-form');
            var categorySelect = document.getElementById('da-category');

            function openModal() {
                alertsModal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }

            function closeModal() {
                alertsModal.style.display = 'none';
                document.body.style.overflow = '';
            }

            alertsBtn.addEventListener('click', openModal);
            overlay.addEventListener('click', closeModal);
            closeBtn.addEventListener('click', closeModal);

            // Live preview: modal category dropdown → filter page behind modal
            if (categorySelect) {
                categorySelect.addEventListener('change', function () {
                    const discountSel = document.getElementById('da-discount');
                    const disc = discountSel ? parseInt(discountSel.value, 10) : 0;
                    applyFilter(this.value, disc, false);
                });
            }
            const discountSel = document.getElementById('da-discount');
            if (discountSel) {
                discountSel.addEventListener('change', function() {
                    const catVal = categorySelect ? categorySelect.value : 'all';
                    applyFilter(catVal, parseInt(this.value, 10) || 0, false);
                });
            }

            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                var category = document.getElementById('da-category').value;
                var discount = document.getElementById('da-discount').value;
                
                var submitBtn = form.querySelector('.da-submit-btn');
                var originalBtnHtml = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner" style="margin-right:8px; border-width: 2px;"></span> Activating...';

                try {
                    var resp = await fetch('/api/deals/alerts', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify({ category: category, minDiscount: discount })
                    });
                    var data = await resp.json();
                    if (!resp.ok || !data.success) throw new Error(data.error || 'Failed to activate deal alerts.');

                    showNotice(data.message || 'Deal alerts activated successfully!');
                    closeModal();
                    // After saving the alert, apply the matching filter to the page
                    applyFilter(category, parseInt(discount, 10) || 0, true);
                } catch (err) {
                    console.error('Error activating deal alert:', err);
                    showNotice(err.message || 'Failed to activate deal alert. Please try again.', true);
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnHtml;
                }
            });
        }
    });
})();
</script>

<% if (locals.user) { %>
<!-- Deal Alerts Modal -->
<div id="deal-alerts-modal" class="da-modal" style="display: none;">
    <div class="da-modal-overlay"></div>
    <div class="da-modal-content">
        <button type="button" class="da-modal-close" aria-label="Close modal">&times;</button>
        <div class="da-modal-header">
            <div class="da-modal-icon">
                <i class="fa-solid fa-bell"></i>
            </div>
            <h2>Get Deal Alerts</h2>
            <p>We'll notify you the instant prices drop on your favorite items.</p>
        </div>
        <form id="da-alerts-form">
            <div class="da-form-group">
                <label for="da-email">Email Address</label>
                <input type="email" id="da-email" value="<%= locals.user.email %>" required readonly>
                <small class="da-form-help">Alerts will be sent to your account email.</small>
            </div>
            <div class="da-form-group">
                <label for="da-category">Alert Category</label>
                <select id="da-category" required>
                    <option value="all">🔥 All Categories</option>
                    <% if (typeof dealCategories !== 'undefined' && dealCategories) { %>
                        <% dealCategories.forEach(cat => { %>
                            <option value="<%= cat.name %>"><%= cat.name %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
            <div class="da-form-group">
                <label for="da-discount">Discount Threshold</label>
                <select id="da-discount" required>
                    <option value="10">10% Off or more</option>
                    <option value="25">25% Off or more</option>
                    <option value="50">50% Off or more</option>
                </select>
            </div>
            <button type="submit" class="da-submit-btn">
                <i class="fa-solid fa-bell"></i> Activate Alerts
            </button>
        </form>
    </div>
</div>

