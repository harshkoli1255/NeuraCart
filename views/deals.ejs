<div class="deals-page">

    <!-- ======== DEALS HERO ======== -->
    <section class="deals-hero">
        <div class="deals-hero-badge">
            <i class="fa-solid fa-bolt"></i> Limited Time Offers
        </div>
        <h1>Today's <span>Hottest Deals</span></h1>
        <p>Handpicked discounts updated daily. Score massive savings on top-rated products before stock runs out.</p>

        <!-- Countdown Timer -->
        <div class="deals-countdown-row">
            <span class="deals-countdown-label">Deals end in</span>
            <div class="deals-timer" id="deals-timer">
                <div class="deals-timer-block">
                    <span class="deals-timer-num" id="timer-hours">08</span>
                    <span class="deals-timer-label">Hours</span>
                </div>
                <span class="deals-timer-sep">:</span>
                <div class="deals-timer-block">
                    <span class="deals-timer-num" id="timer-minutes">42</span>
                    <span class="deals-timer-label">Min</span>
                </div>
                <span class="deals-timer-sep">:</span>
                <div class="deals-timer-block">
                    <span class="deals-timer-num" id="timer-seconds">15</span>
                    <span class="deals-timer-label">Sec</span>
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="deals-stats">
            <div class="deals-stat">
                <i class="fa-solid fa-fire" style="color: #ff4757;"></i>
                <span class="stat-num"><%= totalDeals %></span> Active Deals
            </div>
            <div class="deals-stat">
                <i class="fa-solid fa-arrow-trend-down" style="color: #10b981;"></i>
                Up to <span class="stat-num">60%</span> Off
            </div>
            <div class="deals-stat">
                <i class="fa-solid fa-truck-fast" style="color: var(--cyan);"></i>
                Free Delivery
            </div>
            <div class="deals-stat">
                <i class="fa-solid fa-shield-check" style="color: var(--purple-lt);"></i>
                Buyer Protection
            </div>
        </div>
    </section>

    <div class="deals-container">

        <% if (featuredDeal) { %>
        <!-- ======== DEAL OF THE DAY ======== -->
        <div class="deals-section">
            <div class="deals-section-header">
                <div class="deals-section-title">
                    <div class="deals-section-icon" style="background: rgba(255,71,87,0.12); color: #ff4757;">
                        <i class="fa-solid fa-crown"></i>
                    </div>
                    <div>
                        <h2>Deal of the Day</h2>
                        <span class="deals-section-subtitle">Our biggest discount right now</span>
                    </div>
                </div>
            </div>

            <a href="/product/<%= featuredDeal._id %>" class="deal-featured">
                <div class="deal-featured-image">
                    <img src="<%= featuredDeal.image %>" alt="<%= featuredDeal.title %>" loading="lazy" onerror="this.parentElement.classList.add('image-load-failed');">
                </div>
                <div class="deal-featured-body">
                    <span class="deal-featured-badge">
                        <i class="fa-solid fa-fire"></i> Deal of the Day
                    </span>
                    <span class="deal-card-category"><%= featuredDeal.category ? featuredDeal.category.name : 'Featured' %></span>
                    <h3 class="deal-featured-title"><%= featuredDeal.title %></h3>
                    <p class="deal-featured-desc"><%= featuredDeal.description ? featuredDeal.description.substring(0, 150) + '...' : '' %></p>
                    <div class="deal-featured-prices">
                        <span class="deal-featured-price-current">$<%= featuredDeal.price.toFixed(2) %></span>
                        <span class="deal-featured-price-original">$<%= (featuredDeal.price * 1.6).toFixed(2) %></span>
                        <span class="deal-featured-savings"><i class="fa-solid fa-arrow-down"></i> Save 38%</span>
                    </div>
                    <span class="deal-featured-cta">
                        <i class="fa-solid fa-cart-plus"></i> Grab This Deal
                    </span>
                </div>
            </a>
        </div>
        <% } %>

        <% if (flashDeals && flashDeals.length > 0) { %>
        <!-- ======== FLASH DEALS ======== -->
        <div class="deals-section">
            <div class="deals-section-header">
                <div class="deals-section-title">
                    <div class="deals-section-icon" style="background: rgba(255,165,2,0.12); color: #ffa502;">
                        <i class="fa-solid fa-bolt"></i>
                    </div>
                    <div>
                        <h2>Flash Deals</h2>
                        <span class="deals-section-subtitle">Lowest prices — selling fast!</span>
                    </div>
                </div>
                <a href="/shop" class="deals-view-all">
                    View all <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>

            <div class="deals-grid">
                <% flashDeals.forEach((product, index) => { %>
                    <%
                        const discountPercents = [55, 42, 38, 30, 48, 35, 25, 60];
                        const discount = discountPercents[index % discountPercents.length];
                        const originalPrice = (product.price / (1 - discount / 100)).toFixed(2);
                        const claimed = Math.floor(Math.random() * 40) + 55;
                    %>
                    <div class="deal-card">
                        <a href="/product/<%= product._id %>" class="deal-card-link">
                            <div class="deal-card-image">
                                <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" onerror="this.parentElement.classList.add('image-load-failed');">
                                <span class="deal-card-discount">
                                    <i class="fa-solid fa-arrow-down"></i> <%= discount %>% OFF
                                </span>
                                <span class="deal-card-timer">
                                    <i class="fa-regular fa-clock"></i> <%= Math.floor(Math.random() * 8) + 1 %>h left
                                </span>
                            </div>
                            <div class="deal-card-body">
                                <span class="deal-card-category"><%= product.category ? product.category.name : 'General' %></span>
                                <h3 class="deal-card-title"><%= product.title %></h3>
                                <div class="deal-card-price-row">
                                    <span class="deal-card-price">$<%= product.price.toFixed(2) %></span>
                                    <span class="deal-card-original">$<%= originalPrice %></span>
                                    <span class="deal-card-save">Save <%= discount %>%</span>
                                </div>
                                <div class="deal-card-progress">
                                    <div class="deal-card-progress-bar">
                                        <div class="deal-card-progress-fill" style="width: <%= claimed %>%;"></div>
                                    </div>
                                    <span class="deal-card-progress-text"><%= claimed %>% claimed</span>
                                </div>
                            </div>
                        </a>
                        <div style="padding: 0 14px 14px;">
                            <button class="deal-card-btn" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                                <i class="fa-solid fa-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- ======== PROMO BANNER ======== -->
        <div class="deal-promo-banner">
            <div class="deal-promo-content">
                <h3><i class="fa-solid fa-bell" style="color: #ffa502; margin-right: 8px;"></i>Never Miss a Deal</h3>
                <p>Sign up for price drop alerts and get notified when your favorite products go on sale.</p>
            </div>
            <a href="/auth/register" class="deal-promo-cta">
                <i class="fa-solid fa-bell"></i> Get Deal Alerts
            </a>
        </div>

        <% if (moreDeals && moreDeals.length > 0) { %>
        <!-- ======== MORE DEALS ======== -->
        <div class="deals-section">
            <div class="deals-section-header">
                <div class="deals-section-title">
                    <div class="deals-section-icon" style="background: rgba(139,92,246,0.12); color: var(--purple-lt);">
                        <i class="fa-solid fa-percent"></i>
                    </div>
                    <div>
                        <h2>More Great Deals</h2>
                        <span class="deals-section-subtitle">Even more savings across all categories</span>
                    </div>
                </div>
            </div>

            <% if (dealCategories && dealCategories.length > 1) { %>
            <div class="deals-category-strip" id="deals-cat-strip">
                <button type="button" class="deals-cat-pill active" data-filter="all">🔥 All Deals</button>
                <% dealCategories.forEach(cat => { %>
                    <button type="button" class="deals-cat-pill" data-filter="<%= cat.name %>"><%= cat.icon || '📁' %> <%= cat.name %></button>
                <% }) %>
            </div>
            <% } %>

            <div class="deals-grid" id="more-deals-grid">
                <% moreDeals.forEach((product, index) => { %>
                    <%
                        const moreDiscounts = [20, 33, 28, 45, 22, 40, 15, 50, 35, 18];
                        const disc = moreDiscounts[index % moreDiscounts.length];
                        const origPrice = (product.price / (1 - disc / 100)).toFixed(2);
                    %>
                    <div class="deal-card" data-category="<%= product.category ? product.category.name : 'General' %>">
                        <a href="/product/<%= product._id %>" class="deal-card-link">
                            <div class="deal-card-image">
                                <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" onerror="this.parentElement.classList.add('image-load-failed');">
                                <span class="deal-card-discount">
                                    <i class="fa-solid fa-arrow-down"></i> <%= disc %>% OFF
                                </span>
                            </div>
                            <div class="deal-card-body">
                                <span class="deal-card-category"><%= product.category ? product.category.name : 'General' %></span>
                                <h3 class="deal-card-title"><%= product.title %></h3>
                                <div class="deal-card-price-row">
                                    <span class="deal-card-price">$<%= product.price.toFixed(2) %></span>
                                    <span class="deal-card-original">$<%= origPrice %></span>
                                    <span class="deal-card-save">Save <%= disc %>%</span>
                                </div>
                            </div>
                        </a>
                        <div style="padding: 0 14px 14px;">
                            <button class="deal-card-btn" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                                <i class="fa-solid fa-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <% if (totalDeals === 0) { %>
        <!-- Empty State -->
        <div class="cart-empty" style="margin-top: 60px;">
            <div class="cart-empty-icon">
                <i class="fa-regular fa-face-frown-open"></i>
            </div>
            <h1>No deals right now</h1>
            <p>Check back later for massive discounts on your favorite products!</p>
            <a href="/shop" class="cart-empty-cta" style="display: inline-flex; gap: 8px; text-decoration: none; margin-top: 8px;">Explore Shop</a>
        </div>
        <% } %>

    </div>
</div>

<!-- Countdown Timer + Deal Buttons Script -->
<script>
(function() {
    // ── Countdown Timer ──
    function getEndTime() {
        const now = new Date();
        const end = new Date(now);
        end.setHours(23, 59, 59, 999);
        return end;
    }
    
    const endTime = getEndTime();
    
    function updateTimer() {
        const now = new Date();
        let diff = Math.max(0, endTime - now) / 1000;
        
        const hours = Math.floor(diff / 3600);
        diff %= 3600;
        const minutes = Math.floor(diff / 60);
        const seconds = Math.floor(diff % 60);
        
        const h = document.getElementById('timer-hours');
        const m = document.getElementById('timer-minutes');
        const s = document.getElementById('timer-seconds');
        
        if (h) h.textContent = String(hours).padStart(2, '0');
        if (m) m.textContent = String(minutes).padStart(2, '0');
        if (s) s.textContent = String(seconds).padStart(2, '0');
    }
    
    updateTimer();
    setInterval(updateTimer, 1000);

    // ── Deal Page Add-to-Cart Buttons ──
    function showNotice(msg, isError) {
        var notice = document.createElement('div');
        notice.className = 'cart-notice' + (isError ? ' cart-notice-error' : '');
        notice.setAttribute('role', 'status');
        notice.textContent = msg;
        document.body.appendChild(notice);
        setTimeout(function () { notice.remove(); }, 3200);
    }

    function updateBadge(count) {
        var badge = document.querySelector('.nc-cart-count');
        if (badge) {
            badge.textContent = count;
            badge.style.display = count > 0 ? '' : 'none';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.deal-card-btn').forEach(function (btn) {
            btn.addEventListener('click', async function (e) {
                e.preventDefault();
                e.stopPropagation();
                if (btn.disabled) return;

                var productId = btn.dataset.productId;
                if (!productId) return;

                var original = btn.innerHTML;
                btn.disabled = true;
                btn.textContent = 'Adding…';

                try {
                    var res = await fetch('/cart/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify({ productId: productId, quantity: 1 })
                    });
                    var data = await res.json();
                    if (!res.ok || !data.success) throw new Error(data.error || 'Could not add to cart.');

                    // Update global state
                    if (window.CART_ITEMS) {
                        var existing = window.CART_ITEMS.find(function (i) { return i.productId === productId; });
                        if (existing) existing.quantity += 1;
                        else window.CART_ITEMS.push({ productId: productId, quantity: 1 });
                    }
                    updateBadge(data.cartCount);
                    showNotice(data.message || 'Added to cart!');

                    // Swap to "Added ✓"
                    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" style="display:inline-block;height:1em;width:auto;vertical-align:-0.125em;fill:currentColor;overflow:visible;"><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg> Added';
                    btn.style.background = 'rgba(16,185,129,0.15)';
                    btn.style.borderColor = '#10b981';
                    btn.style.color = '#10b981';
                    btn.disabled = true;
                } catch (err) {
                    showNotice(err.message || 'Could not add to cart.', true);
                    btn.disabled = false;
                    btn.innerHTML = original;
                    if (window.ncReplaceIcons) window.ncReplaceIcons();
                }
            });
        });
    });
})();
</script>
