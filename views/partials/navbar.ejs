<!-- ============================== NAVBAR ============================== -->
<nav class="nc-nav" id="navbar" role="navigation" aria-label="Main navigation">
    <div class="nc-inner">

        <!-- LEFT: Logo -->
        <a href="/" class="nc-logo" aria-label="NeuraCart home">
            <!-- Neural cart SVG icon in white rounded square -->
            <div class="nc-logo-icon">
                <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Neural connections -->
                    <line x1="8" y1="8" x2="12" y2="5" stroke="#a78bfa" stroke-width="1.2"/>
                    <line x1="8" y1="8" x2="6" y2="12" stroke="#a78bfa" stroke-width="1.2"/>
                    <line x1="12" y1="5" x2="14" y2="10" stroke="#a78bfa" stroke-width="1.2"/>
                    <line x1="6" y1="12" x2="11" y2="14" stroke="#a78bfa" stroke-width="1.2"/>
                    <line x1="14" y1="10" x2="11" y2="14" stroke="#a78bfa" stroke-width="1.2"/>
                    <line x1="11" y1="14" x2="14" y2="15" stroke="#22d3ee" stroke-width="1.2"/>

                    <!-- Neural nodes -->
                    <circle cx="8" cy="8" r="2" fill="#8b5cf6"/>
                    <circle cx="12" cy="5" r="2" fill="#8b5cf6"/>
                    <circle cx="6" cy="12" r="2" fill="#8b5cf6"/>
                    <circle cx="14" cy="10" r="2" fill="#8b5cf6"/>
                    <circle cx="11" cy="14" r="2" fill="#8b5cf6"/>

                    <!-- Stylized Cart Basket -->
                    <path d="M12 16 L14 10 L18 16 L21 8" stroke="#22d3ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    
                    <!-- Cart Base & Wheels -->
                    <path d="M10 17 L18 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="12" cy="20" r="2" fill="currentColor"/>
                    <circle cx="18" cy="20" r="2" fill="currentColor"/>
                </svg>
            </div>
            <span class="nc-logo-wordmark">NeuraCart</span>
        </a>

        <!-- CENTER: Search + Nav Links -->
        <div class="nc-center">
            <form action="/shop" method="GET" class="nc-search-form" role="search">
                <div class="nc-search-box">
                    <i class="fa-solid fa-magnifying-glass nc-search-icon"></i>
                    <input
                        type="text"
                        name="q"
                        class="nc-search-input"
                        placeholder="Search products..."
                        autocomplete="off"
                        aria-label="Search products"
                        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                    >
                    <button type="submit" class="nc-search-btn" aria-label="Search">
                        <i class="fa-solid fa-chevron-right" style="-webkit-text-stroke: 1px currentColor;"></i>
                    </button>
                </div>
            </form>

            <!-- Vertical Divider -->
            <div class="nc-nav-divider"></div>

            <nav class="nc-links" aria-label="Site links">
                <a href="/shop"    class="nc-link <%= locals.path === '/shop' ? 'active' : '' %>">Shop</a>
                <% if (!locals.isSeller) { %>
                <a href="/deals"   class="nc-link <%= locals.path === '/deals' ? 'active' : '' %>">Deals</a>
                <a href="/ai-picks" class="nc-link <%= locals.path === '/ai-picks' ? 'active' : '' %>">AI Picks</a>
                <% } %>
            </nav>
        </div>

        <!-- RIGHT: Cart, Dark Mode, Auth -->
        <div class="nc-right">

            <!-- Dark Mode Toggle -->
            <button class="nc-dark-toggle" aria-label="Toggle dark mode">
                <i class="fa-solid fa-moon"></i>
            </button>

            <!-- Cart -->
            <% if (!locals.isSeller) { %>
            <a href="/cart" class="nc-cart" aria-label="Shopping cart">
                <i class="fa-solid fa-cart-shopping"></i>
                <span class="nc-cart-badge"><%= locals.cartCount || 0 %></span>
            </a>
            <% } %>

            <!-- Auth -->
            <% if (locals.user) { %>
                <% if (locals.isSeller) { %>
                    <a href="/seller/dashboard" class="nc-link" style="color: var(--cyan); font-weight: 500; margin-right: 12px;">Seller Dashboard</a>
                <% } %>
                <a href="/auth/profile" class="nc-login" aria-label="Your account">
                    <%= locals.user.name ? locals.user.name.split(' ')[0] : 'Account' %>
                </a>
                <a href="/auth/logout" class="nc-cta" id="nc-cta-btn">
                    Log Out <i class="fa-solid fa-arrow-right"></i>
                </a>
            <% } else { %>
                <a href="/auth/login" class="nc-login" id="nc-login-btn">Log In</a>
                <a href="/auth/register" class="nc-cta" id="nc-cta-btn">
                    Get Started <i class="fa-solid fa-arrow-right"></i>
                </a>
            <% } %>

            <!-- Hamburger (mobile only) -->
            <button
                class="nc-hamburger"
                type="button"
                aria-label="Open navigation menu"
                aria-expanded="false"
                aria-controls="mobile-menu"
            >
                <span class="nc-hbar"></span>
                <span class="nc-hbar"></span>
                <span class="nc-hbar"></span>
            </button>
        </div>
    </div>
</nav>

<!-- ============================== MOBILE DRAWER ============================== -->
<div class="nc-drawer" id="mobile-menu" role="dialog" aria-label="Mobile navigation" aria-hidden="true">

    <!-- Search -->
    <form action="/shop" method="GET" class="nc-drawer-search" role="search">
        <i class="fa-solid fa-magnifying-glass" style="color:var(--text-lo); font-size:14px; flex-shrink:0;"></i>
        <input type="text" name="q" placeholder="Search products..." autocomplete="off" aria-label="Search">
        <button type="submit" aria-label="Search"><i class="fa-solid fa-arrow-right"></i></button>
    </form>

    <a href="/shop" class="nc-drawer-link">
        <span class="nc-drawer-icon"><i class="fa-solid fa-shop"></i></span> Shop
    </a>
    <% if (!locals.isSeller) { %>
    <a href="/deals" class="nc-drawer-link">
        <span class="nc-drawer-icon"><i class="fa-solid fa-tags"></i></span> Deals
    </a>
    <a href="/ai-picks" class="nc-drawer-link">
        <span class="nc-drawer-icon"><i class="fa-solid fa-wand-magic-sparkles" style="color: var(--cyan)"></i></span> AI Picks
    </a>

    <hr class="nc-drawer-sep">

    <div style="display:flex; gap: 8px; margin: 4px 0;">
        <a href="/cart" class="nc-drawer-link" style="flex:1;">
            <span class="nc-drawer-icon"><i class="fa-solid fa-cart-shopping"></i></span> Cart
            <% if (locals.cartCount && locals.cartCount > 0) { %>
                <span style="margin-left:auto;background:var(--grad-purple);color:#fff;font-size:11px;font-weight:700;padding:2px 9px;border-radius:100px;"><%= locals.cartCount %></span>
            <% } %>
        </a>
    <% } %>
        
        <button class="nc-dark-toggle" style="width: auto; padding: 0 16px; flex-shrink: 0; background: var(--surface-2);" aria-label="Toggle dark mode">
            <i class="fa-solid fa-moon"></i>
        </button>
    </div>

    <hr class="nc-drawer-sep">

    <% if (locals.user) { %>
        <% if (locals.isSeller) { %>
            <a href="/seller/dashboard" class="nc-drawer-link" style="color: var(--cyan); font-weight: 500;">
                <span class="nc-drawer-icon"><i class="fa-solid fa-gauge-high"></i></span> Seller Dashboard
            </a>
        <% } %>
        <a href="/auth/profile" class="nc-drawer-link">
            <span class="nc-drawer-icon"><i class="fa-solid fa-user"></i></span>
            Hi, <%= locals.user.name ? locals.user.name.split(' ')[0] : 'Account' %>
        </a>
        <a href="/auth/logout" class="nc-drawer-link">
            <span class="nc-drawer-icon"><i class="fa-solid fa-right-from-bracket"></i></span> Log Out
        </a>
    <% } else { %>
        <div class="nc-drawer-auth">
            <a href="/auth/login" class="nc-drawer-login">Log In</a>
            <a href="/auth/register" class="nc-drawer-signup">Get Started</a>
        </div>
    <% } %>
</div>
