<!DOCTYPE html>
<html lang="en" data-theme="<%= locals.theme %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="NeuraCart — AI-powered e-commerce. Find any product in seconds using natural language.">

    <title><%= title %></title>

    <!-- Read the cookie before styles paint. This also protects the preference
         during a navigation if an intermediary served a stale HTML response. -->
    <script>
        (function () {
            var themes = document.cookie.split(';').map(function (part) {
                return part.trim().split('=');
            }).filter(function (pair) {
                return pair[0] === 'theme' && (pair[1] === 'dark' || pair[1] === 'light');
            });
            var theme = themes.length ? themes[themes.length - 1][1] : null;

            if (!theme && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                theme = 'dark';
            }

            document.documentElement.setAttribute('data-theme', theme || 'light');
        }());
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Design Tokens -->
    <link rel="stylesheet" href="/css/tokens.css?v=1.1">

    <!-- Site Styles -->
    <link rel="stylesheet" href="/css/style.css?v=7.1">
    <link rel="icon" type="image/png" href="/images/favicon.png">

    <!-- SVG Icon System — zero CDN, zero CSP issues -->
    <script src="/js/icons.js"></script>
</head>
<body>

    <%- include('../partials/navbar') %>

    <%- body %>

    <script src="/js/axios.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/theme.js"></script>

</body>
</html>
