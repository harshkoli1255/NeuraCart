<div class="container" style="padding-top: 40px; padding-bottom: 80px; max-width: 1200px; margin: 0 auto;">
    
    <div class="profile-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px;">
        <div>
            <h1 style="font-size: 32px; font-weight: 700; color: var(--text-hi); margin-bottom: 8px;">Seller Dashboard</h1>
            <p style="color: var(--text-lo); font-size: 16px;">Welcome back, <strong><%= user.name %></strong>! Here's what's happening with your store.</p>
        </div>
        <div>
            <span style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; background: var(--surface-2); border-radius: var(--r-full); border: 1px solid var(--border); font-size: 13px; font-weight: 600; color: var(--text-hi);">
                <i class="fa-solid fa-store" style="color: var(--cyan);"></i> Seller Account
            </span>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 300px 1fr; gap: 32px;">
        <!-- Sidebar -->
        <aside>
            <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 24px; position: sticky; top: calc(var(--navbar-h) + 24px);">
                <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--grad-purple); display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 700; color: #fff; margin-bottom: 16px;">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <h2 style="font-size: 18px; font-weight: 600; color: var(--text-hi); margin-bottom: 4px;"><%= user.name %></h2>
                <p style="color: var(--text-lo); font-size: 14px; margin-bottom: 24px;"><%= user.email %></p>

                <hr style="border: none; border-top: 1px solid var(--border-2); margin-bottom: 24px;">

                <nav style="display: flex; flex-direction: column; gap: 12px;">
                    <a href="/seller/dashboard" style="color: var(--cyan); font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-solid fa-chart-line" style="width: 20px;"></i> Overview</a>
                    <a href="/seller/add-product" style="color: var(--text-lo); font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-solid fa-plus" style="width: 20px;"></i> Add Product</a>
                    <a href="/auth/profile" style="color: var(--text-lo); font-weight: 500; display: flex; align-items: center; gap: 12px; transition: color var(--ease);"><i class="fa-solid fa-user" style="width: 20px;"></i> Profile Settings</a>
                    
                    <a href="/auth/logout" style="color: #ef4444; font-weight: 500; display: flex; align-items: center; gap: 12px; margin-top: 12px; transition: opacity var(--ease);"><i class="fa-solid fa-right-from-bracket" style="width: 20px;"></i> Log Out</a>
                </nav>
            </div>
        </aside>

        <!-- Main Content -->
        <main>
            <!-- Stats -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 32px;">
                <div style="background: var(--surface); padding: 24px; border-radius: var(--r-lg); border: 1px solid var(--border);">
                    <div style="color: var(--text-lo); font-size: 14px; margin-bottom: 8px; font-weight: 500;">Total Sales</div>
                    <div style="color: var(--text-hi); font-size: 32px; font-weight: 700;">₹0.00</div>
                </div>
                <div style="background: var(--surface); padding: 24px; border-radius: var(--r-lg); border: 1px solid var(--border);">
                    <div style="color: var(--text-lo); font-size: 14px; margin-bottom: 8px; font-weight: 500;">Active Products</div>
                    <div style="color: var(--text-hi); font-size: 32px; font-weight: 700;"><%= locals.products ? products.length : 0 %></div>
                </div>
                <div style="background: var(--surface); padding: 24px; border-radius: var(--r-lg); border: 1px solid var(--border);">
                    <div style="color: var(--text-lo); font-size: 14px; margin-bottom: 8px; font-weight: 500;">Pending Orders</div>
                    <div style="color: var(--text-hi); font-size: 32px; font-weight: 700;">0</div>
                </div>
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 style="font-size: 20px; font-weight: 600; color: var(--text-hi);">Your Products</h3>
                <a href="/seller/add-product" class="nc-btn-secondary" style="padding: 8px 16px; font-size: 14px; text-decoration:none;">
                    <i class="fa-solid fa-plus"></i> Add Product
                </a>
            </div>

            <% if (locals.products && products.length > 0) { %>
                <div style="background: var(--surface); border-radius: var(--r-lg); border: 1px solid var(--border); overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02);">
                                <th style="padding: 16px; color: var(--text-lo); font-weight: 500; font-size: 14px;">Product</th>
                                <th style="padding: 16px; color: var(--text-lo); font-weight: 500; font-size: 14px;">Price</th>
                                <th style="padding: 16px; color: var(--text-lo); font-weight: 500; font-size: 14px;">Stock</th>
                                <th style="padding: 16px; color: var(--text-lo); font-weight: 500; font-size: 14px; text-align: right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% products.forEach(product => { %>
                                <tr style="border-bottom: 1px solid var(--border);">
                                    <td style="padding: 16px;">
                                        <div style="display: flex; align-items: center; gap: 16px;">
                                            <img src="<%= product.image %>" alt="<%= product.title %>" style="width: 48px; height: 48px; object-fit: contain; border-radius: 8px; background: #fff;">
                                            <div>
                                                <div style="color: var(--text-hi); font-weight: 500; margin-bottom: 4px;"><%= product.title.substring(0, 50) %><%= product.title.length > 50 ? '...' : '' %></div>
                                                <div style="color: var(--text-lo); font-size: 13px;"><%= product.brand %></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="padding: 16px; color: var(--text-hi);">₹<%= product.price %></td>
                                    <td style="padding: 16px; color: var(--text-lo);"><%= product.stock %> in stock</td>
                                    <td style="padding: 16px; text-align: right;">
                                        <a href="/product/<%= product._id %>" style="color: var(--cyan); margin-right: 12px; text-decoration: none;"><i class="fa-solid fa-eye"></i> View</a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div style="background: var(--surface); padding: 48px 32px; border-radius: var(--r-lg); border: 1px solid var(--border); text-align: center;">
                    <i class="fa-solid fa-box-open" style="font-size: 48px; color: var(--purple-lt); margin-bottom: 16px;"></i>
                    <h3 style="color: var(--text-hi); font-size: 20px; margin-bottom: 8px;">No Products Yet</h3>
                    <p style="color: var(--text-lo); margin-bottom: 24px; max-width: 400px; margin-inline: auto;">Start adding products to your store to begin selling to NeuraCart customers.</p>
                    <a href="/seller/add-product" class="nc-btn-secondary" style="text-decoration:none; display:inline-block;">Add Your First Product</a>
                </div>
            <% } %>
        </main>
    </div>
</div>
