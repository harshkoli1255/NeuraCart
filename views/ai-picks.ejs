<div class="shop-page">
    <!-- Header Section -->
    <div class="shop-header">
        <h1>
            <i class="fa-solid fa-sparkles" style="background: var(--grad-purple); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; margin-right: 12px;"></i>
            AI Picks For You
        </h1>
        <p>A highly personalized selection of products curated by NeuraCart AI, specifically tailored to your unique tastes and previous browsing history.</p>
    </div>

    <% if (products && products.length > 0) { %>
        <div class="ai-picks-grid">
            <% products.forEach(product => { %>
                <div class="product-card" style="cursor: pointer;" onclick="if(!event.target.closest('button')) window.location.href='/product/<%= product._id %>'">
                    <button class="product-wishlist" aria-label="Add to wishlist" data-product-id="<%= product._id %>">
                        <i class="fa-regular fa-heart"></i>
                    </button>
                    
                    <div class="product-link" style="text-decoration: none; color: inherit; display: block;">
                        <div class="product-card-image">
                            <% if (product.image) { %>
                                <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" data-product-image>
                            <% } else { %>
                                <%= product.category?.icon || '📁' %>
                            <% } %>
                            <div class="product-badge">
                                <i class="fa-solid fa-star"></i> 99% Match
                            </div>
                        </div>
                        
                        <div class="product-card-body">
                            <span class="product-category-tag"><%= product.brand || (product.category ? product.category.name : 'General') %></span>
                            <h3 class="product-title"><%= product.title %></h3>
                            <div class="product-meta">
                                <span class="product-price">₹<%= product.price.toFixed(2) %></span>
                            </div>
                            
                            <div class="ai-picks-rationale">
                                <i class="fa-solid fa-microchip"></i>
                                <span>Because you recently searched for similar <%= product.category ? product.category.name.toLowerCase() : 'items' %>.</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="product-card-footer" style="padding: 0 14px 14px 14px;">
                        <button class="btn btn-primary" type="button" data-add-to-cart data-product-id="<%= product._id %>" style="width: 100%;">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <!-- Empty State matching standard Shop Empty layout -->
        <div class="shop-empty">
            <div class="shop-empty-icon">
                <i class="fa-solid fa-robot" style="color: var(--purple-lt);"></i>
            </div>
            <h2>We're learning your preferences</h2>
            <p>Browse more products and use the AI Search to help us build your personalized profile!</p>
            <a href="/shop" class="btn btn-primary" style="margin-top: 16px;">Explore Shop</a>
        </div>
    <% } %>
</div>
