<div class="checkout-success-page" style="min-height: calc(100vh - var(--navbar-h)); display: flex; align-items: center; justify-content: center; padding: 40px 24px; background: var(--bg);">
    <div class="success-card" style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-xl); box-shadow: var(--shadow-lg); padding: 48px; max-width: 560px; width: 100%; text-align: center; animation: success-fade-in 0.4s ease-out;">

        <!-- Success Icon -->
        <div class="success-icon-wrap" style="display: inline-flex; align-items: center; justify-content: center; width: 88px; height: 88px; background: rgba(16, 185, 129, 0.12); color: var(--success); border-radius: 50%; font-size: 40px; margin-bottom: 24px; animation: pop-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.2s both;">
            <i class="fa-solid fa-circle-check"></i>
        </div>

        <h1 style="font-size: 28px; font-weight: 800; color: var(--text-hi); margin-bottom: 10px;">Order Placed Successfully!</h1>

        <% if (locals.orderId) { %>
        <div style="display:inline-flex; align-items:center; gap:8px; padding:8px 16px; background:rgba(139,92,246,0.10); border:1px solid rgba(139,92,246,0.20); border-radius:8px; margin-bottom:16px;">
            <i class="fa-solid fa-hashtag" style="color:var(--purple-lt); font-size:12px;"></i>
            <span style="font-size:13px; color:var(--text-md);">Order ID:</span>
            <span style="font-size:14px; font-weight:800; color:var(--purple-lt); font-family:'Outfit',sans-serif;"><%= locals.orderId.toString().slice(-8).toUpperCase() %></span>
        </div>
        <% } %>

        <p style="font-size: 15px; color: var(--text-md); line-height: 1.7; margin-bottom: 12px;">
            Thank you for shopping with NeuraCart! Your payment has been securely processed and your order has been confirmed.
        </p>

        <!-- Order Info Pills -->
        <div style="display:flex; justify-content:center; gap:12px; flex-wrap:wrap; margin-bottom:32px;">
            <div style="display:flex; align-items:center; gap:6px; padding:6px 14px; background:var(--surface-2); border:1px solid var(--border); border-radius:999px; font-size:12px; color:var(--text-md);">
                <i class="fa-solid fa-truck" style="color:var(--purple-lt);"></i>
                Estimated delivery in 5–7 days
            </div>
            <div style="display:flex; align-items:center; gap:6px; padding:6px 14px; background:var(--surface-2); border:1px solid var(--border); border-radius:999px; font-size:12px; color:var(--text-md);">
                <i class="fa-solid fa-envelope" style="color:var(--cyan);"></i>
                Confirmation email sent
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 12px;">
            <a href="/shop" class="nc-cta" style="text-decoration: none; justify-content: center; height: 48px; font-size: 15px;">
                <i class="fa-solid fa-bag-shopping" style="margin-right: 8px;"></i> Continue Shopping
            </a>
            <a href="/auth/profile/orders" class="nc-cta" style="background: rgba(139, 92, 246, 0.1); border: 1px solid var(--purple-lt); color: var(--purple-lt); text-decoration: none; justify-content: center; height: 48px; font-size: 15px;">
                <i class="fa-solid fa-clock-rotate-left" style="margin-right: 8px;"></i> View My Orders
            </a>
        </div>
    </div>
</div>

<style>
@keyframes success-fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}
@keyframes pop-in {
    from { opacity: 0; transform: scale(0.6); }
    to   { opacity: 1; transform: scale(1); }
}
</style>

