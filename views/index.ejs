<style>
/* Hero grid overlay */
.hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image: 
        linear-gradient(rgba(139,92,246,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(139,92,246,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
}

/* Animate search wrapper on focus */
#heroSearchWrap:focus-within {
    box-shadow: 0 0 0 3px rgba(139,92,246,0.2), 0 20px 60px rgba(139,92,246,0.15);
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

/* AI results panel animate in */
#ai-results-panel {
    animation: fadeUp 0.4s ease;
}

/* Clear button hover */
#ai-clear-search:hover {
    background: var(--surface-3) !important;
    border-color: var(--border-2) !important;
}

/* Hero pill hover improvement */
.hero-pill:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(139,92,246,0.2);
}

/* Product grid for AI results */
#ai-product-grid .product-card {
    animation: fadeUp 0.3s ease both;
}
#ai-product-grid .product-card:nth-child(1) { animation-delay: 0.05s; }
#ai-product-grid .product-card:nth-child(2) { animation-delay: 0.10s; }
#ai-product-grid .product-card:nth-child(3) { animation-delay: 0.15s; }
#ai-product-grid .product-card:nth-child(4) { animation-delay: 0.20s; }
#ai-product-grid .product-card:nth-child(5) { animation-delay: 0.25s; }
#ai-product-grid .product-card:nth-child(6) { animation-delay: 0.30s; }
</style>
