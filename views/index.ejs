<div class="home-page">

    <!-- Background blobs -->
    <div class="blob blob-pink"></div>
    <div class="blob blob-purple"></div>
    <div class="blob blob-blue"></div>

    <!-- ======== NAVBAR ======== -->
    <nav class="navbar" id="navbar">

        <!-- Column 1: Logo -->
        <a href="/" class="nav-logo">
            <img src="/images/favicon.png" alt="NeuraCart logo">
            <span class="nav-logo-name">NeuraCart</span>
            <span class="nav-logo-beta">Beta</span>
        </a>

        <!-- Column 2: Search + Links (hidden on mobile) -->
        <div class="nav-middle">
            <div class="nav-search-wrap">
                <div class="nav-search-icon-sm" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" class="nav-search-input-sm" placeholder="Search products..." aria-label="Search">
                <button class="nav-search-submit" aria-label="Submit search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>
            <div class="nav-sep"></div>
            <div class="nav-links-row">
                <a href="#">Shop</a>
                <a href="#">Deals</a>
                <a href="#">AI Picks</a>
            </div>
        </div>

        <!-- Column 3: Right actions — cart/login/signup hidden on mobile; hamburger always visible -->
        <div class="nav-right">
            <a href="#" class="nav-cart-btn" aria-label="Cart (0 items)">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <span class="cart-count">0</span>
            </a>
            <div class="nav-right-sep"></div>
            <a href="/auth/login" class="nav-login">Log In</a>
            <a href="/auth/register" class="nav-signup">
                Get Started
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
            </a>
            <!-- Hamburger: always inside nav-right but flex-shown only on mobile -->
            <button class="nav-hamburger" id="hamburger-btn" aria-label="Toggle menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <!-- Mobile slide-down drawer -->
    <div class="nav-mobile-menu" id="mobile-menu" role="navigation" aria-label="Mobile navigation">
        <div class="nav-mobile-search">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" placeholder="Search products..." aria-label="Mobile search">
        </div>
        <a href="#"><span>🛍️</span> Shop</a>
        <a href="#"><span>📁</span> Categories</a>
        <a href="#"><span>🔥</span> Deals</a>
        <a href="#"><span>✨</span> AI Picks</a>
        <div class="mobile-divider"></div>
        <div class="mobile-auth-row">
            <a href="/auth/login"    class="mobile-login">Log In</a>
            <a href="/auth/register" class="mobile-signup">Get Started →</a>
        </div>
    </div>

    <!-- ======== HERO ======== -->
    <section class="hero-section">
        <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Powered by Artificial Intelligence
        </div>

        <h1 class="hero-title">
            Shop smarter with<br>
            <span class="highlight">NeuraCart AI</span>
        </h1>

        <p class="hero-subtitle">
            Just describe what you need — in plain English. Our AI finds the perfect match with personalised recommendations and smart comparisons.
        </p>

        <div class="ai-search-container" role="search">
            <div class="ai-search-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                </svg>
            </div>
            <input
                type="text"
                id="hero-search"
                class="ai-search-input"
                placeholder="e.g. 'Noise-cancelling headphones under ₹5,000'"
                aria-label="Ask NeuraCart AI"
                autocomplete="off"
            >
            <button class="ai-search-btn" id="hero-search-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                Ask AI
            </button>
        </div>

        <div class="hero-trust">
            <span class="trust-pill"><span class="trust-icon">⚡</span> Instant results</span>
            <span class="trust-pill"><span class="trust-icon">🔒</span> Safe & secure</span>
            <span class="trust-pill"><span class="trust-icon">🌟</span> 10K+ shoppers</span>
            <span class="trust-pill"><span class="trust-icon">🚚</span> Free delivery</span>
        </div>
    </section>

    <!-- ======== CATEGORIES ======== -->
    <div class="section-wrapper">
        <div class="section-header">
            <h2 class="section-title">Shop by Category</h2>
            <a href="#" class="section-see-all">View all →</a>
        </div>
        <div class="categories-grid">
            <a href="/category/Tech" class="category-card">
                <div class="category-icon">💻</div>
                <div class="category-name">Tech</div>
            </a>
            <a href="/category/Clothing" class="category-card">
                <div class="category-icon">👕</div>
                <div class="category-name">Clothing</div>
            </a>
            <a href="/category/Home" class="category-card">
                <div class="category-icon">🏡</div>
                <div class="category-name">Home</div>
            </a>
            <a href="/category/Shoes" class="category-card">
                <div class="category-icon">👟</div>
                <div class="category-name">Shoes</div>
            </a>
            <a href="/category/Books" class="category-card">
                <div class="category-icon">📚</div>
                <div class="category-name">Books</div>
            </a>
            <a href="/category/Toys" class="category-card">
                <div class="category-icon">🧸</div>
                <div class="category-name">Toys</div>
            </a>
        </div>
    </div>

    <!-- ======== PRODUCTS ======== -->
    <div class="section-wrapper">
        <div class="section-header">
            <h2 class="section-title">✨ AI Top Picks</h2>
            <a href="#" class="section-see-all">See all →</a>
        </div>
        <div class="product-grid" id="product-grid">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <a href="/product/<%= product._id %>" class="product-card" style="text-decoration: none; color: inherit; display: block;">
                        <% if (product.isFeatured) { %>
                            <span class="product-badge">Hot</span>
                        <% } %>
                        <button class="product-wishlist" aria-label="Add to wishlist" onclick="event.preventDefault();">♡</button>
                        <div class="product-image" style="overflow: hidden; display: flex; align-items: center; justify-content: center;">
                            <% if (product.image) { %>
                                <img src="<%= product.image %>" alt="<%= product.name %>" style="width: 100%; height: 100%; object-fit: cover;">
                            <% } else { %>
                                <%= product.category.icon %>
                            <% } %>
                        </div>
                        <div class="product-info">
                            <span class="product-category-tag"><%= product.category.name %></span>
                            <h3 class="product-title"><%= product.title %></h3>
                            <div class="product-meta">
                                <span class="product-price">₹<%= product.price.toFixed(2) %></span>
                                <span class="product-rating">★ <%= product.ratings.average %></span>
                            </div>
                            <button class="btn-add-cart" onclick="event.preventDefault();">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                                Add to Cart
                            </button>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <p>No products found.</p>
            <% } %>
        </div>
    </div>
    <!-- ======== PROMO BANNER ======== -->
    <div class="promo-banner">
        <div class="promo-inner">
            <div class="promo-text">
                <span class="promo-tag">🎉 Limited Time Offer</span>
                <h3 class="promo-title">Get 20% off your<br>first AI-powered order</h3>
                <p class="promo-subtitle">Use code <strong>NEURA20</strong> at checkout · New users only</p>
            </div>
            <a href="/auth/register" class="promo-cta">Claim Offer →</a>
        </div>
    </div>

    <!-- ======== TESTIMONIALS ======== -->
    <div class="testimonial-strip">
        <div class="testimonial-inner">
            <div class="testimonial-card">
                <div class="testimonial-stars">★★★★★</div>
                <p class="testimonial-text">"I just told it 'a birthday gift for my tech-obsessed brother under ₹10,000' and it found the perfect gadget in seconds. Absolutely mind-blowing."</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">👨‍💻</div>
                    <div>
                        <div class="testimonial-name">Rohan M.</div>
                        <div class="testimonial-role">Software Engineer, Bangalore</div>
                    </div>
                </div>
            </div>
            <div class="testimonial-card">
                <div class="testimonial-stars">★★★★★</div>
                <p class="testimonial-text">"The AI picked headphones I'd never heard of and they're genuinely better than what I was going to buy. I trust NeuraCart more than my own research."</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">🎵</div>
                    <div>
                        <div class="testimonial-name">Priya S.</div>
                        <div class="testimonial-role">Music Producer, Mumbai</div>
                    </div>
                </div>
            </div>
            <div class="testimonial-card">
                <div class="testimonial-stars">★★★★★</div>
                <p class="testimonial-text">"It's like having a friend who actually knows products. Fast, accurate, no fluff. I've already recommended it to everyone I know."</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">🌿</div>
                    <div>
                        <div class="testimonial-name">Aisha K.</div>
                        <div class="testimonial-role">Lifestyle Blogger, Delhi</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ======== FOOTER ======== -->
    <footer class="site-footer">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="/" class="nav-logo">
                    <img src="/images/favicon.png" alt="NeuraCart">
                    <span class="nav-logo-name">NeuraCart</span>
                </a>
                <p class="footer-desc">The AI-powered e-commerce platform that finds the right product for you in seconds — so you can shop with confidence.</p>
                <div class="footer-social">
                    <a href="#" aria-label="Twitter">𝕏</a>
                    <a href="#" aria-label="Instagram">📸</a>
                    <a href="#" aria-label="LinkedIn">in</a>
                </div>
            </div>
            <div class="footer-col">
                <h4>Shop</h4>
                <ul>
                    <li><a href="#">New Arrivals</a></li>
                    <li><a href="#">Best Sellers</a></li>
                    <li><a href="#">Today's Deals</a></li>
                    <li><a href="#">AI Picks</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <ul>
                    <li><a href="#">Help Centre</a></li>
                    <li><a href="#">Track Order</a></li>
                    <li><a href="#">Returns</a></li>
                    <li><a href="#">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Company</h4>
                <ul>
                    <li><a href="#">About</a></li>
                    <li><a href="#">Blog</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="footer-copy">© 2025 NeuraCart Inc. All rights reserved.</p>
            <div class="footer-badges">
                <span class="footer-badge">🔒 Secure Checkout</span>
                <span class="footer-badge">⚡ AI-Powered</span>
                <span class="footer-badge">🚚 Free Shipping</span>
            </div>
        </div>
    </footer>

</div>
