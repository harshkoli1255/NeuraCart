<!-- ======== HERO ======== -->
<section class="hero-section">
    <!-- Decorative Orbs -->
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <!-- Grid overlay -->
    <div class="hero-grid-overlay"></div>

    <div class="hero-content">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            Powered by Artificial Intelligence
        </div>

        <h1 class="hero-headline">
            Shop Smarter with<br>
            <span class="highlight">NeuraCart AI</span>
        </h1>

        <p class="hero-subtext">
            Describe what you need in plain English. Our AI reads every product description, image, and review to find your perfect match — instantly.
        </p>

        <!-- Search Wrap -->
        <div class="hero-search-wrap" id="heroSearchWrap">
            <div class="hero-search-icon-ai">
                <i class="fa-solid fa-robot"></i>
            </div>
            <label for="hero-search" class="sr-only">What are you looking for?</label>
            <input
                type="text"
                class="hero-search-input"
                id="hero-search"
                placeholder="e.g. 'Best laptop for video editing under ₹80,000'"
                autocomplete="off"
                aria-label="What are you looking for?"
            >
            <button class="hero-search-btn" id="hero-search-btn">
                Ask AI <i class="fa-solid fa-arrow-right"></i>
            </button>
        </div>

        <!-- Suggestion Pills -->
        <div class="hero-pills">
            <button class="hero-pill" onclick="document.getElementById('hero-search').value = this.innerText.trim(); document.getElementById('hero-search-btn').click();">Gaming laptop under ₹80k</button>
            <button class="hero-pill" onclick="document.getElementById('hero-search').value = this.innerText.trim(); document.getElementById('hero-search-btn').click();">Best wireless earbuds for running</button>
            <button class="hero-pill" onclick="document.getElementById('hero-search').value = this.innerText.trim(); document.getElementById('hero-search-btn').click();">Gift for my girlfriend</button>
            <button class="hero-pill" onclick="document.getElementById('hero-search').value = this.innerText.trim(); document.getElementById('hero-search-btn').click();">Skincare for dry skin</button>
        </div>

        <div class="hero-trust">
            <span class="trust-item"><i class="fa-solid fa-bolt" style="color:var(--warning)"></i> Instant results</span>
            <span class="trust-item"><i class="fa-solid fa-shield" style="color:var(--success)"></i> Safe & secure</span>
            <span class="trust-item"><i class="fa-solid fa-users" style="color:var(--cyan)"></i> 10K+ shoppers</span>
            <span class="trust-item"><i class="fa-solid fa-truck" style="color:var(--purple-lt)"></i> Free delivery</span>
        </div>
    </div>
</section>

<!-- ======== AI SEARCH RESULTS PANEL ======== -->
<div id="ai-results-panel" style="display:none; padding: 0 24px 64px;">
    <!-- AI Explanation Card -->
    <div id="ai-explanation-card" style="max-width:1100px; margin: 0 auto 32px; padding:20px 24px; border-radius:20px; background:linear-gradient(135deg, rgba(139,92,246,0.10) 0%, rgba(34,211,238,0.06) 100%); border:1px solid rgba(139,92,246,0.25); display:flex; align-items:flex-start; gap:16px; box-shadow: 0 4px 24px rgba(139,92,246,0.08);">
        <div style="width:44px; height:44px; flex-shrink:0; background:var(--grad-purple); border-radius:14px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:20px; box-shadow:0 4px 12px rgba(139,92,246,0.3);">
            <i class="fa-solid fa-sparkles"></i>
        </div>
        <div style="flex:1">
            <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--purple-lt); margin-bottom:6px; display:flex; align-items:center; gap:6px;">
                <span>NeuraCart AI</span>
                <span style="width:4px; height:4px; border-radius:50%; background:var(--purple-lt); display:inline-block;"></span>
                <span style="color:var(--text-lo); font-weight:500; text-transform:none; letter-spacing:0">Semantic Vector Search</span>
            </div>
            <p id="ai-explanation-text" style="margin:0; font-size:15px; color:var(--text-hi); line-height:1.5; font-weight:500;"></p>
        </div>
        <button id="ai-clear-search" type="button" style="flex-shrink:0; display:flex;align-items:center;gap:6px;padding:8px 16px;border-radius:100px;border:1px solid var(--border);background:var(--surface-2);color:var(--text-md);cursor:pointer;font-size:12px;font-weight:600; transition: all 0.2s;">
            <i class="fa-solid fa-xmark"></i> Clear
        </button>
    </div>

    <!-- Search Results Header -->
    <div style="max-width:1100px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:8px;">
        <h2 id="ai-results-title" style="font-size:20px; font-weight:800; color:var(--text-hi); margin:0;"></h2>
        <a href="/shop" style="color:var(--purple-lt); font-size:13px; font-weight:600; text-decoration:none;">Browse all <i class="fa-solid fa-arrow-right"></i></a>
    </div>

    <!-- Product Cards Grid -->
    <div id="ai-product-grid" class="product-grid" style="max-width:1100px; margin:0 auto;"></div>

    <!-- Empty State — never shown now, but kept as fallback -->
    <div id="ai-empty-state" style="display:none; max-width:1100px; margin:0 auto; padding:72px 24px; text-align:center;">
        <div style="font-size:64px; margin-bottom:16px; filter: grayscale(0.3);">🛒</div>
        <h3 style="font-size:22px; font-weight:800; color:var(--text-hi); margin-bottom:8px;">No exact matches — but here's what we have!</h3>
        <p style="color:var(--text-lo); font-size:15px; max-width:400px; margin: 0 auto 24px;">Our AI returned the closest alternatives from our catalog. Try refining your search for better results.</p>
        <a href="/shop" class="btn btn-primary">Browse All Products</a>
    </div>
</div>


<div class="section-wrapper">
    <div class="section-header">
        <h2 class="section-title">Shop by Category</h2>
        <a href="/shop" class="section-see-all">View all <i class="fa-solid fa-arrow-right"></i></a>
    </div>
    <div class="categories-grid">
        <% if (locals.globalCategories && globalCategories.length > 0) { %>
            <% globalCategories.forEach(cat => { %>
                <a href="/category/<%= cat.slug %>" class="category-card">
                    <div class="category-icon"><%= cat.icon || '🛍️' %></div>
                    <div class="category-name"><%= cat.name %></div>
                </a>
            <% }); %>
        <% } else { %>
            <p style="color:var(--text-lo); text-align:center; grid-column: 1 / -1; padding: 40px;">No categories found. Please seed the database.</p>
        <% } %>
    </div>
</div>

<!-- AI TOP PICKS -->
<div class="section-wrapper">
    <div class="section-header">
        <h2 class="section-title">✨ <%= locals.isPersonalized ? 'Recommended For You' : 'AI Top Picks' %></h2>
        <a href="/ai-picks" class="section-see-all">View all <i class="fa-solid fa-arrow-right"></i></a>
    </div>
    <div class="product-grid">
        <% if (products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <% if (!product || !product.category) return; %>
                <div class="product-card" onclick="if(!event.target.closest('button')) window.location.href='/product/<%= product._id %>'">
                    <% if (product.isFeatured) { %><span class="product-badge product-badge-ai">AI Pick</span><% } %>
                    <button class="product-wishlist" aria-label="Add to wishlist" data-product-id="<%= product._id %>"><i class="fa-regular fa-heart"></i></button>
                    <div class="product-card-image">
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" data-product-image>
                        <% } else { %>
                            <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:56px">
                                <%= product.category.icon %>
                            </div>
                        <% } %>
                    </div>
                    <div class="product-card-body">
                        <span class="product-category-tag"><%= product.category.name %></span>
                        <h3 class="product-title"><%= product.title %></h3>
                        <div class="product-meta">
                            <span class="product-price">₹<%= product.price.toFixed(2) %></span>
                            <span class="product-rating">
                                <i class="fa-solid fa-star"></i> <%= product.ratings.average %>
                                <span class="product-rating-count">(<%= product.ratings.count %>)</span>
                            </span>
                        </div>
                        <button class="btn-add-cart" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="shop-empty" style="grid-column: 1 / -1;">
                <div class="shop-empty-icon"><i class="fa-solid fa-box-open"></i></div>
                <h2>No Products Found</h2>
                <p>Check back later for exciting new products.</p>
            </div>
        <% } %>
    </div>
</div>

<!-- ======== FEATURES ======== -->
