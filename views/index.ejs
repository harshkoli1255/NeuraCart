<!-- ======== HERO ======== -->
<section class="hero-section">
    <!-- Decorative Orbs -->
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>

    <div class="hero-content">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            Powered by Artificial Intelligence
        </div>

        <h1 class="hero-headline">
            Shop smarter with<br>
            <span class="highlight">NeuraCart AI</span>
        </h1>

        <p class="hero-subtext">
            Just describe what you need — in plain English. Our AI finds the perfect match with personalised recommendations and smart comparisons.
        </p>

        <!-- Search Wrap -->
        <div class="hero-search-wrap">
            <div class="hero-search-icon-ai">
                <i class="fa-solid fa-robot"></i>
            </div>
            <label for="hero-search" class="sr-only">What are you looking for?</label>
            <input
                type="text"
                class="hero-search-input"
                id="hero-search"
                placeholder="e.g. 'Noise-cancelling headphones under ₹5,000'"
                autocomplete="off"
                aria-label="What are you looking for?"
            >
            <button class="hero-search-btn" id="hero-search-btn">
                Ask AI <i class="fa-solid fa-arrow-right"></i>
            </button>
        </div>

        <!-- Suggestion Pills -->
        <div class="hero-pills">
            <button class="hero-pill" onclick="document.getElementById('hero-search').value = this.innerText; document.getElementById('hero-search').focus();">Gaming laptop under ₹80k</button>
            <button class="hero-pill" onclick="document.getElementById('hero-search').value = this.innerText; document.getElementById('hero-search').focus();">Best wireless earbuds for running</button>
            <button class="hero-pill" onclick="document.getElementById('hero-search').value = this.innerText; document.getElementById('hero-search').focus();">Ergonomic office chair</button>
        </div>

        <div class="hero-trust">
            <span class="trust-item"><i class="fa-solid fa-bolt" style="color:var(--warning)"></i> Instant results</span>
            <span class="trust-item"><i class="fa-solid fa-shield" style="color:var(--success)"></i> Safe & secure</span>
            <span class="trust-item"><i class="fa-solid fa-users" style="color:var(--cyan)"></i> 10K+ shoppers</span>
            <span class="trust-item"><i class="fa-solid fa-truck" style="color:var(--purple-lt)"></i> Free delivery</span>
        </div>
    </div>
</section>

<!-- ======== CATEGORIES ======== -->
<div class="section-wrapper">
    <div class="section-header">
        <h2 class="section-title">Shop by Category</h2>
        <a href="/shop" class="section-see-all">View all <i class="fa-solid fa-arrow-right"></i></a>
    </div>
    <div class="categories-grid">
        <a href="/shop?category=Tech" class="category-card">
            <div class="category-icon">💻</div>
            <div class="category-name">Tech</div>
        </a>
        <a href="/shop?category=Clothing" class="category-card">
            <div class="category-icon">👕</div>
            <div class="category-name">Clothing</div>
        </a>
        <a href="/shop?category=Home" class="category-card">
            <div class="category-icon">🏡</div>
            <div class="category-name">Home</div>
        </a>
        <a href="/shop?category=Shoes" class="category-card">
            <div class="category-icon">👟</div>
            <div class="category-name">Shoes</div>
        </a>
        <a href="/shop?category=Books" class="category-card">
            <div class="category-icon">📚</div>
            <div class="category-name">Books</div>
        </a>
        <a href="/shop?category=Toys" class="category-card">
            <div class="category-icon">🧸</div>
            <div class="category-name">Toys</div>
        </a>
    </div>
</div>

<!-- ======== PRODUCTS ======== -->
<div class="section-wrapper">
    <div class="section-header">
        <h2 class="section-title">✨ AI Top Picks</h2>
        <a href="/shop" class="section-see-all">See all <i class="fa-solid fa-arrow-right"></i></a>
    </div>
    
    <div class="product-grid">
        <% if (products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <a href="/product/<%= product._id %>" class="product-card">
                    <% if (product.isFeatured) { %>
                        <span class="product-badge product-badge-ai">Hot</span>
                    <% } %>
                    <button class="product-wishlist" aria-label="Add to wishlist"><i class="fa-regular fa-heart"></i></button>
                    <div class="product-card-image">
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.title %>" loading="lazy" decoding="async" data-product-image>
                        <% } else { %>
                            <%= product.category.icon %>
                        <% } %>
                    </div>
                    <div class="product-card-body">
                        <span class="product-category-tag"><%= product.category.name %></span>
                        <h3 class="product-title"><%= product.title %></h3>
                        <div class="product-meta">
                            <span class="product-price">₹<%= product.price.toFixed(2) %></span>
                            <span class="product-rating">
                                <i class="fa-solid fa-star"></i> <%= product.ratings.average %>
                                <span class="product-rating-count">(<%= product.ratings.count %>)</span>
                            </span>
                        </div>
                        <button class="btn-add-cart" type="button" data-add-to-cart data-product-id="<%= product._id %>">
                            <i class="fa-solid fa-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </a>
            <% }) %>
        <% } else { %>
            <div class="shop-empty" style="grid-column: 1 / -1;">
                <div class="shop-empty-icon"><i class="fa-solid fa-box-open"></i></div>
                <h2>No Products Found</h2>
                <p>Check back later for exciting new products.</p>
            </div>
        <% } %>
    </div>
</div>

